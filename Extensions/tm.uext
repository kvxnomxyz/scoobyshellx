{
    "name": "Tape Maniac",
    "author": "kvxnom (Game design), Claude (Code)",
    "version": "1.0",
    "sig_ver": 2,
    "aid": "com.kvxnom.tape_maniac",
    "certcode": "C7CB24A958ABD26BE708EAC42ABB773942891B45A37DB00AD7F393F367A77F59",
    "description": "Tape factory idle/clicker. Spam R to roll tape. Progress bar, upgrades, achievements, auto-rollers, paste.rs multiplayer, save/load. Command: tape",
    "commands": [
        {
            "name": "tapemaniac",
            "description": "Launch Tape Maniac factory simulator",
            "action": "python",
            "value": "def _game():\n    import curses, json, os, pathlib, random, threading, time, urllib.request\n\n    SAVE_FILE  = pathlib.Path.home() / \".tape_maniac.tmf\"\n    PASTE_BASE = \"https://paste.rs/\"\n    ROLL_NEEDED = 100\n    BASE_CASH   = 1.50\n\n    UPGRADES = [\n        {\"id\":\"grip\",   \"name\":\"Sticky Fingers\", \"desc\":\"+2 tape/press\",         \"cost\":50,     \"tapPower\":2,  \"autoMs\":0,    \"cashMult\":0.0,  \"multBonus\":0.0},\n        {\"id\":\"wax\",    \"name\":\"Wax Coating\",     \"desc\":\"+4 tape/press\",         \"cost\":200,    \"tapPower\":4,  \"autoMs\":0,    \"cashMult\":0.0,  \"multBonus\":0.0},\n        {\"id\":\"auto1\",  \"name\":\"Speed Dispenser\", \"desc\":\"Auto-roll every 4s\",    \"cost\":500,    \"tapPower\":0,  \"autoMs\":4000, \"cashMult\":0.0,  \"multBonus\":0.0},\n        {\"id\":\"bulk\",   \"name\":\"Bulk Core\",       \"desc\":\"+30% cash/roll\",        \"cost\":1000,   \"tapPower\":0,  \"autoMs\":0,    \"cashMult\":0.30, \"multBonus\":0.0},\n        {\"id\":\"turbo\",  \"name\":\"Turbo Arm\",       \"desc\":\"+10 tape/press\",        \"cost\":2500,   \"tapPower\":10, \"autoMs\":0,    \"cashMult\":0.0,  \"multBonus\":0.0},\n        {\"id\":\"auto2\",  \"name\":\"Mini Factory\",    \"desc\":\"Auto-roll every 1.5s\",  \"cost\":8000,   \"tapPower\":0,  \"autoMs\":1500, \"cashMult\":0.0,  \"multBonus\":0.0},\n        {\"id\":\"chrome\", \"name\":\"Chrome Roll\",     \"desc\":\"+0.5x multiplier\",      \"cost\":20000,  \"tapPower\":0,  \"autoMs\":0,    \"cashMult\":0.0,  \"multBonus\":0.5},\n        {\"id\":\"alien\",  \"name\":\"Alien Adhesive\",  \"desc\":\"+25 tape/press\",        \"cost\":75000,  \"tapPower\":25, \"autoMs\":0,    \"cashMult\":0.0,  \"multBonus\":0.0},\n        {\"id\":\"auto3\",  \"name\":\"Mega Mill\",       \"desc\":\"Auto-roll every 0.5s\",  \"cost\":200000, \"tapPower\":0,  \"autoMs\":500,  \"cashMult\":0.0,  \"multBonus\":0.0},\n        {\"id\":\"golden\", \"name\":\"Golden Cylinder\", \"desc\":\"+2x multi +100% cash\", \"cost\":500000, \"tapPower\":0,  \"autoMs\":0,    \"cashMult\":1.0,  \"multBonus\":2.0},\n    ]\n\n    ACHIEVEMENTS = [\n        {\"id\":\"first\",  \"name\":\"First Roll!\",      \"desc\":\"Complete your first roll\", \"rolls\":1,       \"earned\":0,       \"upgcount\":0},\n        {\"id\":\"r10\",    \"name\":\"10 Rolls Deep\",    \"desc\":\"Complete 10 rolls\",        \"rolls\":10,      \"earned\":0,       \"upgcount\":0},\n        {\"id\":\"r100\",   \"name\":\"Century\",           \"desc\":\"Complete 100 rolls\",       \"rolls\":100,     \"earned\":0,       \"upgcount\":0},\n        {\"id\":\"r1000\",  \"name\":\"Tape Overlord\",    \"desc\":\"1000 rolls\",               \"rolls\":1000,    \"earned\":0,       \"upgcount\":0},\n        {\"id\":\"cash100\",\"name\":\"First Paycheck\",   \"desc\":\"Earn $100\",                \"rolls\":0,       \"earned\":100,     \"upgcount\":0},\n        {\"id\":\"cash10k\",\"name\":\"High Roller\",      \"desc\":\"Earn $10,000\",             \"rolls\":0,       \"earned\":10000,   \"upgcount\":0},\n        {\"id\":\"cash1m\", \"name\":\"Tape Millionaire\", \"desc\":\"Earn $1,000,000\",          \"rolls\":0,       \"earned\":1000000, \"upgcount\":0},\n        {\"id\":\"auto\",   \"name\":\"Automated\",        \"desc\":\"Own any auto-roller\",      \"rolls\":0,       \"earned\":0,       \"upgcount\":0, \"needauto\":True},\n        {\"id\":\"mult3\",  \"name\":\"Multiplied\",       \"desc\":\"Reach 3x multiplier\",      \"rolls\":0,       \"earned\":0,       \"upgcount\":0, \"needmult\":3.0},\n        {\"id\":\"allup\",  \"name\":\"Fully Loaded\",     \"desc\":\"Buy all upgrades\",         \"rolls\":0,       \"earned\":0,       \"upgcount\":10},\n    ]\n\n    MILESTONES = [\n        (10,   \"Tape Trainee\"),\n        (50,   \"Tape Technician\"),\n        (100,  \"Tape Engineer\"),\n        (500,  \"Tape Director\"),\n        (1000, \"Tape Baron\"),\n        (5000, \"TAPE MANIAC\"),\n    ]\n\n    def get_rank(rolls):\n        rank = \"Tape Rookie\"\n        for n, r in MILESTONES:\n            if rolls >= n: rank = r\n        return rank\n\n    def fmt(n):\n        if n >= 1e9: return \"$%.2fB\" % (n/1e9)\n        if n >= 1e6: return \"$%.2fM\" % (n/1e6)\n        if n >= 1e3: return \"$%.1fK\" % (n/1e3)\n        return \"$%.2f\" % n\n\n    def compute_stats(owned):\n        tap=1; cm=1.0; mb=0.0; autos=[]\n        for uid in owned:\n            u=next((x for x in UPGRADES if x[\"id\"]==uid),None)\n            if not u: continue\n            tap+=u[\"tapPower\"]; cm+=u[\"cashMult\"]; mb+=u[\"multBonus\"]\n            if u[\"autoMs\"]>0: autos.append(u[\"autoMs\"])\n        return tap,cm,mb,autos\n\n    def save_game(st):\n        try: SAVE_FILE.write_text(json.dumps(st), encoding=\"utf-8\")\n        except: pass\n\n    def load_game():\n        try: return json.loads(SAVE_FILE.read_text(encoding=\"utf-8\"))\n        except: return None\n\n    def default_state(name=\"Factory\"):\n        return {\"name\":name,\"tape\":0,\"rolls\":0,\"totalRolls\":0,\"cash\":0.0,\n                \"totalEarned\":0.0,\"multiplier\":1.0,\"upgrades\":[],\"achievements\":[]}\n\n    _key=[None]; _opps={}; _lock=threading.Lock(); _stop=threading.Event()\n\n    def pb_post(txt):\n        try:\n            req=urllib.request.Request(PASTE_BASE,data=txt.encode(),method=\"POST\",\n                headers={\"Content-Type\":\"text/plain; charset=utf-8\"})\n            with urllib.request.urlopen(req,timeout=8) as r:\n                url=r.read().decode().strip()\n            if url.startswith(PASTE_BASE): return url[len(PASTE_BASE):]\n        except: pass\n        return None\n\n    def pb_get(key):\n        try:\n            req=urllib.request.Request(PASTE_BASE+key,headers={\"User-Agent\":\"tape_maniac/1.0\"})\n            with urllib.request.urlopen(req,timeout=8) as r: return r.read().decode()\n        except: return None\n\n    def pb_del(key):\n        try:\n            req=urllib.request.Request(PASTE_BASE+key,method=\"DELETE\")\n            with urllib.request.urlopen(req,timeout=8) as r: r.read()\n        except: pass\n\n    def push(st):\n        blob={\"name\":st[\"name\"],\"totalRolls\":st[\"totalRolls\"],\"cash\":st[\"cash\"],\n              \"totalEarned\":st[\"totalEarned\"],\"multiplier\":st[\"multiplier\"],\n              \"upgrades\":len(st[\"upgrades\"])}\n        old=_key[0]; k=pb_post(json.dumps(blob))\n        if k:\n            if old and old!=k: threading.Thread(target=pb_del,args=(old,),daemon=True).start()\n            _key[0]=k\n        return k\n\n    def poll(opp_keys):\n        while not _stop.is_set():\n            for nm,k in list(opp_keys.items()):\n                raw=pb_get(k)\n                if raw:\n                    try:\n                        with _lock: _opps[nm]=json.loads(raw)\n                    except: pass\n            _stop.wait(10)\n\n    def parse_keys(raw):\n        out={}\n        for part in raw.split(\",\"):\n            part=part.strip()\n            if \"|\" in part:\n                nm,k=part.split(\"|\",1); out[nm.strip()]=k.strip()\n            elif part: out[\"P_\"+part[:6]]=part\n        return out\n\n    def run(stdscr, state, opp_keys):\n        curses.curs_set(0); stdscr.nodelay(True); stdscr.keypad(True)\n        curses.start_color(); curses.use_default_colors()\n        curses.init_pair(1,curses.COLOR_WHITE,  -1)\n        curses.init_pair(2,curses.COLOR_GREEN,  -1)\n        curses.init_pair(3,curses.COLOR_YELLOW, -1)\n        curses.init_pair(4,curses.COLOR_CYAN,   -1)\n        curses.init_pair(5,curses.COLOR_RED,    -1)\n        curses.init_pair(6,curses.COLOR_MAGENTA,-1)\n        curses.init_pair(7,curses.COLOR_BLACK,  curses.COLOR_YELLOW)\n        curses.init_pair(8,curses.COLOR_BLACK,  curses.COLOR_GREEN)\n        curses.init_pair(9,curses.COLOR_WHITE,  curses.COLOR_BLUE)\n        curses.init_pair(10,curses.COLOR_BLACK, curses.COLOR_WHITE)\n\n        cW=curses.color_pair(1); G=curses.color_pair(2); Y=curses.color_pair(3)\n        C=curses.color_pair(4);  R=curses.color_pair(5); M=curses.color_pair(6)\n        YB=curses.color_pair(7); GB=curses.color_pair(8)\n        BL=curses.color_pair(9); WB=curses.color_pair(10)\n\n        tape=[state[\"tape\"]]; rolls=[state[\"rolls\"]]; tr=[state[\"totalRolls\"]]\n        cash=[state[\"cash\"]]; te=[state[\"totalEarned\"]]; mult=[state[\"multiplier\"]]\n        upg=[list(state[\"upgrades\"])]; ach=[list(state[\"achievements\"])]\n        tab=[0]; notif=[\"\"];ntick=[0]; flash=[0]; panim=[0]; tick=[0]\n        nach=[\"\"];natick=[0]; atimers=[{}]\n\n        TABS=[\"[R] FACTORY\",\"[S] SHOP\",\"[A] MEDALS\",\"[L] RIVALS\"]\n\n        def gst(): return compute_stats(upg[0])\n\n        def do_roll():\n            tp,cm,mb,_=gst(); em=mult[0]+mb; earned=BASE_CASH*cm*em\n            tape[0]=0; rolls[0]+=1; tr[0]+=1\n            cash[0]+=earned; te[0]+=earned\n            mult[0]=round(1.0+(tr[0]//10)*0.1,1)\n            flash[0]=8; notif[0]=\"+%s ROLL!\" % fmt(earned); ntick[0]=50\n            chk_ach()\n            sn=snap(); threading.Thread(target=push,args=(sn,),daemon=True).start()\n\n        def snap():\n            return {\"name\":state[\"name\"],\"tape\":tape[0],\"rolls\":rolls[0],\n                    \"totalRolls\":tr[0],\"cash\":cash[0],\"totalEarned\":te[0],\n                    \"multiplier\":mult[0],\"upgrades\":upg[0],\"achievements\":ach[0]}\n\n        def press():\n            tp,_,_,_=gst()\n            tape[0]=min(tape[0]+tp,ROLL_NEEDED)\n            panim[0]=4\n            if tape[0]>=ROLL_NEEDED: do_roll()\n\n        def chk_ach():\n            ucount=len(upg[0])\n            has_auto=any(u in upg[0] for u in [\"auto1\",\"auto2\",\"auto3\"])\n            eff=mult[0]+gst()[2]\n            for a in ACHIEVEMENTS:\n                if a[\"id\"] in ach[0]: continue\n                ok=True\n                if a.get(\"rolls\",0)>0   and tr[0]<a[\"rolls\"]:    ok=False\n                if a.get(\"earned\",0)>0  and te[0]<a[\"earned\"]:   ok=False\n                if a.get(\"upgcount\",0)>0 and ucount<a[\"upgcount\"]:ok=False\n                if a.get(\"needauto\") and not has_auto:             ok=False\n                if a.get(\"needmult\",0)>0 and eff<a[\"needmult\"]:   ok=False\n                if ok: ach[0].append(a[\"id\"]); nach[0]=a[\"name\"]; natick[0]=80\n\n        def buy(uid):\n            if uid in upg[0]: notif[0]=\"Already owned!\";ntick[0]=40;return\n            u=next((x for x in UPGRADES if x[\"id\"]==uid),None)\n            if not u: return\n            if cash[0]<u[\"cost\"]: notif[0]=\"Need %s!\" % fmt(u[\"cost\"]);ntick[0]=40;return\n            cash[0]-=u[\"cost\"]; upg[0].append(uid)\n            notif[0]=\"Bought: %s!\" % u[\"name\"]; ntick[0]=60; chk_ach()\n\n        def auto_thread():\n            while not _stop.is_set():\n                time.sleep(0.1)\n                _,_,_,autos=gst(); now=time.monotonic()\n                for i,ms in enumerate(autos):\n                    k=\"a%d\"%i; last=atimers[0].get(k,0)\n                    if now-last>=ms/1000.0:\n                        atimers[0][k]=now\n                        tp,_,_,_=gst()\n                        tape[0]=min(tape[0]+tp,ROLL_NEEDED)\n                        if tape[0]>=ROLL_NEEDED: do_roll()\n\n        threading.Thread(target=auto_thread,daemon=True).start()\n\n        def sa(y,x,txt,a=0):\n            H,SW=stdscr.getmaxyx(); txt=str(txt)\n            if y<0 or y>=H or x>=SW: return\n            if x<0: txt=txt[-x:]; x=0\n            txt=txt[:SW-x-1]\n            try: stdscr.addstr(y,x,txt,a)\n            except: pass\n\n        last_save=time.monotonic()\n\n        while True:\n            tick[0]+=1\n            if ntick[0]>0:  ntick[0]-=1\n            if flash[0]>0:  flash[0]-=1\n            if panim[0]>0:  panim[0]-=1\n            if natick[0]>0: natick[0]-=1\n            if time.monotonic()-last_save>30:\n                save_game(snap()); last_save=time.monotonic()\n\n            stdscr.erase()\n            H,SW=stdscr.getmaxyx()\n            if H<20 or SW<55:\n                sa(0,0,\"Terminal too small (need 55x20)\",R|curses.A_BOLD)\n                stdscr.refresh(); time.sleep(0.05); stdscr.getch(); continue\n\n            tp,cm,mb,autos=gst()\n            em=mult[0]+mb; cpr=BASE_CASH*cm*em\n            pct=tape[0]/ROLL_NEEDED; rank=get_rank(tr[0])\n\n            # title bar\n            title=\" TAPE MANIAC // tape // %s // %s\" % (state[\"name\"],rank)\n            sa(0,0,title.ljust(SW-1),BL|curses.A_BOLD)\n\n            # tabs\n            tx=0\n            for i,tn in enumerate(TABS):\n                sa(1,tx,\" \"+tn+\" \", WB|curses.A_BOLD if tab[0]==i else cW|curses.A_DIM)\n                tx+=len(tn)+3\n            sa(2,0,\"-\"*(SW-1),M|curses.A_DIM)\n\n            # notif\n            if natick[0]>0:\n                msg=\" ** ACHIEVEMENT: %s! **\" % nach[0]\n                sa(3,(SW-len(msg))//2,msg,YB|curses.A_BOLD)\n            elif ntick[0]>0 and notif[0]:\n                sa(3,2,notif[0],Y|curses.A_BOLD)\n            else:\n                sa(3,2,\"Cash: %s  |  %.1fx  |  %d rolls\" % (fmt(cash[0]),em,tr[0]),G)\n\n            # ==== GAME TAB ====\n            if tab[0]==0:\n                mid=SW//2; cyw=14; cyh=12; cyx=mid-cyw//2; cyy=5\n                fill=int(pct*(cyh-2))\n                battr=(Y|curses.A_BOLD) if flash[0]>0 else (cW|curses.A_DIM)\n\n                # cylinder box (pure ascii)\n                sa(cyy,   cyx,\"+\"+\"-\"*(cyw-2)+\"+\",battr)\n                for i in range(1,cyh-1):\n                    row_i=cyh-1-i  # 1 at bottom\n                    sa(cyy+i,cyx,\"|\")\n                    if row_i<=fill:\n                        fc=\"#\" if row_i==fill else \"=\"\n                        sa(cyy+i,cyx+1,fc*(cyw-2),GB|curses.A_BOLD)\n                    else:\n                        sa(cyy+i,cyx+1,\".\"*(cyw-2),cW|curses.A_DIM)\n                    sa(cyy+i,cyx+cyw-1,\"|\")\n                sa(cyy+cyh-1,cyx,\"+\"+\"-\"*(cyw-2)+\"+\",battr)\n                sa(cyy,cyx+2,\" ROLL #%d \" % (rolls[0]+1),Y|curses.A_BOLD)\n                sa(cyy+cyh,cyx,\" %.1f%%  %d/%d \" % (pct*100,tape[0],ROLL_NEEDED),G|curses.A_BOLD)\n\n                # progress bar\n                pby=cyy+cyh+2; pbw=min(SW-6,48); pbx=(SW-pbw)//2\n                filled=int(pct*pbw)\n                sa(pby,pbx,\"[\",Y|curses.A_BOLD)\n                sa(pby,pbx+1,\"#\"*filled,GB|curses.A_BOLD)\n                sa(pby,pbx+1+filled,\".\"*(pbw-filled),cW|curses.A_DIM)\n                sa(pby,pbx+pbw+1,\"]\",Y|curses.A_BOLD)\n                sa(pby+1,pbx,\"+%d tape/R\" % tp,C)\n                sa(pby+1,pbx+pbw-10,\"%s/roll\" % fmt(cpr),Y)\n\n                # R button\n                by=pby+3; is_a=panim[0]>0\n                btxt=\"  [ PRESS R TO ROLL ]  \" if not is_a else \"  [ ## ROLLING! ## ]  \"\n                bx=(SW-len(btxt))//2\n                sa(by,  bx,\"-\"*len(btxt),Y|curses.A_DIM)\n                sa(by+1,bx,btxt,(GB if is_a else YB)|curses.A_BOLD)\n                sa(by+2,bx,\"-\"*len(btxt),Y|curses.A_DIM)\n\n                # stats\n                sy=by+4\n                cols=[(\"ROLLS\",str(tr[0]),Y),(\"$/ROLL\",fmt(cpr),G),\n                      (\"TOTAL\",fmt(te[0]),C),(\"MULT\",\"%.1fx\"%em,M)]\n                cw2=(SW-2)//4\n                for i,(lb,vl,at) in enumerate(cols):\n                    cx=1+i*cw2\n                    sa(sy,  cx,lb.center(cw2-1),cW|curses.A_DIM)\n                    sa(sy+1,cx,vl.center(cw2-1),at|curses.A_BOLD)\n\n                # mult progress bar\n                my=sy+3; nin=10-(tr[0]%10); mw=28; mx=(SW-mw-22)//2\n                mf=(tr[0]%10)*mw//10\n                sa(my,mx,\"Next x0.1 in %d rolls: \" % nin,cW|curses.A_DIM)\n                sa(my,mx+22,\"[\"+\"#\"*mf+\"-\"*(mw-mf)+\"]\",M)\n                if autos:\n                    sa(my+1,mx,\" AUTO: %d roller(s) active\" % len(autos),C|curses.A_BOLD)\n\n            # ==== SHOP TAB ====\n            elif tab[0]==1:\n                sa(4,2,\"Cash: %s\" % fmt(cash[0]),Y|curses.A_BOLD)\n                sa(5,2,\"-\"*(SW-4),M|curses.A_DIM)\n                for i,u in enumerate(UPGRADES):\n                    row=6+i*2\n                    if row>=H-2: break\n                    owned=u[\"id\"] in upg[0]; can=cash[0]>=u[\"cost\"]\n                    tag=\" [OWNED] \" if owned else \" [%s] \" % fmt(u[\"cost\"])\n                    if owned:   na=G|curses.A_DIM;  ta=G\n                    elif can:   na=cW|curses.A_BOLD; ta=Y|curses.A_BOLD\n                    else:       na=cW|curses.A_DIM;  ta=R|curses.A_DIM\n                    nm_str=\" %s.  %-20s %-28s\" % (\"0\" if i==9 else str(i+1), u[\"name\"], u[\"desc\"])\n                    sa(row,0,nm_str,na); sa(row,SW-len(tag)-1,tag,ta)\n                sa(H-2,2,\"Press 1-9, 0 to buy upgrades\",cW|curses.A_DIM)\n\n            # ==== MEDALS TAB ====\n            elif tab[0]==2:\n                cnt=len(ach[0]); tot=len(ACHIEVEMENTS)\n                sa(4,2,\"Unlocked: %d/%d\" % (cnt,tot),Y|curses.A_BOLD)\n                sa(5,2,\"-\"*(SW-4),M|curses.A_DIM)\n                for i,a in enumerate(ACHIEVEMENTS):\n                    row=6+i\n                    if row>=H-2: break\n                    ul=a[\"id\"] in ach[0]\n                    icon=\"*\" if ul else \"o\"\n                    nm=a[\"name\"] if ul else \"???\"\n                    ds=a[\"desc\"] if ul else \"???\"\n                    sa(row,2,\"%s %-22s %s\" % (icon,nm,ds),\n                       (Y|curses.A_BOLD) if ul else (cW|curses.A_DIM))\n\n            # ==== RIVALS TAB ====\n            elif tab[0]==3:\n                sa(4,2,\"RIVAL FACTORY STANDINGS\",C|curses.A_BOLD)\n                sa(5,2,\"-\"*(SW-4),M|curses.A_DIM)\n                sa(6,2,\" YOU  %-16s %6d rolls  %10s  %.1fx\" % (state[\"name\"],tr[0],fmt(cash[0]),mult[0]),\n                   Y|curses.A_BOLD)\n                row=7\n                with _lock: snap_opps=dict(_opps)\n                if snap_opps:\n                    for nm,st in sorted(snap_opps.items(),key=lambda x:-x[1].get(\"totalRolls\",0)):\n                        if row>=H-4: break\n                        sa(row,2,\"  %-18s %6d rolls  %10s  %.1fx\" % (\n                            nm,st.get(\"totalRolls\",0),fmt(st.get(\"cash\",0)),st.get(\"multiplier\",1)),cW)\n                        row+=1\n                else:\n                    sa(row,2,\"(no rivals -- share your paste.rs key)\",cW|curses.A_DIM); row+=1\n                if _key[0]:\n                    sa(row+1,2,\"Your key : paste.rs/%s\" % _key[0],C)\n                    sa(row+2,2,\"Share as : %s|%s\" % (state[\"name\"],_key[0]),C|curses.A_DIM)\n                sa(H-2,2,\"[P] Push score  [F] Refresh\",cW|curses.A_DIM)\n\n            # bottom bar\n            sa(H-2,0,\"-\"*(SW-1),M|curses.A_DIM)\n            hint=\" R=Roll S=Shop A=Medals L=Rivals F5=Save Q=Quit | %s %.1fx %d rolls\" % (fmt(cash[0]),em,tr[0])\n            sa(H-1,0,hint[:SW-1],cW|curses.A_DIM)\n\n            stdscr.refresh()\n\n            k=stdscr.getch()\n            if k==-1: time.sleep(0.016); continue\n            ch=chr(k).lower() if 0<=k<256 else \"\"\n\n            if ch==\"q\": save_game(snap()); break\n            elif k==curses.KEY_F5:\n                save_game(snap()); notif[0]=\"Saved!\"; ntick[0]=50\n\n            elif ch==\"r\" and tab[0]!=0: tab[0]=0\n            elif ch==\"s\" and tab[0]!=1: tab[0]=1\n            elif ch==\"a\" and tab[0]!=2: tab[0]=2\n            elif ch==\"l\" and tab[0]!=3: tab[0]=3\n\n            elif tab[0]==0:\n                if ch in(\"r\",\" \"): press()\n            elif tab[0]==1:\n                if ch.isdigit():\n                    idx=int(ch)-1\n                    if idx==-1: idx=9\n                    if 0<=idx<len(UPGRADES): buy(UPGRADES[idx][\"id\"])\n            elif tab[0]==3:\n                if ch in(\"p\",\"f\"):\n                    k2=push(snap())\n                    if k2: notif[0]=\"Pushed! Key: %s\" % k2; ntick[0]=70\n                    else:  notif[0]=\"paste.rs offline\"; ntick[0]=50\n\n    # LOBBY (plain terminal, ascii only)\n    os.system(\"cls\" if os.name==\"nt\" else \"clear\")\n    print(\"\\033[93m\\033[1m\")\n    print(\"  +----------------------------------------------+\")\n    print(\"  |  TAPE MANIAC  //  tape  //  v1.0            |\")\n    print(\"  |  Spam R to roll. Buy upgrades. Beat rivals. |\")\n    print(\"  |                             kvxnom          |\")\n    print(\"  +----------------------------------------------+\")\n    print(\"\\033[0m\")\n    print(\"  \\033[92m[N]\\033[0m  New factory\")\n    print(\"  \\033[93m[C]\\033[0m  Continue saved\")\n    print(\"  \\033[94m[M]\\033[0m  Multiplayer\")\n    print(\"  \\033[91m[Q]\\033[0m  Quit\")\n    print()\n    mode=input(\"  > \").strip().lower()\n    if mode==\"q\": return\n\n    opp_keys={}; state=None\n\n    if mode==\"c\":\n        saved=load_game()\n        if saved:\n            state=saved\n            print(\"\\033[92m  Loaded: %s  %d rolls  %s\\033[0m\" % (state[\"name\"],state[\"totalRolls\"],fmt(state[\"cash\"])))\n        else:\n            print(\"\\033[93m  No save found.\\033[0m\")\n            name=input(\"  Factory name: \").strip() or \"Factory\"\n            state=default_state(name)\n    elif mode==\"m\":\n        print(\"\\n  \\033[92m[H]\\033[0m Host   \\033[94m[J]\\033[0m Join\")\n        sub=input(\"  > \").strip().lower()\n        if sub==\"h\":\n            name=input(\"  Factory name: \").strip() or \"Factory\"\n            state=default_state(name)\n            k=push(state)\n            if k:\n                print(\"\\n\\033[97m\\033[1m  Your key : paste.rs/%s\" % k)\n                print(\"  Share as : %s|%s\\033[0m\\n\" % (name,k))\n            else:\n                print(\"\\033[93m  paste.rs offline.\\033[0m\")\n        else:\n            saved=load_game()\n            if saved: state=saved; print(\"\\033[92m  Loaded: %s\\033[0m\" % state[\"name\"])\n            else:\n                name=input(\"  Factory name: \").strip() or \"Factory\"\n                state=default_state(name)\n            k=push(state)\n            if k:\n                print(\"\\n\\033[97m\\033[1m  Your key : paste.rs/%s\" % k)\n                print(\"  Share as : %s|%s\\033[0m\\n\" % (state[\"name\"],k))\n        raw=input(\"  Rival keys (Name|Key, comma-sep, ENTER=skip): \").strip()\n        opp_keys=parse_keys(raw)\n    else:\n        name=input(\"  Factory name: \").strip() or \"Factory\"\n        state=default_state(name)\n\n    input(\"  Press ENTER to open factory...\")\n    if opp_keys:\n        threading.Thread(target=poll,args=(opp_keys,),daemon=True).start()\n\n    curses.wrapper(run, state, opp_keys)\n    _stop.set()\n\n    if _key[0]:\n        k=_key[0]\n        threading.Thread(target=lambda:(__import__(\"time\").sleep(300),pb_del(k)),daemon=True).start()\n\n    os.system(\"cls\" if os.name==\"nt\" else \"clear\")\n    print(\"\\033[93m  Thanks for playing TAPE MANIAC!\\033[0m\")\n    print()\n\n_game()\n"
        }
    ]
}
