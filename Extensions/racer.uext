{
    "name": "KX Racer",
    "author": "kvxnom (Game design), Claude (Code)",
    "version": "1.0",
    "description": "GT1-style pseudo-3D road racer in curses. 5 cars (Civic/Supra/GTR/Viper/F40), 3 tracks, lap timer, best-lap save, paste.rs MP rivals. W/S=gas/brake A/D=steer. Command: race",
    "commands": [
        {
            "name": "race",
            "description": "Launch KX Racer - GT style road racing",
            "action": "python",
            "value": "def _game():\n    import curses, json, os, pathlib, random, threading, time, urllib.request\n\n    SAVE_FILE  = pathlib.Path.home() / \".kxracer.sav\"\n    PASTE_BASE = \"https://paste.rs/\"\n\n    CARS = [\n        {\"id\":\"civic\",  \"name\":\"Honda Civic   \",\"spd\":6.0,\"acc\":0.45,\"brk\":0.55,\"grip\":0.80,\"col\":2},\n        {\"id\":\"supra\",  \"name\":\"Toyota Supra  \",\"spd\":7.5,\"acc\":0.40,\"brk\":0.50,\"grip\":0.75,\"col\":3},\n        {\"id\":\"gtr\",    \"name\":\"Nissan GT-R   \",\"spd\":8.5,\"acc\":0.50,\"brk\":0.60,\"grip\":0.85,\"col\":4},\n        {\"id\":\"viper\",  \"name\":\"Dodge Viper   \",\"spd\":9.5,\"acc\":0.35,\"brk\":0.45,\"grip\":0.65,\"col\":5},\n        {\"id\":\"f40\",    \"name\":\"Ferrari F40   \",\"spd\":10.0,\"acc\":0.55,\"brk\":0.55,\"grip\":0.70,\"col\":1},\n    ]\n\n    # curve: negative=left, positive=right; width=road width in units\n    TRACKS = {\n        \"Trial Hill\":[\n            (0,22),(0,22),(1,20),(1,20),(0,22),(-1,20),(-1,20),(0,22),\n            (0,24),(1,18),(0,22),(-1,18),(0,24),(0,22),(0,22),(0,22),\n        ],\n        \"City Loop\":[\n            (0,20),(0,20),(2,16),(2,16),(0,20),(0,20),(-2,16),(-2,16),\n            (0,20),(1,18),(0,20),(-1,18),(0,20),(2,14),(0,20),(-2,14),\n        ],\n        \"Grand Circuit\":[\n            (0,24),(0,24),(0,24),(1,20),(1,20),(2,16),(2,16),(0,22),\n            (0,22),(-1,20),(-1,20),(-2,16),(0,24),(0,24),(1,18),(0,22),\n            (-1,18),(0,24),(2,14),(-2,14),(0,24),(0,24),(0,24),(0,24),\n        ],\n    }\n    TRACK_NAMES = list(TRACKS.keys())\n    LAPS_DEF = 3\n\n    _key=[None]; _opps={}; _lock=threading.Lock(); _stop=threading.Event()\n\n    def pb_post(txt):\n        try:\n            req=urllib.request.Request(PASTE_BASE,data=txt.encode(),method=\"POST\",\n                headers={\"Content-Type\":\"text/plain; charset=utf-8\"})\n            with urllib.request.urlopen(req,timeout=8) as r:\n                url=r.read().decode().strip()\n            if url.startswith(PASTE_BASE): return url[len(PASTE_BASE):]\n        except: pass\n        return None\n\n    def pb_get(key):\n        try:\n            req=urllib.request.Request(PASTE_BASE+key,headers={\"User-Agent\":\"kxracer/1.0\"})\n            with urllib.request.urlopen(req,timeout=8) as r: return r.read().decode()\n        except: return None\n\n    def pb_del(key):\n        try:\n            req=urllib.request.Request(PASTE_BASE+key,method=\"DELETE\")\n            with urllib.request.urlopen(req,timeout=8) as r: r.read()\n        except: pass\n\n    def push_blob(blob):\n        old=_key[0]; k=pb_post(json.dumps(blob))\n        if k:\n            if old and old!=k: threading.Thread(target=pb_del,args=(old,),daemon=True).start()\n            _key[0]=k\n        return k\n\n    def poll(opp_keys):\n        while not _stop.is_set():\n            for nm,k in list(opp_keys.items()):\n                raw=pb_get(k)\n                if raw:\n                    try:\n                        with _lock: _opps[nm]=json.loads(raw)\n                    except: pass\n            _stop.wait(8)\n\n    def parse_keys(raw):\n        out={}\n        for part in raw.split(\",\"):\n            part=part.strip()\n            if \"|\" in part:\n                nm,k=part.split(\"|\",1); out[nm.strip()]=k.strip()\n            elif part: out[\"R_\"+part[:6]]=part\n        return out\n\n    def save_data(d):\n        try: SAVE_FILE.write_text(json.dumps(d),encoding=\"utf-8\")\n        except: pass\n\n    def load_data():\n        try: return json.loads(SAVE_FILE.read_text(encoding=\"utf-8\"))\n        except: return {}\n\n    def fmt_time(s):\n        if s is None: return \"--:--.---\"\n        m=int(s)//60; sec=s-m*60\n        return \"%d:%06.3f\" % (m,sec)\n\n    def build_road_lines(H, W, segments, cam_pos, curve_acc):\n        lines=[]\n        n=len(segments)\n        proj_h=H-8\n        x_offset=0.0\n        for row in range(proj_h):\n            depth_t=(proj_h-1-row)/(proj_h) if proj_h>1 else 0\n            depth=1.0+depth_t*150.0\n            seg_dist=cam_pos+depth*0.12\n            seg_idx=int(seg_dist) % n\n            seg_curve,seg_w=segments[seg_idx]\n            # perspective scale\n            scale=1.0/(1.0+depth_t*2.5)\n            road_w=max(4,int(seg_w*scale*(W//20)))\n            road_w=min(road_w,W-4)\n            # horizontal shift from curve\n            x_offset+=seg_curve*scale*0.6\n            center=W//2+int(x_offset*0.4+curve_acc*2)\n            left_x=center-road_w//2\n            left_x=max(0,min(left_x,W-road_w-1))\n            is_rumble=(int(seg_dist*0.8)%2==0)\n            lines.append((left_x,road_w,seg_idx,is_rumble))\n        return lines\n\n    def run_race(stdscr, player_name, car, track_name, laps_total, opp_keys, save_d):\n        curses.curs_set(0); stdscr.nodelay(True); stdscr.keypad(True)\n        curses.start_color(); curses.use_default_colors()\n        curses.init_pair(1, curses.COLOR_WHITE,   -1)\n        curses.init_pair(2, curses.COLOR_GREEN,   -1)\n        curses.init_pair(3, curses.COLOR_YELLOW,  -1)\n        curses.init_pair(4, curses.COLOR_CYAN,    -1)\n        curses.init_pair(5, curses.COLOR_RED,     -1)\n        curses.init_pair(6, curses.COLOR_MAGENTA, -1)\n        curses.init_pair(7, curses.COLOR_BLACK,   curses.COLOR_WHITE)\n        curses.init_pair(8, curses.COLOR_BLACK,   curses.COLOR_YELLOW)\n        curses.init_pair(9, curses.COLOR_WHITE,   curses.COLOR_BLUE)\n        curses.init_pair(10,curses.COLOR_BLACK,   curses.COLOR_GREEN)\n        curses.init_pair(11,curses.COLOR_BLACK,   curses.COLOR_RED)\n        curses.init_pair(12,curses.COLOR_BLACK,   curses.COLOR_WHITE)\n\n        cW=curses.color_pair(1); cG=curses.color_pair(2); cY=curses.color_pair(3)\n        cC=curses.color_pair(4); cR=curses.color_pair(5); cM=curses.color_pair(6)\n        ROAD=curses.color_pair(7); RMB=curses.color_pair(8)\n        TITLE=curses.color_pair(9); GRASS=curses.color_pair(10)\n        DANGER=curses.color_pair(11); SKY=curses.color_pair(12)\n\n        CAR_PAIR=[cW,cG,cY,cC,cR,cM]\n        car_col=CAR_PAIR[car[\"col\"]%6]\n\n        segments=TRACKS[track_name]; n_seg=len(segments)\n\n        pos=[0.0]; speed=[0.0]; lateral=[0.0]\n        lap=[0]; lap_start=[time.monotonic()]; race_start=[None]\n        finished=[False]; best_lap=[save_d.get(\"best_\"+track_name)]\n        lap_times=[]; gear=[1]; off_road=[False]; off_tick=[0]\n        countdown=[3]; cd_t=[time.monotonic()]\n        notif=[\"\"]; ntick=[0]; curve_acc=[0.0]\n\n        MAX_SPD=car[\"spd\"]; ACC=car[\"acc\"]; BRK=car[\"brk\"]; GRIP=car[\"grip\"]\n        last_push=[time.monotonic()]; last_t=[time.monotonic()]\n\n        def sa(y,x,txt,a=0):\n            H2,W2=stdscr.getmaxyx(); txt=str(txt)\n            if y<0 or y>=H2 or x>=W2: return\n            if x<0: txt=txt[-x:]; x=0\n            txt=txt[:W2-x-1]\n            try: stdscr.addstr(y,x,txt,a)\n            except: pass\n\n        def do_push():\n            blob={\"name\":player_name,\"lap\":lap[0],\"laps_total\":laps_total,\n                  \"speed\":int(speed[0]*30),\"track\":track_name,\n                  \"best\":best_lap[0],\"finished\":finished[0]}\n            threading.Thread(target=push_blob,args=(blob,),daemon=True).start()\n\n        while True:\n            now=time.monotonic()\n            dt=min(now-last_t[0],0.05); last_t[0]=now\n            H,W=stdscr.getmaxyx()\n\n            # countdown logic\n            if countdown[0]>0:\n                if now-cd_t[0]>=1.0:\n                    countdown[0]-=1; cd_t[0]=now\n                    if countdown[0]==0:\n                        race_start[0]=now; lap_start[0]=now\n\n            k=stdscr.getch()\n            ch=chr(k).lower() if 0<=k<256 else \"\"\n            if ch==\"q\": break\n            if finished[0] and ch==\" \": break\n\n            # physics\n            if countdown[0]==0 and not finished[0]:\n                steer=0\n                if k in(curses.KEY_LEFT, ord(\"a\"),ord(\"A\")): steer=-1\n                if k in(curses.KEY_RIGHT,ord(\"d\"),ord(\"D\")): steer= 1\n                accel=0\n                if k in(curses.KEY_UP,  ord(\"w\"),ord(\"W\")): accel= 1\n                if k in(curses.KEY_DOWN,ord(\"s\"),ord(\"S\")): accel=-1\n\n                if accel>0:   speed[0]=min(speed[0]+ACC*dt*55, MAX_SPD)\n                elif accel<0: speed[0]=max(speed[0]-BRK*dt*55, 0.0)\n                else:         speed[0]=max(speed[0]-0.07*dt*55, 0.0)\n\n                if off_road[0]:\n                    speed[0]=min(speed[0],MAX_SPD*0.35)\n                    off_tick[0]=max(off_tick[0]-dt,0)\n                    if off_tick[0]<=0: off_road[0]=False\n\n                seg_i=int(pos[0])%n_seg\n                seg_curve=segments[seg_i][0]\n                drift=seg_curve*speed[0]*(1.0-GRIP)*dt*0.4\n                lateral[0]+=steer*0.07*dt*55+drift\n                lateral[0]=max(-1.0,min(1.0,lateral[0]))\n\n                if abs(lateral[0])>0.88 and not off_road[0]:\n                    off_road[0]=True; off_tick[0]=0.8\n                    notif[0]=\"OFF ROAD!\"; ntick[0]=40\n\n                pos[0]+=speed[0]*dt\n                tlen=n_seg\n\n                if pos[0]>=tlen*(lap[0]+1):\n                    lt=now-lap_start[0]; lap_times.append(lt)\n                    lap[0]+=1; lap_start[0]=now\n                    notif[0]=\"LAP %d! %s\" % (lap[0],fmt_time(lt)); ntick[0]=80\n                    if best_lap[0] is None or lt<best_lap[0]:\n                        best_lap[0]=lt\n                        notif[0]=\"BEST LAP! \"+fmt_time(lt)\n                        save_d[\"best_\"+track_name]=lt; save_data(save_d)\n                    do_push()\n                    if lap[0]>=laps_total: finished[0]=True\n\n                spd_n=speed[0]/MAX_SPD\n                if   spd_n<0.2: gear[0]=1\n                elif spd_n<0.4: gear[0]=2\n                elif spd_n<0.6: gear[0]=3\n                elif spd_n<0.8: gear[0]=4\n                else:           gear[0]=5\n\n                curve_acc[0]=curve_acc[0]*0.88+seg_curve*speed[0]*0.12\n\n                if now-last_push[0]>5.0: do_push(); last_push[0]=now\n                if ntick[0]>0: ntick[0]-=1\n\n            # DRAW\n            stdscr.erase()\n            if H<18 or W<55:\n                sa(0,0,\"Terminal too small (need 55x18)\",cR|curses.A_BOLD)\n                stdscr.refresh(); time.sleep(0.05); continue\n\n            proj_h=H-8\n\n            # sky rows\n            sa(0,0,\" \"*(W-1),TITLE)\n            hdr=\" KX RACER // %s // %s // Lap %d/%d\" % (track_name,player_name,min(lap[0]+1,laps_total),laps_total)\n            sa(0,(W-len(hdr))//2,hdr,TITLE|curses.A_BOLD)\n            for row in range(1,3):\n                sa(row,0,\" \"*(W-1),SKY)\n            # simple horizon line\n            sa(2,0,\"-\"*(W-1),cC|curses.A_DIM)\n\n            # road\n            road_lines=build_road_lines(H,W,segments,pos[0],curve_acc[0])\n            for ri,(lx,rw,si,rumble) in enumerate(road_lines):\n                sr=3+ri\n                if sr>=H-6: break\n                # grass\n                if lx>0:    sa(sr,0,   \" \"*lx,GRASS)\n                if lx+rw<W: sa(sr,lx+rw,\" \"*(W-lx-rw-1),GRASS)\n                # road\n                rattr=RMB if rumble else ROAD\n                sa(sr,lx,\" \"*rw,rattr)\n                # center stripe\n                if not rumble and rw>8:\n                    cx=lx+rw//2\n                    if (int(pos[0]*4)+ri)%8<4:\n                        sa(sr,cx,\"|\",cW|curses.A_DIM)\n\n            # car sprite\n            car_row=H-9\n            car_cx=W//2+int(lateral[0]*(W//5))\n            car_cx=max(3,min(car_cx,W-6))\n            top=\"  _  \"; mid=\" [%s] \" % \"#\"; bot=\" --- \"\n            sa(car_row-1,car_cx-2,top, car_col|curses.A_BOLD)\n            sa(car_row,  car_cx-2,mid, car_col|curses.A_BOLD)\n            sa(car_row+1,car_cx-2,bot, car_col|curses.A_DIM)\n            if off_road[0] and int(now*8)%2==0:\n                sa(car_row,car_cx-2,mid,DANGER|curses.A_BOLD)\n\n            # HUD\n            hy=H-6\n            sa(hy,0,\"=\"*(W-1),cM|curses.A_DIM)\n            spd_kmh=int(speed[0]*30)\n            bw=18; bf=int(speed[0]/MAX_SPD*bw) if MAX_SPD>0 else 0\n            sbar=\"[%s%s]\" % (\"#\"*bf,\"-\"*(bw-bf))\n            sa(hy+1,0,\" SPD:%3d km/h %s G%d\" % (spd_kmh,sbar,gear[0]),cY|curses.A_BOLD)\n            rt=now-race_start[0] if race_start[0] else 0.0\n            sa(hy+2,0,\" TIME:%-12s BEST:%-12s\" % (fmt_time(rt),fmt_time(best_lap[0])),cW)\n            # rivals\n            with _lock: snop=dict(_opps)\n            if snop:\n                rv=\" RIVALS: \"+\"  \".join(\"%s L%d\" % (nm[:7],st.get(\"lap\",0)) for nm,st in list(snop.items())[:3])\n                sa(hy+2,W-min(len(rv)+1,W//2-1),rv,cC|curses.A_DIM)\n\n            # notif / hint\n            if ntick[0]>0 and notif[0]:\n                msg=\" \"+notif[0]+\" \"\n                sa(hy+3,(W-len(msg))//2,msg,RMB|curses.A_BOLD)\n            else:\n                sa(hy+3,0,\" W/S=Gas/Brake  A/D=Steer  Q=Quit\",cW|curses.A_DIM)\n\n            sa(H-2,0,\"=\"*(W-1),cM|curses.A_DIM)\n            spd_bar2=int(speed[0]/MAX_SPD*20) if MAX_SPD>0 else 0\n            sa(H-1,0,\"|\"+\">\"*spd_bar2+\" \"*(20-spd_bar2)+\"| \"+car[\"name\"].strip(),cG|curses.A_DIM)\n\n            # countdown overlay\n            if countdown[0]>0:\n                cx=W//2-6; cy=H//2-2\n                sa(cy,  cx,\"+------------+\",cY|curses.A_BOLD)\n                sa(cy+1,cx,\"|   READY %d  |\" % countdown[0],cY|curses.A_BOLD)\n                sa(cy+2,cx,\"+------------+\",cY|curses.A_BOLD)\n            elif countdown[0]==0 and race_start[0] and now-race_start[0]<0.8:\n                cx=W//2-6; cy=H//2-2\n                sa(cy,  cx,\"+------------+\",cG|curses.A_BOLD)\n                sa(cy+1,cx,\"|    GO!!!   |\",cG|curses.A_BOLD)\n                sa(cy+2,cx,\"+------------+\",cG|curses.A_BOLD)\n\n            # finish overlay\n            if finished[0]:\n                fx=max(0,W//2-14); fy=max(0,H//2-4)\n                total=sum(lap_times)\n                sa(fy,  fx,\"+----------------------------+\",cG|curses.A_BOLD)\n                sa(fy+1,fx,\"|   RACE FINISHED!           |\",cG|curses.A_BOLD)\n                sa(fy+2,fx,\"|   Total  %-18s|\" % fmt_time(total),cG)\n                sa(fy+3,fx,\"|   Best   %-18s|\" % fmt_time(best_lap[0]),cY|curses.A_BOLD)\n                sa(fy+4,fx,\"|   SPACE to continue        |\",cW|curses.A_DIM)\n                sa(fy+5,fx,\"+----------------------------+\",cG|curses.A_BOLD)\n\n            stdscr.refresh()\n            time.sleep(0.016)\n\n        return best_lap[0], lap_times\n\n    def car_select(stdscr):\n        curses.curs_set(0); stdscr.nodelay(False); stdscr.keypad(True)\n        curses.start_color(); curses.use_default_colors()\n        for i in range(1,7):\n            curses.init_pair(i,[curses.COLOR_WHITE,curses.COLOR_GREEN,curses.COLOR_YELLOW,\n                curses.COLOR_CYAN,curses.COLOR_RED,curses.COLOR_MAGENTA][i-1],-1)\n        curses.init_pair(9,curses.COLOR_WHITE,curses.COLOR_BLUE)\n        CAPS=[curses.color_pair(i) for i in range(1,7)]\n        sel=[0]\n        while True:\n            stdscr.erase(); H,W=stdscr.getmaxyx()\n            def sa(y,x,txt,a=0):\n                txt=str(txt)\n                if y<0 or y>=H or x>=W: return\n                try: stdscr.addstr(y,x,txt[:W-x-1],a)\n                except: pass\n            sa(0,0,\" KX RACER // Car Select \".center(W-1),curses.color_pair(9)|curses.A_BOLD)\n            sa(2,2,\"UP/DOWN = navigate    ENTER = select    Q = quit\")\n            for i,c in enumerate(CARS):\n                r=4+i*3; attr=CAPS[c[\"col\"]%6]|curses.A_BOLD if i==sel[0] else curses.color_pair(1)|curses.A_DIM\n                sa(r,  2,(\"%s  %s\" % (\">>>\" if i==sel[0] else \"   \",c[\"name\"])),attr)\n                sa(r+1,9,\"SPD:%4.1f  ACC:%4.2f  BRK:%4.2f  GRIP:%4.2f\" % (c[\"spd\"],c[\"acc\"],c[\"brk\"],c[\"grip\"]),attr)\n            stdscr.refresh()\n            k=stdscr.getch()\n            if k in(curses.KEY_UP,  ord(\"w\"),ord(\"W\")): sel[0]=(sel[0]-1)%len(CARS)\n            elif k in(curses.KEY_DOWN,ord(\"s\"),ord(\"S\")): sel[0]=(sel[0]+1)%len(CARS)\n            elif k in(10,13): return CARS[sel[0]]\n            elif k in(ord(\"q\"),ord(\"Q\")): return None\n\n    def track_select(stdscr):\n        curses.curs_set(0); stdscr.nodelay(False); stdscr.keypad(True)\n        curses.start_color(); curses.use_default_colors()\n        curses.init_pair(3,curses.COLOR_YELLOW,-1)\n        curses.init_pair(9,curses.COLOR_WHITE,curses.COLOR_BLUE)\n        sel=[0]\n        while True:\n            stdscr.erase(); H,W=stdscr.getmaxyx()\n            def sa(y,x,txt,a=0):\n                txt=str(txt)\n                if y<0 or y>=H or x>=W: return\n                try: stdscr.addstr(y,x,txt[:W-x-1],a)\n                except: pass\n            sa(0,0,\" KX RACER // Track Select \".center(W-1),curses.color_pair(9)|curses.A_BOLD)\n            sa(2,2,\"UP/DOWN = navigate    ENTER = select    Q = quit\")\n            for i,tn in enumerate(TRACK_NAMES):\n                r=4+i*2\n                attr=curses.color_pair(3)|curses.A_BOLD if i==sel[0] else curses.color_pair(1)|curses.A_DIM\n                sa(r,2,\"%s  %s  (%d segs)\" % (\">>>\" if i==sel[0] else \"   \",tn,len(TRACKS[tn])),attr)\n            stdscr.refresh()\n            k=stdscr.getch()\n            if k in(curses.KEY_UP,  ord(\"w\"),ord(\"W\")): sel[0]=(sel[0]-1)%len(TRACK_NAMES)\n            elif k in(curses.KEY_DOWN,ord(\"s\"),ord(\"S\")): sel[0]=(sel[0]+1)%len(TRACK_NAMES)\n            elif k in(10,13): return TRACK_NAMES[sel[0]]\n            elif k in(ord(\"q\"),ord(\"Q\")): return None\n\n    # LOBBY\n    os.system(\"cls\" if os.name==\"nt\" else \"clear\")\n    print(\"\\033[93m\\033[1m\")\n    print(\"  +--------------------------------------------------+\")\n    print(\"  |   KX RACER  //  GT Style  //  v1.0              |\")\n    print(\"  |   W/S = gas/brake    A/D = steer                |\")\n    print(\"  |   3 tracks, 5 cars, best-lap save, MP rivals    |\")\n    print(\"  |                                    kvxnom        |\")\n    print(\"  +--------------------------------------------------+\")\n    print(\"\\033[0m\")\n    save_d=load_data()\n    for tn in TRACK_NAMES:\n        bt=save_d.get(\"best_\"+tn)\n        if bt: print(\"  Best %-20s %s\" % (tn+\":\",fmt_time(bt)))\n    print()\n    print(\"  \\033[92m[R]\\033[0m  Race (solo)\")\n    print(\"  \\033[94m[M]\\033[0m  Multiplayer\")\n    print(\"  \\033[91m[Q]\\033[0m  Quit\")\n    print()\n    mode=input(\"  > \").strip().lower()\n    if mode==\"q\": return\n\n    opp_keys={}\n    player_name=input(\"  Driver name: \").strip() or \"Driver\"\n\n    if mode==\"m\":\n        print(\"\\n  \\033[92m[H]\\033[0m Host   \\033[94m[J]\\033[0m Join\")\n        sub=input(\"  > \").strip().lower()\n        dummy={\"name\":player_name,\"lap\":0,\"laps_total\":LAPS_DEF,\"speed\":0,\"track\":\"?\",\"best\":None,\"finished\":False}\n        k=push_blob(dummy)\n        if k:\n            print(\"\\n\\033[97m\\033[1m  Your key : paste.rs/%s\" % k)\n            print(\"  Share as : %s|%s\\033[0m\\n\" % (player_name,k))\n        else:\n            print(\"\\033[93m  paste.rs offline.\\033[0m\")\n        raw=input(\"  Rival keys (Name|Key, ENTER=skip): \").strip()\n        opp_keys=parse_keys(raw)\n\n    laps_str=input(\"  Laps [%d]: \" % LAPS_DEF).strip()\n    laps_total=int(laps_str) if laps_str.isdigit() and int(laps_str)>0 else LAPS_DEF\n\n    if opp_keys:\n        threading.Thread(target=poll,args=(opp_keys,),daemon=True).start()\n\n    input(\"  Press ENTER to select car...\")\n    car=curses.wrapper(car_select)\n    if car is None: _stop.set(); return\n\n    track_name=curses.wrapper(track_select)\n    if track_name is None: _stop.set(); return\n\n    best,lap_times=curses.wrapper(run_race,player_name,car,track_name,laps_total,opp_keys,save_d)\n    _stop.set()\n\n    if _key[0]:\n        kk=_key[0]\n        threading.Thread(target=lambda:(__import__(\"time\").sleep(120),pb_del(kk)),daemon=True).start()\n\n    os.system(\"cls\" if os.name==\"nt\" else \"clear\")\n    print(\"\\033[93m  Race over!  Driver: %s  Car: %s\\033[0m\" % (player_name,car[\"name\"].strip()))\n    if lap_times:\n        for i,lt in enumerate(lap_times): print(\"  Lap %d: %s\" % (i+1,fmt_time(lt)))\n        print(\"  Best : %s\" % fmt_time(best))\n    print()\n\n_game()\n"
        }
    ]
}