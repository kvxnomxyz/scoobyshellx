{
    "name": "XEngine",
    "author": "kvxnom (Design), Claude (Code)",
    "version": "1.0",
    "sig_ver": 2,
    "aid": "com.kvxnom.xengine",
    "certcode": "4757C50D792DD52B14B9505828ADD425369A102801AF0881C657402DA4C7B7C6",
    "description": "XEngine \u2014 CLI Raycaster Game Engine. Build maps, objects and scripts in the terminal editor, then play in Minecraft-style 3D raycasting (no external libraries). Windows & Linux compatible. Command: xengine",
    "commands": [
        {
            "name": "xengine",
            "description": "Launch XEngine \u2014 CLI raycaster game engine",
            "action": "python",
            "value": "def _game():\n    import os, sys, json, math, time, pathlib, threading, curses, random, copy, textwrap\n\n    # \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n    #  X E N G I N E  \u2014 CLI Raycaster Game Engine\n    #  Minecraft-style block raycaster rendered in the terminal with curses.\n    #  Includes: map editor, object editor, script editor, 3-D renderer.\n    #  Save format: .xworld (JSON)\n    # \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n\n    SAVE_DIR  = pathlib.Path.home() / \".xengine\"\n    SAVE_DIR.mkdir(exist_ok=True)\n\n    # \u2500\u2500 Block palette (id \u2192 display) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    BLOCKS = {\n        0: {\"name\":\"Air\",      \"solid\":False,\"sym\":\" \",\"shade\":[\"  \",\"  \",\"  \"],\"col\":0},\n        1: {\"name\":\"Stone\",    \"solid\":True, \"sym\":\"#\",\"shade\":[\"\u2588\u2588\",\"\u2593\u2593\",\"\u2592\u2592\"],\"col\":7},\n        2: {\"name\":\"Grass\",    \"solid\":True, \"sym\":\"G\",\"shade\":[\"\u2588\u2588\",\"\u2593\u2593\",\"\u2592\u2592\"],\"col\":2},\n        3: {\"name\":\"Dirt\",     \"solid\":True, \"sym\":\"D\",\"shade\":[\"\u2588\u2588\",\"\u2593\u2593\",\"\u2592\u2592\"],\"col\":3},\n        4: {\"name\":\"Wood\",     \"solid\":True, \"sym\":\"W\",\"shade\":[\"\u2588\u2588\",\"\u2593\u2593\",\"\u2592\u2592\"],\"col\":5},\n        5: {\"name\":\"Brick\",    \"solid\":True, \"sym\":\"B\",\"shade\":[\"\u2588\u2588\",\"\u2593\u2593\",\"\u2592\u2592\"],\"col\":4},\n        6: {\"name\":\"Sand\",     \"solid\":True, \"sym\":\"S\",\"shade\":[\"\u2588\u2588\",\"\u2593\u2593\",\"\u2592\u2592\"],\"col\":5},\n        7: {\"name\":\"Water\",    \"solid\":False,\"sym\":\"~\",\"shade\":[\"\u2592\u2592\",\"\u2591\u2591\",\"  \"],\"col\":6},\n        8: {\"name\":\"Glass\",    \"solid\":True, \"sym\":\"=\",\"shade\":[\"\u2591\u2591\",\"\u2591\u2591\",\"\u2591\u2591\"],\"col\":3},\n        9: {\"name\":\"Lava\",     \"solid\":False,\"sym\":\"*\",\"shade\":[\"\u2588\u2588\",\"\u2593\u2593\",\"\u2592\u2592\"],\"col\":4},\n        10:{\"name\":\"Snow\",     \"solid\":True, \"sym\":\"^\",\"shade\":[\"\u2588\u2588\",\"\u2593\u2593\",\"\u2592\u2592\"],\"col\":1},\n        11:{\"name\":\"Metal\",    \"solid\":True, \"sym\":\"M\",\"shade\":[\"\u2588\u2588\",\"\u2593\u2593\",\"\u2592\u2592\"],\"col\":6},\n        12:{\"name\":\"Door\",     \"solid\":True, \"sym\":\"+\",\"shade\":[\"\u2588\u2588\",\"\u2593\u2593\",\"\u2592\u2592\"],\"col\":3},\n        13:{\"name\":\"Chest\",    \"solid\":True, \"sym\":\"C\",\"shade\":[\"\u2588\u2588\",\"\u2593\u2593\",\"\u2592\u2592\"],\"col\":5},\n        14:{\"name\":\"Torch\",    \"solid\":False,\"sym\":\"i\",\"shade\":[\"ii\",\"i \",\"  \"],\"col\":5},\n        15:{\"name\":\"Bedrock\",  \"solid\":True, \"sym\":\"X\",\"shade\":[\"\u2588\u2588\",\"\u2593\u2593\",\"\u2592\u2592\"],\"col\":7},\n    }\n\n    # \u2500\u2500 Colour pairs (set up in curses) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    # pair index = block col; we also add sky/floor pairs\n    COL_NAMES = {0:\"white\",1:\"white\",2:\"green\",3:\"yellow\",4:\"red\",\n                 5:\"yellow\",6:\"cyan\",7:\"white\"}\n\n    # \u2500\u2500 Default empty world \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    MAP_W, MAP_H = 24, 24\n\n    def empty_world():\n        grid = [[0]*MAP_W for _ in range(MAP_H)]\n        # border walls\n        for x in range(MAP_W):\n            grid[0][x] = 1; grid[MAP_H-1][x] = 1\n        for y in range(MAP_H):\n            grid[y][0] = 1; grid[y][MAP_W-1] = 1\n        # floor suggestion (editor shows top-down, renderer uses height=1 everywhere)\n        return {\n            \"name\": \"Untitled\",\n            \"map_w\": MAP_W, \"map_h\": MAP_H,\n            \"grid\": grid,\n            \"objects\": [],   # [{id,x,y,name,script_id,sym,col}]\n            \"scripts\": {},   # {id: \"source code string\"}\n            \"player_start\": [2.5, 2.5, 0.0],  # x, y, angle(radians)\n            \"sky_col\": 6,\n            \"floor_col\": 3,\n            \"fog_dist\": 12.0,\n        }\n\n    def world_path(name):\n        return SAVE_DIR / (name.replace(\" \",\"_\") + \".xworld\")\n\n    def save_world(w):\n        p = world_path(w[\"name\"])\n        p.write_text(json.dumps(w, indent=2))\n        return str(p)\n\n    def load_world(name):\n        p = world_path(name)\n        if p.exists():\n            w = json.loads(p.read_text())\n            return w\n        return None\n\n    def list_worlds():\n        return sorted(p.stem.replace(\"_\",\" \") for p in SAVE_DIR.glob(\"*.xworld\"))\n\n    # \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n    #  RAYCASTER  (Wolfenstein-style DDA, column rendering, ASCII shading)\n    # \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n\n    def run_renderer(stdscr, world):\n        curses.curs_set(0); stdscr.nodelay(True); stdscr.keypad(True)\n        curses.start_color(); curses.use_default_colors()\n        # colour pairs: 1-15 = block colours, 16=sky, 17=floor, 18=hud, 19=dark\n        _block_fg = {0:7,1:7,2:2,3:3,4:5,5:1,6:5,7:3,8:3,9:1,10:7,11:6,12:3,13:3,14:3,15:7}\n        _block_bg = {0:-1,1:-1,2:-1,3:-1,4:-1,5:-1,6:-1,7:-1,8:-1,9:-1,10:-1,11:-1,12:-1,13:-1,14:-1,15:-1}\n        for bid, b in BLOCKS.items():\n            pair = bid + 1\n            fg = [curses.COLOR_WHITE,curses.COLOR_WHITE,curses.COLOR_GREEN,\n                  curses.COLOR_YELLOW,curses.COLOR_RED,curses.COLOR_YELLOW,\n                  curses.COLOR_CYAN,curses.COLOR_WHITE][min(b[\"col\"],7)]\n            try: curses.init_pair(pair, fg, -1)\n            except: pass\n        try:\n            curses.init_pair(17, curses.COLOR_CYAN,   -1)  # sky\n            curses.init_pair(18, curses.COLOR_GREEN,  -1)  # floor\n            curses.init_pair(19, curses.COLOR_WHITE,  curses.COLOR_BLUE)  # hud\n            curses.init_pair(20, curses.COLOR_BLACK,  -1)  # dark/fog\n            curses.init_pair(21, curses.COLOR_YELLOW, -1)  # torch/lava\n            curses.init_pair(22, curses.COLOR_WHITE,  -1)  # bright\n        except: pass\n\n        P_SKY   = curses.color_pair(17)\n        P_FLOOR = curses.color_pair(18)\n        P_HUD   = curses.color_pair(19)\n        P_DARK  = curses.color_pair(20)\n        P_TORCH = curses.color_pair(21)\n        P_W     = curses.color_pair(22)\n\n        grid     = world[\"grid\"]\n        mw       = world[\"map_w\"]\n        mh       = world[\"map_h\"]\n        fog      = world[\"fog_dist\"]\n        objects  = world[\"objects\"]\n\n        # player state\n        px, py, pangle = world[\"player_start\"]\n        pmove_speed = 0.07\n        prot_speed  = 0.055\n        pfov        = math.pi / 2.8   # ~64 degrees\n\n        def is_solid(x, y):\n            ix, iy = int(x), int(y)\n            if ix < 0 or iy < 0 or ix >= mw or iy >= mh: return True\n            b = grid[iy][ix]\n            return BLOCKS.get(b, BLOCKS[0])[\"solid\"]\n\n        def cast_ray(angle):\n            # DDA algorithm\n            rdx = math.cos(angle); rdy = math.sin(angle)\n            mx = int(px); my = int(py)\n            ddx = abs(1/rdx) if rdx != 0 else 1e30\n            ddy = abs(1/rdy) if rdy != 0 else 1e30\n            if rdx < 0: sx=-1; sdx=(px-mx)*ddx\n            else:       sx= 1; sdx=(mx+1-px)*ddx\n            if rdy < 0: sy=-1; sdy=(py-my)*ddy\n            else:       sy= 1; sdy=(my+1-py)*ddy\n            hit=False; side=0; dist=0\n            for _ in range(64):\n                if sdx < sdy: sdx+=ddx; mx+=sx; side=0\n                else:         sdy+=ddy; my+=sy; side=1\n                if mx<0 or my<0 or mx>=mw or my>=mh: dist=fog; hit=True; break\n                if BLOCKS.get(grid[my][mx], BLOCKS[0])[\"solid\"]:\n                    hit=True\n                    if side==0: dist=(mx-px+(1-sx)/2)/rdx\n                    else:       dist=(my-py+(1-sy)/2)/rdy\n                    break\n            if not hit: dist=fog\n            block_id = grid[min(max(my,0),mh-1)][min(max(mx,0),mw-1)] if hit else 0\n            return abs(dist), side, block_id\n\n        last_t = time.time()\n        fps_acc = [0.0]; fps_cnt = [0]; fps_val = [0]\n\n        while True:\n            sh, sw = stdscr.getmaxyx()\n            stdscr.erase()\n\n            now   = time.time()\n            dt    = now - last_t; last_t = now\n            fps_acc[0] += dt; fps_cnt[0] += 1\n            if fps_acc[0] >= 0.5:\n                fps_val[0] = int(fps_cnt[0]/fps_acc[0])\n                fps_acc[0] = fps_cnt[0] = 0\n\n            # \u2500\u2500 Render columns \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            render_h = sh - 2   # leave 2 rows for HUD\n            half_h   = render_h // 2\n\n            for col in range(sw):\n                ray_angle = pangle - pfov/2 + pfov * col / max(sw-1,1)\n                dist, side, bid = cast_ray(ray_angle)\n                # fish-eye fix\n                dist = dist * math.cos(ray_angle - pangle)\n                dist = max(dist, 0.001)\n\n                wall_h = min(int(render_h / dist), render_h)\n                top    = half_h - wall_h // 2\n                bot    = half_h + wall_h // 2\n\n                block  = BLOCKS.get(bid, BLOCKS[1])\n                shade_idx = 0 if dist < fog*0.33 else (1 if dist < fog*0.66 else 2)\n                if side == 1: shade_idx = min(shade_idx+1, 2)  # darken side faces\n\n                # block colour pair\n                pair_id = bid + 1\n                try: bcol = curses.color_pair(pair_id)\n                except: bcol = P_W\n                if dist > fog * 0.8: bcol = P_DARK\n\n                shade_ch = block[\"shade\"][shade_idx]\n                if len(shade_ch) == 0: shade_ch = \"  \"\n                ch = shade_ch[col % len(shade_ch)] if shade_ch.strip() else \" \"\n\n                # sky (above wall)\n                for row in range(max(0, top)):\n                    sky_ch = \"\u00b7\" if row < half_h//3 else \" \"\n                    try: stdscr.addstr(row, col, sky_ch, P_SKY)\n                    except: pass\n\n                # wall strip\n                for row in range(max(0,top), min(bot, render_h)):\n                    try: stdscr.addstr(row, col, ch, bcol | (curses.A_BOLD if shade_idx==0 else 0))\n                    except: pass\n\n                # floor (below wall)\n                for row in range(min(bot, render_h), render_h):\n                    depth = render_h - row\n                    floor_ch = \",\" if depth > render_h*0.15 else \".\"\n                    try: stdscr.addstr(row, col, floor_ch, P_FLOOR)\n                    except: pass\n\n            # \u2500\u2500 Objects (billboard sprites, simple distance sort) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            for obj in sorted(objects, key=lambda o: (o[\"x\"]-px)**2+(o[\"y\"]-py)**2, reverse=True):\n                ox = obj[\"x\"] - px; oy = obj[\"y\"] - py\n                inv = 1.0/(math.cos(pangle)*oy - math.sin(pangle)*ox + 1e-9)\n                if inv < 0: continue\n                sx2 = int((sw/2)*(1 + (math.cos(pangle)*ox + math.sin(pangle)*oy)*inv/pfov*2))\n                sy2 = int(render_h/2)\n                h2  = max(1, int(render_h/max(0.1,(ox**2+oy**2)**0.5)))\n                osym = obj.get(\"sym\",\"?\")[:1]\n                ocol_id = obj.get(\"col\",2)\n                try: opcol = curses.color_pair(ocol_id+1)\n                except: opcol = P_W\n                for dy in range(-h2//2, h2//2):\n                    ry = sy2 + dy\n                    if 0 <= ry < render_h and 0 <= sx2 < sw:\n                        try: stdscr.addstr(ry, sx2, osym, opcol | curses.A_BOLD)\n                        except: pass\n\n            # \u2500\u2500 Crosshair \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            cy = render_h//2; cx = sw//2\n            try:\n                stdscr.addstr(cy,   cx,   \"+\", P_W | curses.A_BOLD)\n            except: pass\n\n            # \u2500\u2500 Mini-map (top-right corner) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            mm_size = 10; mm_x = sw - mm_size*2 - 2; mm_y = 1\n            cam_mx = int(px) - mm_size//2; cam_my = int(py) - mm_size//2\n            for my2 in range(mm_size):\n                for mx2 in range(mm_size):\n                    wx=cam_mx+mx2; wy=cam_my+my2\n                    if 0<=wx<mw and 0<=wy<mh:\n                        b = grid[wy][wx]\n                        mc = \"\u2588\" if BLOCKS.get(b,BLOCKS[0])[\"solid\"] else \"\u00b7\"\n                        try:\n                            pair = b+1 if b>0 else 0\n                            stdscr.addstr(mm_y+my2, mm_x+mx2*2, mc*2,\n                                curses.color_pair(pair) if pair else P_DARK)\n                        except: pass\n            # player dot on mini-map\n            pdx = int(px)-cam_mx; pdy = int(py)-cam_my\n            if 0<=pdx<mm_size and 0<=pdy<mm_size:\n                try: stdscr.addstr(mm_y+pdy, mm_x+pdx*2, \"@@\", P_W | curses.A_BOLD)\n                except: pass\n\n            # \u2500\u2500 HUD bar \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            pos_str = f\"X:{px:.1f} Y:{py:.1f} A:{math.degrees(pangle):.0f}\u00b0\"\n            hud_str = f\"  [WASD]=Move  [QE]=Turn  [ESC]=Editor  {pos_str}  FPS:{fps_val[0]}\"\n            try:\n                stdscr.addstr(sh-2, 0, \"\u2500\"*(sw-1), P_HUD)\n                stdscr.addstr(sh-1, 0, hud_str[:sw-1].ljust(sw-1), P_HUD)\n            except: pass\n\n            stdscr.refresh()\n\n            # \u2500\u2500 Input \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            k = stdscr.getch()\n            if k == -1: time.sleep(0.016); continue\n\n            cos_a = math.cos(pangle); sin_a = math.sin(pangle)\n            if k in (ord('w'), curses.KEY_UP):\n                nx=px+cos_a*pmove_speed; ny=py+sin_a*pmove_speed\n                if not is_solid(nx, py): px=nx\n                if not is_solid(px, ny): py=ny\n            elif k in (ord('s'), curses.KEY_DOWN):\n                nx=px-cos_a*pmove_speed; ny=py-sin_a*pmove_speed\n                if not is_solid(nx, py): px=nx\n                if not is_solid(px, ny): py=ny\n            elif k in (ord('a'),):\n                nx=px-sin_a*pmove_speed; ny=py+cos_a*pmove_speed\n                if not is_solid(nx, py): px=nx\n                if not is_solid(px, ny): py=ny\n            elif k in (ord('d'),):\n                nx=px+sin_a*pmove_speed; ny=py-cos_a*pmove_speed\n                if not is_solid(nx, py): px=nx\n                if not is_solid(px, ny): py=ny\n            elif k in (ord('q'), curses.KEY_LEFT):\n                pangle -= prot_speed\n            elif k in (ord('e'), curses.KEY_RIGHT):\n                pangle += prot_speed\n            elif k == 27:  # ESC \u2192 back to editor\n                world[\"player_start\"] = [px, py, pangle]\n                break\n\n    # \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n    #  CLI EDITOR\n    # \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n\n    SCRIPT_COMMANDS = [\n        (\"move\",      \"move(obj_id, dx, dy)\",       \"Move an object by dx,dy tiles\"),\n        (\"teleport\",  \"teleport(obj_id, x, y)\",     \"Teleport object to absolute position\"),\n        (\"say\",       \"say(obj_id, text)\",           \"Show speech bubble above object\"),\n        (\"hurt\",      \"hurt(obj_id, amount)\",        \"Deal damage to player if near object\"),\n        (\"heal\",      \"heal(amount)\",                \"Heal player by amount\"),\n        (\"give_item\", \"give_item(name, qty)\",        \"Add item to player inventory\"),\n        (\"take_item\", \"take_item(name, qty)\",        \"Remove item from player inventory\"),\n        (\"set_block\", \"set_block(x, y, block_id)\",  \"Replace block at map position\"),\n        (\"play_sound\",\"play_sound(name)\",            \"Play a named sound (beep/alert/coin)\"),\n        (\"open_door\", \"open_door(x, y)\",             \"Set block at x,y to Air (open door)\"),\n        (\"close_door\",\"close_door(x, y)\",            \"Set block at x,y to Door\"),\n        (\"spawn\",     \"spawn(obj_id, x, y)\",         \"Spawn/move a named object to x,y\"),\n        (\"despawn\",   \"despawn(obj_id)\",             \"Remove object from the world\"),\n        (\"if_near\",   \"if_near(obj_id, dist): ...\",  \"Run block if player within dist\"),\n        (\"if_item\",   \"if_item(name, qty): ...\",     \"Run block if player has item\"),\n        (\"if_flag\",   \"if_flag(name): ...\",          \"Run block if world flag is set\"),\n        (\"set_flag\",  \"set_flag(name)\",              \"Set a persistent world flag\"),\n        (\"clear_flag\",\"clear_flag(name)\",            \"Clear a world flag\"),\n        (\"win\",       \"win(message)\",                \"Trigger win screen with message\"),\n        (\"lose\",      \"lose(message)\",               \"Trigger lose screen with message\"),\n        (\"goto\",      \"goto(label)\",                 \"Jump to a label in the script\"),\n        (\"label\",     \"label(name)\",                 \"Define a jump target label\"),\n        (\"wait\",      \"wait(seconds)\",               \"Pause script execution\"),\n        (\"print_hud\", \"print_hud(text)\",             \"Show text on the HUD for 3 seconds\"),\n        (\"random_move\",\"random_move(obj_id)\",        \"Move object one tile randomly\"),\n        (\"face_player\",\"face_player(obj_id)\",        \"Rotate object toward the player\"),\n        (\"each_tick\", \"each_tick: ...\",              \"Run this block every game tick\"),\n        (\"on_touch\",  \"on_touch(obj_id): ...\",       \"Run when player touches object\"),\n        (\"on_use\",    \"on_use(obj_id): ...\",         \"Run when player presses E near object\"),\n    ]\n\n    def run_editor(stdscr, world):\n        curses.curs_set(0); stdscr.nodelay(False); stdscr.keypad(True)\n        curses.start_color(); curses.use_default_colors()\n        try:\n            curses.init_pair(1,  curses.COLOR_WHITE,   -1)\n            curses.init_pair(2,  curses.COLOR_GREEN,   -1)\n            curses.init_pair(3,  curses.COLOR_CYAN,    -1)\n            curses.init_pair(4,  curses.COLOR_RED,     -1)\n            curses.init_pair(5,  curses.COLOR_YELLOW,  -1)\n            curses.init_pair(6,  curses.COLOR_MAGENTA, -1)\n            curses.init_pair(7,  curses.COLOR_BLUE,    -1)\n            curses.init_pair(8,  curses.COLOR_BLACK,   curses.COLOR_GREEN)\n            curses.init_pair(9,  curses.COLOR_BLACK,   curses.COLOR_YELLOW)\n            curses.init_pair(10, curses.COLOR_WHITE,   curses.COLOR_BLUE)\n            curses.init_pair(11, curses.COLOR_BLACK,   curses.COLOR_CYAN)\n            curses.init_pair(12, curses.COLOR_WHITE,   curses.COLOR_RED)\n            curses.init_pair(13, curses.COLOR_WHITE,   curses.COLOR_MAGENTA)\n            curses.init_pair(14, curses.COLOR_BLACK,   curses.COLOR_WHITE)\n            for bid in range(16):\n                pair=bid+20\n                fg_list=[7,7,2,3,5,1,5,3,3,1,7,6,3,3,5,7]\n                fg_cols=[curses.COLOR_WHITE,curses.COLOR_WHITE,curses.COLOR_GREEN,\n                         curses.COLOR_YELLOW,curses.COLOR_RED,curses.COLOR_WHITE,\n                         curses.COLOR_YELLOW,curses.COLOR_CYAN,curses.COLOR_CYAN,\n                         curses.COLOR_RED,curses.COLOR_WHITE,curses.COLOR_CYAN,\n                         curses.COLOR_YELLOW,curses.COLOR_YELLOW,curses.COLOR_YELLOW,\n                         curses.COLOR_WHITE]\n                curses.init_pair(pair, fg_cols[bid], -1)\n        except: pass\n\n        P_W=curses.color_pair(1);  P_G=curses.color_pair(2);  P_C=curses.color_pair(3)\n        P_R=curses.color_pair(4);  P_Y=curses.color_pair(5);  P_M=curses.color_pair(6)\n        P_B=curses.color_pair(7);  P_BG=curses.color_pair(8); P_BY=curses.color_pair(9)\n        P_TB=curses.color_pair(10);P_BC=curses.color_pair(11);P_BR=curses.color_pair(12)\n        P_BM=curses.color_pair(13);P_BW=curses.color_pair(14)\n\n        def block_pair(bid):\n            return curses.color_pair(bid+20) if bid < 16 else P_W\n\n        # editor state\n        mode      = \"map\"       # map | objects | scripts | palette | help\n        cam_x     = [0]; cam_y = [0]\n        cur_x     = [1]; cur_y = [1]\n        sel_block = [1]\n        sel_obj   = [None]      # index into world[\"objects\"]\n        sel_scr   = [None]      # selected script id\n        script_buf= [\"\"]        # list of lines being edited\n        scr_cursor= [0]         # line cursor in script editor\n        msg       = [\"\"]; msg_t= [0]\n\n        grid = world[\"grid\"]\n        mw   = world[\"map_w\"]; mh = world[\"map_h\"]\n\n        def setmsg(s): msg[0]=s; msg_t[0]=0\n\n        def sa(r, c, txt, attr=0):\n            try: stdscr.addstr(int(r), int(c), str(txt), attr)\n            except: pass\n\n        def prompt(label, default=\"\"):\n            sh, sw = stdscr.getmaxyx()\n            sa(sh-1, 0, (label + default)[:sw-1].ljust(sw-1), P_BY)\n            stdscr.refresh(); stdscr.nodelay(False)\n            curses.curs_set(1); buf = list(default)\n            while True:\n                sa(sh-1, 0, (label+\"\".join(buf)+\" \")[:sw-1].ljust(sw-1), P_BY)\n                stdscr.refresh()\n                k = stdscr.getch()\n                if k in (10,13): curses.curs_set(0); return \"\".join(buf)\n                elif k == 27:    curses.curs_set(0); return None\n                elif k in (8,127,curses.KEY_BACKSPACE): buf = buf[:-1]\n                elif 32<=k<128:  buf.append(chr(k))\n\n        def draw_map():\n            sh, sw = stdscr.getmaxyx()\n            stdscr.erase()\n            sa(0,0,\"  XENGINE EDITOR  |  MAP  |  \"+world[\"name\"][:30],P_TB|curses.A_BOLD)\n\n            view_w = sw - 30; view_h = sh - 4\n            cell_w = 2\n\n            # auto-scroll camera\n            if cur_x[0] - cam_x[0] > view_w//cell_w - 3: cam_x[0] = cur_x[0] - view_w//cell_w + 3\n            if cur_x[0] - cam_x[0] < 2:                  cam_x[0] = max(0, cur_x[0]-2)\n            if cur_y[0] - cam_y[0] > view_h - 3:         cam_y[0] = cur_y[0] - view_h + 3\n            if cur_y[0] - cam_y[0] < 2:                  cam_y[0] = max(0, cur_y[0]-2)\n\n            for vy in range(view_h):\n                wy = cam_y[0] + vy\n                if wy >= mh: break\n                for vx in range(view_w // cell_w):\n                    wx = cam_x[0] + vx\n                    if wx >= mw: break\n                    bid = grid[wy][wx]\n                    b   = BLOCKS.get(bid, BLOCKS[0])\n                    sym = (b[\"sym\"]*2)[:2]\n                    is_cur = (wx==cur_x[0] and wy==cur_y[0])\n                    # check if object here\n                    has_obj = any(int(o[\"x\"])==wx and int(o[\"y\"])==wy for o in world[\"objects\"])\n                    is_start= (int(world[\"player_start\"][0])==wx and int(world[\"player_start\"][1])==wy)\n                    if is_cur:\n                        attr = P_BW | curses.A_BOLD\n                        ch   = \"[]\"\n                    elif is_start:\n                        attr = P_BG | curses.A_BOLD; ch = \"@@\"\n                    elif has_obj:\n                        obj = next(o for o in world[\"objects\"] if int(o[\"x\"])==wx and int(o[\"y\"])==wy)\n                        attr = curses.color_pair(obj.get(\"col\",2)+1) | curses.A_BOLD\n                        ch   = (obj.get(\"sym\",\"?\")[:1]*2)[:2]\n                    else:\n                        attr = block_pair(bid)\n                        if is_cur: attr |= curses.A_REVERSE\n                        ch = sym\n                    sa(1+vy, vx*cell_w, ch, attr)\n\n            # right panel\n            rp = view_w + 2\n            sa(1, rp, \"\u250c\"+\"\u2500\"*25+\"\u2510\", P_C|curses.A_BOLD)\n            sa(2, rp, \"\u2502\"+\" CONTROLS \".center(25)+\"\u2502\", P_C|curses.A_BOLD)\n            sa(3, rp, \"\u251c\"+\"\u2500\"*25+\"\u2524\", P_C|curses.A_BOLD)\n            panel=[\n                \"\u2502 Arrow/WASD : Move cursor \u2502\",\n                \"\u2502 SPACE/Enter: Place block  \u2502\",\n                \"\u2502 DEL/X      : Erase block  \u2502\",\n                \"\u2502 P          : Pick block   \u2502\",\n                \"\u2502 [/]        : Prev/next blk\u2502\",\n                \"\u2502 S          : Set spawn    \u2502\",\n                \"\u2502 Tab        : Next mode    \u2502\",\n                \"\u2502 R          : Run (3D)     \u2502\",\n                \"\u2502 W          : Save world   \u2502\",\n                \"\u2502 Q          : Quit editor  \u2502\",\n                \"\u251c\"+\"\u2500\"*25+\"\u2524\",\n                \"\u2502 SELECTED BLOCK:           \u2502\",\n                \"\u2502  [\"+BLOCKS[sel_block[0]][\"sym\"]*2+\"] \"+BLOCKS[sel_block[0]][\"name\"].ljust(18)+\"\u2502\",\n                \"\u251c\"+\"\u2500\"*25+\"\u2524\",\n                \"\u2502 PALETTE (0-9, a-f):       \u2502\",\n            ]\n            for bid2, b2 in BLOCKS.items():\n                k2 = str(bid2) if bid2<10 else chr(ord('a')+bid2-10)\n                mark = \"\u25ba\" if bid2==sel_block[0] else \" \"\n                panel.append(\"\u2502\"+mark+\"[\"+b2[\"sym\"]+\"] \"+b2[\"name\"].ljust(19)+\"\u2502\")\n            panel.append(\"\u2514\"+\"\u2500\"*25+\"\u2518\")\n            for i,line in enumerate(panel):\n                sa(3+i, rp, line[:27], P_C)\n\n            # mode tabs\n            tabs = [(\"MAP\",'m'),(\"OBJECTS\",'o'),(\"SCRIPTS\",'s'),(\"HELP\",'h')]\n            tx=0\n            for tname,_ in tabs:\n                active = tname.lower()==mode\n                attr = P_BW|curses.A_BOLD if active else P_W\n                sa(sh-3, tx, \" \"+tname+\" \", attr)\n                tx += len(tname)+2\n\n            if msg[0]:\n                sa(sh-2, 0, (\"  \"+msg[0])[:sw-1], P_BY)\n            try:\n                stdscr.addstr(sh-1,0,\"\u2500\"*(sw-1),P_M|curses.A_BOLD)\n                stdscr.addstr(sh-1,0,\" [TAB]Mode  [R]Run3D  [W]Save  [Q]Quit\"[:sw-1],P_W|curses.A_DIM)\n            except: pass\n            stdscr.refresh()\n\n        def draw_objects():\n            sh, sw = stdscr.getmaxyx(); stdscr.erase()\n            sa(0,0,\"  XENGINE EDITOR  |  OBJECTS  |  \"+world[\"name\"][:25],P_TB|curses.A_BOLD)\n            objs = world[\"objects\"]\n            sa(2, 2, \"\u250c\"+\"\u2500\"*50+\"\u2510\", P_Y|curses.A_BOLD)\n            sa(3, 2, \"\u2502\"+\" OBJECTS IN WORLD \".center(50)+\"\u2502\", P_Y|curses.A_BOLD)\n            sa(4, 2, \"\u251c\"+\"\u2500\"*50+\"\u2524\", P_Y|curses.A_BOLD)\n            for i,obj in enumerate(objs):\n                active = i==sel_obj[0]\n                line = \" [\"+obj.get(\"sym\",\"?\")[:1]+\"] \"+obj[\"name\"][:15].ljust(15)+\" @ (\"+str(round(obj[\"x\"],1))+\",\"+str(round(obj[\"y\"],1))+\")  scr:\"+str(obj.get(\"script_id\",\"none\"))[:8]\n                attr = P_BW|curses.A_BOLD if active else P_W\n                sa(5+i, 2, \"\u2502\"+line[:50].ljust(50)+\"\u2502\", attr)\n            if not objs:\n                sa(5, 2, \"\u2502\"+\" (no objects \u2014 press N to add one)\".ljust(50)+\"\u2502\", P_W|curses.A_DIM)\n            sa(5+max(len(objs),1), 2, \"\u2514\"+\"\u2500\"*50+\"\u2518\", P_Y|curses.A_BOLD)\n            sa(7+max(len(objs),1), 2, \"N=New  DEL=Delete  E=Edit  \u2191\u2193=Select  TAB=Next mode\", P_W|curses.A_DIM)\n            if msg[0]: sa(sh-2,2,(\"  \"+msg[0])[:sw-3],P_BY)\n            try:\n                stdscr.addstr(sh-1,0,\"\u2500\"*(sw-1),P_M|curses.A_BOLD)\n                stdscr.addstr(sh-1,0,\" [TAB]Mode  [R]Run3D  [W]Save  [Q]Quit\"[:sw-1],P_W|curses.A_DIM)\n            except: pass\n            stdscr.refresh()\n\n        def draw_scripts():\n            sh, sw = stdscr.getmaxyx(); stdscr.erase()\n            sa(0,0,\"  XENGINE EDITOR  |  SCRIPTS  |  \"+world[\"name\"][:24],P_TB|curses.A_BOLD)\n            scripts = world.get(\"scripts\",{})\n            scr_list = list(scripts.keys())\n            # left: script list\n            sa(2,2,\"\u250c\"+\"\u2500\"*20+\"\u2510\",P_M|curses.A_BOLD)\n            sa(3,2,\"\u2502\"+\" SCRIPTS \".center(20)+\"\u2502\",P_M|curses.A_BOLD)\n            sa(4,2,\"\u251c\"+\"\u2500\"*20+\"\u2524\",P_M|curses.A_BOLD)\n            for i,sid in enumerate(scr_list):\n                active = sid==sel_scr[0]\n                attr = P_BW|curses.A_BOLD if active else P_W\n                sa(5+i,2,\"\u2502 \"+sid[:18].ljust(18)+\" \u2502\",attr)\n            if not scr_list:\n                sa(5,2,\"\u2502 (none)             \u2502\",P_W|curses.A_DIM)\n            sa(5+max(len(scr_list),1),2,\"\u2514\"+\"\u2500\"*20+\"\u2518\",P_M|curses.A_BOLD)\n            sa(7+max(len(scr_list),1),2,\"N=New  DEL=Delete  E=Edit\",P_W|curses.A_DIM)\n            # right: script content / command list\n            if sel_scr[0] and sel_scr[0] in scripts:\n                src = scripts[sel_scr[0]]\n                lines = src.split(\"\\n\")\n                sa(2,26,\"\u250c\"+\"\u2500\"*(sw-30)+\"\u2510\",P_C|curses.A_BOLD)\n                sa(3,26,\"\u2502\"+\" SCRIPT: \"+sel_scr[0][:sw-40]+\" \".ljust(sw-30-9-len(sel_scr[0][:sw-40]))+\"\u2502\",P_C|curses.A_BOLD)\n                sa(4,26,\"\u251c\"+\"\u2500\"*(sw-30)+\"\u2524\",P_C|curses.A_BOLD)\n                for i,line in enumerate(lines[:sh-8]):\n                    sa(5+i,26,\"\u2502 \"+line[:sw-32].ljust(sw-32)+\"\u2502\",P_G if line.strip().startswith(\"#\") else P_W)\n                sa(5+len(lines[:sh-8]),26,\"\u2514\"+\"\u2500\"*(sw-30)+\"\u2518\",P_C|curses.A_BOLD)\n            else:\n                sa(2,26,\"\u250c\"+\"\u2500\"*(sw-30)+\"\u2510\",P_C|curses.A_BOLD)\n                sa(3,26,\"\u2502\"+\" SCRIPT COMMANDS REFERENCE \".center(sw-30)+\"\u2502\",P_C|curses.A_BOLD)\n                sa(4,26,\"\u251c\"+\"\u2500\"*(sw-30)+\"\u2524\",P_C|curses.A_BOLD)\n                for i,(cmd,sig,desc) in enumerate(SCRIPT_COMMANDS[:sh-8]):\n                    line = \" \"+sig.ljust(28)+\" \u2014 \"+desc\n                    sa(5+i,26,\"\u2502\"+line[:sw-32].ljust(sw-32)+\"\u2502\",P_Y if i%2==0 else P_W)\n                sa(5+min(len(SCRIPT_COMMANDS),sh-8),26,\"\u2514\"+\"\u2500\"*(sw-30)+\"\u2518\",P_C|curses.A_BOLD)\n            if msg[0]: sa(sh-2,2,(\"  \"+msg[0])[:sw-3],P_BY)\n            try:\n                stdscr.addstr(sh-1,0,\"\u2500\"*(sw-1),P_M|curses.A_BOLD)\n                stdscr.addstr(sh-1,0,\" [TAB]Mode  [R]Run3D  [W]Save  [Q]Quit\"[:sw-1],P_W|curses.A_DIM)\n            except: pass\n            stdscr.refresh()\n\n        def draw_help():\n            sh, sw = stdscr.getmaxyx(); stdscr.erase()\n            sa(0,0,\"  XENGINE EDITOR  |  HELP  \",P_TB|curses.A_BOLD)\n            lines=[\n                \"\",\"  \u2554\u2550\u2550 XENGINE \u2014 Minecraft-style CLI Raycaster Engine \u2550\u2550\u2557\",\"\",\n                \"  EDITOR MODES\",\"  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\",\n                \"  TAB              : Cycle modes (Map \u2192 Objects \u2192 Scripts \u2192 Help)\",\n                \"  R                : Launch 3D renderer (play the world)\",\n                \"  W                : Save world to ~/.xengine/<name>.xworld\",\n                \"  Q                : Quit editor\",\"\",\n                \"  MAP EDITOR\",\"  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\",\n                \"  Arrow / WASD     : Move cursor on the map grid\",\n                \"  SPACE or ENTER   : Place selected block at cursor\",\n                \"  DEL or X         : Erase block (set to Air)\",\n                \"  P                : Pick block under cursor\",\n                \"  [ / ]            : Select previous / next block type\",\n                \"  S                : Set player spawn at cursor position\",\"\",\n                \"  OBJECT EDITOR\",\"  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\",\n                \"  N                : New object (enter name, position, script ID)\",\n                \"  \u2191 / \u2193            : Select object in list\",\n                \"  E                : Edit selected object properties\",\n                \"  DEL              : Delete selected object\",\"\",\n                \"  SCRIPT EDITOR\",\"  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\",\n                \"  N                : New script (enter ID)\",\n                \"  E                : Open selected script in line editor\",\n                \"  DEL              : Delete selected script\",\n                \"  (Right panel shows all available script commands)\",\"\",\n                \"  3D RENDERER\",\"  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\",\n                \"  W / S / \u2191\u2193       : Move forward / backward\",\n                \"  A / D            : Strafe left / right\",\n                \"  Q / E / \u2190\u2192       : Turn left / right\",\n                \"  ESC              : Return to editor\",\"\",\n                \"  SCRIPT LANGUAGE (assign to objects via script_id)\",\"  \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\",\n            ]\n            for i,(cmd,sig,desc) in enumerate(SCRIPT_COMMANDS):\n                lines.append(\"  \"+sig.ljust(30)+\" \"+desc)\n            for i,line in enumerate(lines[:sh-3]):\n                attr = P_C|curses.A_BOLD if line.startswith(\"  \u2554\") or line.startswith(\"  \u2550\u2550\") else \\\n                       P_Y|curses.A_BOLD if line.startswith(\"  \u2500\") else \\\n                       P_W|curses.A_BOLD if line.strip() and line[2].isupper() and not line[3:4].islower() else P_W\n                sa(1+i,0,line[:sw-1],attr)\n            try:\n                stdscr.addstr(sh-1,0,\"\u2500\"*(sw-1),P_M|curses.A_BOLD)\n                stdscr.addstr(sh-1,0,\" [TAB]Mode  [R]Run3D  [W]Save  [Q]Quit\"[:sw-1],P_W|curses.A_DIM)\n            except: pass\n            stdscr.refresh()\n\n        def script_line_editor(sid, src):\n            \"\"\"Simple line-by-line script editor.\"\"\"\n            lines = src.split(\"\\n\") if src else [\"\"]\n            cur   = [0]\n            stdscr.nodelay(False); curses.curs_set(1)\n            while True:\n                sh, sw = stdscr.getmaxyx(); stdscr.erase()\n                sa(0,0,\"  XENGINE SCRIPT EDITOR  |  \"+sid+\"  |  ESC=save&exit  Ctrl+C=discard\",P_TB|curses.A_BOLD)\n                sa(1,0,\"\u2500\"*(sw-1),P_M|curses.A_BOLD)\n                # command reference on right\n                ref_x = max(sw//2, 50)\n                sa(2,ref_x,\"\u2554\"+\"\u2550\"*(sw-ref_x-2)+\"\u2557\",P_C|curses.A_BOLD)\n                sa(3,ref_x,\"\u2551\"+\" COMMANDS \".center(sw-ref_x-2)+\"\u2551\",P_C|curses.A_BOLD)\n                sa(4,ref_x,\"\u2560\"+\"\u2550\"*(sw-ref_x-2)+\"\u2563\",P_C|curses.A_BOLD)\n                for i,(cmd,sig,desc) in enumerate(SCRIPT_COMMANDS[:sh-7]):\n                    line=(\" \"+sig[:sw-ref_x-4]).ljust(sw-ref_x-2)\n                    sa(5+i,ref_x,\"\u2551\"+line+\"\u2551\",P_Y if i%2==0 else P_W)\n                sa(5+min(len(SCRIPT_COMMANDS),sh-7),ref_x,\"\u255a\"+\"\u2550\"*(sw-ref_x-2)+\"\u255d\",P_C|curses.A_BOLD)\n                # line editor on left\n                for i,line in enumerate(lines[:sh-4]):\n                    lnum=str(i+1).rjust(3)\n                    attr=P_BW|curses.A_BOLD if i==cur[0] else (P_W|curses.A_DIM if line.strip().startswith(\"#\") else P_W)\n                    sa(2+i,0,lnum+\" \u2502 \"+line[:ref_x-6].ljust(ref_x-6),attr)\n                # cursor position\n                cy=2+cur[0]; cx=4+len(lines[cur[0]])\n                try: stdscr.move(min(cy,sh-2), min(cx, ref_x-2))\n                except: pass\n                sa(sh-1,0,\" \u2191\u2193=Line  ENTER=NewLine  DEL=DeleteLine  ESC=Save  (type to insert)\"[:sw-1],P_W|curses.A_DIM)\n                stdscr.refresh()\n\n                k=stdscr.getch()\n                if k==27:    break\n                elif k==3:   lines=src.split(\"\\n\"); break  # Ctrl+C discard\n                elif k in (curses.KEY_UP,):\n                    cur[0]=max(0,cur[0]-1)\n                elif k in (curses.KEY_DOWN,):\n                    cur[0]=min(len(lines)-1,cur[0]+1)\n                elif k in (10,13):\n                    lines.insert(cur[0]+1,\"\"); cur[0]+=1\n                elif k in (curses.KEY_DC, curses.KEY_BACKSPACE, 8,127):\n                    if len(lines)>1: lines.pop(cur[0]); cur[0]=max(0,cur[0]-1)\n                    elif lines: lines[cur[0]]=\"\"\n                elif 32<=k<128:\n                    lines[cur[0]]+=chr(k)\n\n            curses.curs_set(0); stdscr.nodelay(False)\n            return \"\\n\".join(lines)\n\n        # \u2500\u2500 editor main loop \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        while True:\n            msg_t[0]+=1\n            if msg_t[0]>120: msg[0]=\"\"\n\n            if   mode==\"map\":     draw_map()\n            elif mode==\"objects\": draw_objects()\n            elif mode==\"scripts\": draw_scripts()\n            elif mode==\"help\":    draw_help()\n\n            k = stdscr.getch()\n            if k==-1: time.sleep(0.02); continue\n\n            # \u2500\u2500 Global keys \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            if k==ord('\\t'):\n                cycle=[\"map\",\"objects\",\"scripts\",\"help\"]\n                mode=cycle[(cycle.index(mode)+1)%len(cycle)]\n                continue\n            elif k in (ord('r'),ord('R')):\n                curses.wrapper(run_renderer, world)\n                stdscr.nodelay(False)\n                continue\n            elif k in (ord('w'),ord('W')) and mode!=\"map\":\n                p=save_world(world); setmsg(\"Saved \u2192 \"+p)\n                continue\n            elif k in (ord('q'),ord('Q')):\n                break\n\n            # \u2500\u2500 MAP mode keys \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            if mode==\"map\":\n                if   k in (curses.KEY_UP,   ord('k')): cur_y[0]=max(0,cur_y[0]-1)\n                elif k in (curses.KEY_DOWN, ord('j')): cur_y[0]=min(mh-1,cur_y[0]+1)\n                elif k in (curses.KEY_LEFT, ord('h')): cur_x[0]=max(0,cur_x[0]-1)\n                elif k in (curses.KEY_RIGHT,ord('l')): cur_x[0]=min(mw-1,cur_x[0]+1)\n                elif k in (ord(' '),10,13):\n                    grid[cur_y[0]][cur_x[0]]=sel_block[0]\n                elif k in (curses.KEY_DC, ord('x'),ord('X')):\n                    grid[cur_y[0]][cur_x[0]]=0\n                elif k in (ord('p'),ord('P')):\n                    sel_block[0]=grid[cur_y[0]][cur_x[0]]; setmsg(\"Picked: \"+BLOCKS[sel_block[0]][\"name\"])\n                elif k==ord('['):\n                    sel_block[0]=max(0,sel_block[0]-1); setmsg(\"Block: \"+BLOCKS[sel_block[0]][\"name\"])\n                elif k==ord(']'):\n                    sel_block[0]=min(15,sel_block[0]+1); setmsg(\"Block: \"+BLOCKS[sel_block[0]][\"name\"])\n                elif k in (ord('s'),ord('S')):\n                    world[\"player_start\"]=[float(cur_x[0])+0.5,float(cur_y[0])+0.5,0.0]; setmsg(\"Spawn set!\")\n                elif k in (ord('w'),ord('W')):\n                    pth=save_world(world); setmsg(\"Saved \u2192 \"+pth)\n                # number keys 0-9 and a-f for quick block select\n                elif ord('0')<=k<=ord('9'): sel_block[0]=k-ord('0'); setmsg(\"Block: \"+BLOCKS[sel_block[0]][\"name\"])\n                elif ord('a')<=k<=ord('f'): sel_block[0]=k-ord('a')+10; setmsg(\"Block: \"+BLOCKS[sel_block[0]][\"name\"])\n\n            # \u2500\u2500 OBJECTS mode keys \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            elif mode==\"objects\":\n                objs=world[\"objects\"]\n                if k in (curses.KEY_UP,):\n                    sel_obj[0]=max(0,(sel_obj[0] or 0)-1) if objs else None\n                elif k in (curses.KEY_DOWN,):\n                    sel_obj[0]=min(len(objs)-1,(sel_obj[0] or 0)+1) if objs else None\n                elif k in (ord('n'),ord('N')):\n                    oname=prompt(\"Object name: \")\n                    if oname:\n                        osym=prompt(\"Symbol (1 char): \",\"?\")\n                        oxs=prompt(\"X position: \",\"2.5\")\n                        oys=prompt(\"Y position: \",\"2.5\")\n                        oscr=prompt(\"Script ID (blank=none): \",\"\")\n                        ocol=prompt(\"Colour (1-7): \",\"2\")\n                        try: ox2=float(oxs); oy2=float(oys)\n                        except: ox2=2.5; oy2=2.5\n                        try: ocol2=int(ocol)\n                        except: ocol2=2\n                        obj={\"id\":oname.lower().replace(\" \",\"_\"),\"name\":oname,\n                             \"sym\":(osym or \"?\")[:1],\"x\":ox2,\"y\":oy2,\n                             \"script_id\":oscr or None,\"col\":ocol2}\n                        objs.append(obj)\n                        sel_obj[0]=len(objs)-1\n                        setmsg(\"Object '\"+oname+\"' added!\")\n                elif k in (curses.KEY_DC, ord('d'),ord('D')):\n                    if sel_obj[0] is not None and objs:\n                        objs.pop(sel_obj[0])\n                        sel_obj[0]=max(0,min((sel_obj[0] or 0),len(objs)-1)) if objs else None\n                        setmsg(\"Object deleted.\")\n                elif k in (ord('e'),ord('E')):\n                    if sel_obj[0] is not None and objs:\n                        obj=objs[sel_obj[0]]\n                        v=prompt(\"Name [\"+obj[\"name\"]+\"]: \",obj[\"name\"])\n                        if v: obj[\"name\"]=v\n                        v=prompt(\"Symbol [\"+obj.get(\"sym\",\"?\")+\"] (1 char): \",obj.get(\"sym\",\"?\"))\n                        if v: obj[\"sym\"]=v[:1]\n                        v=prompt(\"X [\"+str(obj[\"x\"])+\"]: \",str(obj[\"x\"]))\n                        try: obj[\"x\"]=float(v)\n                        except: pass\n                        v=prompt(\"Y [\"+str(obj[\"y\"])+\"]: \",str(obj[\"y\"]))\n                        try: obj[\"y\"]=float(v)\n                        except: pass\n                        v=prompt(\"Script ID [\"+str(obj.get(\"script_id\",\"none\"))+\"]: \",str(obj.get(\"script_id\",\"\") or \"\"))\n                        obj[\"script_id\"]=v if v else None\n                        setmsg(\"Object updated.\")\n\n            # \u2500\u2500 SCRIPTS mode keys \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n            elif mode==\"scripts\":\n                scr_list=list(world.get(\"scripts\",{}).keys())\n                if k in (curses.KEY_UP,):\n                    if scr_list and sel_scr[0] in scr_list:\n                        i=scr_list.index(sel_scr[0]); sel_scr[0]=scr_list[max(0,i-1)]\n                elif k in (curses.KEY_DOWN,):\n                    if scr_list and sel_scr[0] in scr_list:\n                        i=scr_list.index(sel_scr[0]); sel_scr[0]=scr_list[min(len(scr_list)-1,i+1)]\n                    elif scr_list: sel_scr[0]=scr_list[0]\n                elif k in (ord('n'),ord('N')):\n                    sid=prompt(\"Script ID: \")\n                    if sid:\n                        if sid not in world[\"scripts\"]:\n                            world[\"scripts\"][sid]=\"# Script: \"+sid+\"\\n# Use on_use, on_touch, each_tick\\n\\non_use(\"+sid+\"):\\n    say(\"+sid+', \"Hello!\")\\n'\n                        sel_scr[0]=sid; setmsg(\"Script '\"+sid+\"' created.\")\n                elif k in (ord('e'),ord('E')):\n                    if sel_scr[0] and sel_scr[0] in world[\"scripts\"]:\n                        new_src=script_line_editor(sel_scr[0], world[\"scripts\"][sel_scr[0]])\n                        world[\"scripts\"][sel_scr[0]]=new_src; setmsg(\"Script saved.\")\n                elif k in (curses.KEY_DC, ord('d'),ord('D')):\n                    if sel_scr[0] and sel_scr[0] in world[\"scripts\"]:\n                        del world[\"scripts\"][sel_scr[0]]\n                        sel_scr[0]=None; setmsg(\"Script deleted.\")\n                elif k in (ord('w'),ord('W')):\n                    pth=save_world(world); setmsg(\"Saved \u2192 \"+pth)\n\n        return world\n\n    # \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n    #  MAIN MENU\n    # \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n    os.system(\"cls\" if os.name==\"nt\" else \"clear\")\n    print(\"\\033[96m\\033[1m\")\n    print(\"  \u2554\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2557\")\n    print(\"  \u2551                                                          \u2551\")\n    print(\"  \u2551  \u2588\u2588\u2557  \u2588\u2588\u2557\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2557\u2588\u2588\u2588\u2557  \u2588\u2588\u2557 \u2588\u2588\u2588\u2588\u2588\u2588\u2557 \u2588\u2588\u2557\u2588\u2588\u2588\u2557  \u2588\u2588\u2557\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2557\u2551\")\n    print(\"  \u2551  \u255a\u2588\u2588\u2557\u2588\u2588\u2554\u255d\u2588\u2588\u2554\u2550\u2550\u2550\u2550\u255d\u2588\u2588\u2588\u2588\u2557 \u2588\u2588\u2551\u2588\u2588\u2554\u2550\u2550\u2550\u2550\u255d \u2588\u2588\u2551\u2588\u2588\u2588\u2588\u2557 \u2588\u2588\u2551\u2588\u2588\u2554\u2550\u2550\u2550\u2550\u255d\u2551\")\n    print(\"  \u2551   \u255a\u2588\u2588\u2588\u2554\u255d \u2588\u2588\u2588\u2588\u2588\u2557  \u2588\u2588\u2554\u2588\u2588\u2557\u2588\u2588\u2551\u2588\u2588\u2551  \u2588\u2588\u2588\u2557\u2588\u2588\u2551\u2588\u2588\u2554\u2588\u2588\u2557\u2588\u2588\u2551\u2588\u2588\u2588\u2588\u2588\u2557  \u2551\")\n    print(\"  \u2551   \u2588\u2588\u2554\u2588\u2588\u2557 \u2588\u2588\u2554\u2550\u2550\u255d  \u2588\u2588\u2551\u255a\u2588\u2588\u2588\u2588\u2551\u2588\u2588\u2551   \u2588\u2588\u2551\u2588\u2588\u2551\u2588\u2588\u2551\u255a\u2588\u2588\u2588\u2588\u2551\u2588\u2588\u2554\u2550\u2550\u255d  \u2551\")\n    print(\"  \u2551  \u2588\u2588\u2554\u255d\u255a\u2588\u2588\u2557\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2557\u2588\u2588\u2551 \u255a\u2588\u2588\u2588\u2551\u255a\u2588\u2588\u2588\u2588\u2588\u2588\u2554\u255d\u2588\u2588\u2551\u2588\u2588\u2551 \u255a\u2588\u2588\u2588\u2551\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2557\u2551\")\n    print(\"  \u2551                                                          \u2551\")\n    print(\"  \u2551    CLI Raycaster Game Engine  \u2014  Build & Play in 3D     \u2551\")\n    print(\"  \u2551    Minecraft-style block rendering, no external libs     \u2551\")\n    print(\"  \u2551                                                          \u2551\")\n    print(\"  \u255a\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u255d\\033[0m\")\n    print()\n\n    worlds = list_worlds()\n    if worlds:\n        print(\"  \\033[92mSaved worlds:\\033[0m\")\n        for i,wn in enumerate(worlds):\n            print(\"    [\"+str(i)+\"] \"+wn)\n        print()\n\n    print(\"  \\033[93m[N]\\033[0m New world\")\n    print(\"  \\033[96m[L]\\033[0m Load world\")\n    print(\"  \\033[91m[Q]\\033[0m Quit\")\n    print()\n    choice=input(\"\\033[2m  > \\033[0m\").strip().lower()\n\n    world=None\n    if choice==\"q\": return\n    elif choice==\"l\" and worlds:\n        if len(worlds)==1:\n            world=load_world(worlds[0])\n        else:\n            idx=input(\"  World number [0-\"+str(len(worlds)-1)+\"]: \").strip()\n            try: world=load_world(worlds[int(idx)])\n            except: world=load_world(worlds[0])\n        if not world:\n            print(\"  \\033[91mFailed to load.\\033[0m\"); world=empty_world()\n    else:  # N or anything else\n        wname=input(\"  World name: \").strip() or \"My World\"\n        world=empty_world(); world[\"name\"]=wname\n\n    print(\"\\n\\033[2m  Opening editor...\\033[0m\")\n    time.sleep(0.3)\n    curses.wrapper(run_editor, world)\n    print(\"\\n\\033[92m  XEngine session ended. World: \"+world[\"name\"]+\"\\033[0m\")\n    input(\"\\033[2m  Press ENTER to exit.\\033[0m\")\n\n_game()\n"
        }
    ]
}