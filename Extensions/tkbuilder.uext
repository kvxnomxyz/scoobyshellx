{
    "name": "TkBuilder \u2014 CLI Tkinter App Builder",
    "author": "kvxnom (Code), Claude 4.6 (Designing UEXT, UNICODEFix)",
    "version": "1.0",
    "sig_ver": 2,
    "aid": "com.kvxnom.tkbuilder",
    "certcode": "49A65B93B493623272B64AEB1E485575D9AA8A6A348D03B7400F8C62E24F7F10",
    "description": "Interactive CLI builder for Tkinter GUIs. Place widgets on a canvas, configure every property, then export a complete working Python/Tkinter script. Command: tkbuilder",
    "commands": [
        {
            "name": "tkbuilder",
            "description": "Launch the TkBuilder CLI \u2014 design Tkinter GUIs and export Python scripts",
            "action": "python",
            "value": "def _tkbuilder():\n    import curses, json, os, textwrap, re, copy\n\n    # ==============================================================\n    #  WIDGET CATALOGUE  -- every major tkinter widget + properties\n    # ==============================================================\n    WIDGET_TYPES = [\n        \"Button\", \"Label\", \"Entry\", \"Text\", \"Frame\", \"LabelFrame\",\n        \"Checkbutton\", \"Radiobutton\", \"Scale\", \"Scrollbar\", \"Listbox\",\n        \"Combobox\", \"Spinbox\", \"OptionMenu\", \"Canvas\", \"Message\",\n        \"PanedWindow\", \"Notebook\", \"Treeview\", \"ProgressBar\",\n        \"Separator\", \"Sizegrip\", \"MenuButton\",\n    ]\n\n    # Default props per widget type\n    DEFAULTS = {\n        \"Button\":      {\"text\":\"Button\",\"width\":\"10\",\"height\":\"1\",\"bg\":\"#e0e0e0\",\"fg\":\"#000000\",\"font\":\"Arial 10\",\"relief\":\"raised\",\"state\":\"normal\",\"cursor\":\"\",\"command\":\"on_click\",\"padx\":\"4\",\"pady\":\"2\",\"anchor\":\"center\",\"justify\":\"center\",\"wraplength\":\"0\",\"underline\":\"-1\",\"overrelief\":\"groove\",\"activebackground\":\"#c0c0c0\",\"activeforeground\":\"#000000\",\"disabledforeground\":\"#a0a0a0\"},\n        \"Label\":       {\"text\":\"Label\",\"width\":\"10\",\"height\":\"1\",\"bg\":\"#f0f0f0\",\"fg\":\"#000000\",\"font\":\"Arial 10\",\"relief\":\"flat\",\"anchor\":\"w\",\"justify\":\"left\",\"wraplength\":\"0\",\"padx\":\"2\",\"pady\":\"2\",\"underline\":\"-1\",\"bd\":\"0\",\"cursor\":\"\",\"image\":\"\"},\n        \"Entry\":       {\"width\":\"20\",\"bg\":\"#ffffff\",\"fg\":\"#000000\",\"font\":\"Arial 10\",\"relief\":\"sunken\",\"state\":\"normal\",\"show\":\"\",\"justify\":\"left\",\"bd\":\"2\",\"cursor\":\"xterm\",\"selectbackground\":\"#0078d7\",\"selectforeground\":\"#ffffff\",\"insertwidth\":\"1\",\"exportselection\":\"1\"},\n        \"Text\":        {\"width\":\"40\",\"height\":\"8\",\"bg\":\"#ffffff\",\"fg\":\"#000000\",\"font\":\"Courier 10\",\"relief\":\"sunken\",\"state\":\"normal\",\"wrap\":\"word\",\"bd\":\"2\",\"cursor\":\"xterm\",\"padx\":\"2\",\"pady\":\"2\",\"spacing1\":\"0\",\"spacing2\":\"0\",\"spacing3\":\"0\",\"selectbackground\":\"#0078d7\",\"selectforeground\":\"#ffffff\",\"insertwidth\":\"1\",\"undo\":\"0\",\"maxundo\":\"-1\"},\n        \"Frame\":       {\"width\":\"200\",\"height\":\"100\",\"bg\":\"#f0f0f0\",\"relief\":\"flat\",\"bd\":\"0\",\"padx\":\"0\",\"pady\":\"0\",\"cursor\":\"\"},\n        \"LabelFrame\":  {\"text\":\"Group\",\"width\":\"200\",\"height\":\"100\",\"bg\":\"#f0f0f0\",\"fg\":\"#000000\",\"font\":\"Arial 10\",\"relief\":\"groove\",\"bd\":\"2\",\"padx\":\"4\",\"pady\":\"4\",\"labelanchor\":\"nw\",\"cursor\":\"\"},\n        \"Checkbutton\": {\"text\":\"Check\",\"bg\":\"#f0f0f0\",\"fg\":\"#000000\",\"font\":\"Arial 10\",\"state\":\"normal\",\"command\":\"on_check\",\"onvalue\":\"1\",\"offvalue\":\"0\",\"activebackground\":\"#e0e0e0\",\"activeforeground\":\"#000000\",\"selectcolor\":\"#ffffff\",\"relief\":\"flat\",\"anchor\":\"w\",\"cursor\":\"\"},\n        \"Radiobutton\": {\"text\":\"Option\",\"value\":\"1\",\"bg\":\"#f0f0f0\",\"fg\":\"#000000\",\"font\":\"Arial 10\",\"state\":\"normal\",\"command\":\"on_radio\",\"activebackground\":\"#e0e0e0\",\"activeforeground\":\"#000000\",\"selectcolor\":\"#ffffff\",\"relief\":\"flat\",\"anchor\":\"w\",\"cursor\":\"\"},\n        \"Scale\":       {\"from_\":\"0\",\"to\":\"100\",\"orient\":\"horizontal\",\"length\":\"200\",\"width\":\"15\",\"sliderlength\":\"30\",\"bg\":\"#f0f0f0\",\"fg\":\"#000000\",\"troughcolor\":\"#c0c0c0\",\"font\":\"Arial 9\",\"state\":\"normal\",\"showvalue\":\"1\",\"tickinterval\":\"0\",\"resolution\":\"1\",\"command\":\"on_scale\",\"cursor\":\"\"},\n        \"Scrollbar\":   {\"orient\":\"vertical\",\"width\":\"16\",\"bg\":\"#e0e0e0\",\"troughcolor\":\"#c8c8c8\",\"relief\":\"sunken\",\"bd\":\"2\",\"cursor\":\"\"},\n        \"Listbox\":     {\"width\":\"20\",\"height\":\"6\",\"bg\":\"#ffffff\",\"fg\":\"#000000\",\"font\":\"Arial 10\",\"relief\":\"sunken\",\"bd\":\"2\",\"selectmode\":\"browse\",\"activestyle\":\"dotbox\",\"selectbackground\":\"#0078d7\",\"selectforeground\":\"#ffffff\",\"cursor\":\"arrow\",\"exportselection\":\"1\"},\n        \"Combobox\":    {\"width\":\"15\",\"font\":\"Arial 10\",\"state\":\"readonly\",\"values\":\"Option1 Option2 Option3\",\"justify\":\"left\",\"postcommand\":\"\"},\n        \"Spinbox\":     {\"from_\":\"0\",\"to\":\"100\",\"width\":\"8\",\"bg\":\"#ffffff\",\"fg\":\"#000000\",\"font\":\"Arial 10\",\"relief\":\"sunken\",\"state\":\"normal\",\"wrap\":\"0\",\"increment\":\"1\",\"format\":\"\",\"command\":\"on_spin\",\"cursor\":\"xterm\"},\n        \"OptionMenu\":  {\"width\":\"10\",\"bg\":\"#e0e0e0\",\"fg\":\"#000000\",\"font\":\"Arial 10\",\"relief\":\"raised\",\"anchor\":\"center\",\"values\":\"Option1 Option2 Option3\"},\n        \"Canvas\":      {\"width\":\"400\",\"height\":\"300\",\"bg\":\"#ffffff\",\"relief\":\"sunken\",\"bd\":\"2\",\"scrollregion\":\"0 0 400 300\",\"cursor\":\"crosshair\",\"highlightthickness\":\"1\"},\n        \"Message\":     {\"text\":\"Message text here\",\"width\":\"200\",\"bg\":\"#f0f0f0\",\"fg\":\"#000000\",\"font\":\"Arial 10\",\"relief\":\"flat\",\"anchor\":\"nw\",\"justify\":\"left\",\"aspect\":\"150\",\"padx\":\"2\",\"pady\":\"2\"},\n        \"PanedWindow\": {\"orient\":\"horizontal\",\"bg\":\"#d0d0d0\",\"relief\":\"flat\",\"bd\":\"0\",\"sashwidth\":\"6\",\"sashpad\":\"2\",\"sashrelief\":\"flat\",\"handlepad\":\"8\",\"handlesize\":\"8\",\"showhandle\":\"0\"},\n        \"Notebook\":    {\"width\":\"400\",\"height\":\"300\",\"padding\":\"2\"},\n        \"Treeview\":    {\"height\":\"8\",\"columns\":\"col1 col2\",\"show\":\"headings tree\",\"selectmode\":\"browse\",\"padding\":\"2\"},\n        \"ProgressBar\": {\"orient\":\"horizontal\",\"length\":\"200\",\"mode\":\"determinate\",\"maximum\":\"100\",\"value\":\"50\",\"style\":\"\"},\n        \"Separator\":   {\"orient\":\"horizontal\"},\n        \"Sizegrip\":    {},\n        \"MenuButton\":  {\"text\":\"Menu\",\"bg\":\"#e0e0e0\",\"fg\":\"#000000\",\"font\":\"Arial 10\",\"relief\":\"raised\",\"direction\":\"below\",\"anchor\":\"center\",\"state\":\"normal\",\"cursor\":\"\"},\n    }\n\n    # layout methods\n    LAYOUT_METHODS = [\"pack\", \"grid\", \"place\"]\n\n    LAYOUT_DEFAULTS = {\n        \"pack\":  {\"side\":\"top\",\"fill\":\"none\",\"expand\":\"0\",\"padx\":\"4\",\"pady\":\"4\",\"ipadx\":\"0\",\"ipady\":\"0\",\"anchor\":\"center\"},\n        \"grid\":  {\"row\":\"0\",\"column\":\"0\",\"rowspan\":\"1\",\"columnspan\":\"1\",\"padx\":\"4\",\"pady\":\"4\",\"ipadx\":\"0\",\"ipady\":\"0\",\"sticky\":\"nsew\"},\n        \"place\": {\"x\":\"10\",\"y\":\"10\",\"width\":\"\",\"height\":\"\",\"relx\":\"0\",\"rely\":\"0\",\"relwidth\":\"\",\"relheight\":\"\",\"anchor\":\"nw\"},\n    }\n\n    # ==============================================================\n    #  STATE\n    # ==============================================================\n    state = {\n        \"widgets\": [],        # list of widget dicts\n        \"selected\": -1,       # index into widgets\n        \"app_title\": \"My App\",\n        \"win_width\": \"800\",\n        \"win_height\": \"600\",\n        \"win_bg\": \"#f0f0f0\",\n        \"win_resizable\": \"1\",\n        \"win_icon\": \"\",\n        \"theme\": \"default\",   # ttk theme\n        \"menu_enabled\": \"0\",\n        \"statusbar\": \"0\",\n        \"counter\": {},        # type -> count for var naming\n    }\n\n    def new_widget(wtype):\n        c = state[\"counter\"]\n        c[wtype] = c.get(wtype, 0) + 1\n        idx = c[wtype]\n        props = copy.deepcopy(DEFAULTS.get(wtype, {}))\n        layout = \"pack\"\n        lo = copy.deepcopy(LAYOUT_DEFAULTS[\"pack\"])\n        return {\n            \"id\": wtype.lower() + str(idx),\n            \"type\": wtype,\n            \"var\": wtype.lower() + str(idx),\n            \"props\": props,\n            \"layout\": layout,\n            \"lo\": lo,\n            \"note\": \"\",\n        }\n\n    # ==============================================================\n    #  CODE GENERATOR\n    # ==============================================================\n    def generate_code():\n        lines = []\n        ttk_types = {\"Combobox\",\"Progressbar\",\"Treeview\",\"Notebook\",\n                     \"Separator\",\"Sizegrip\",\"PanedWindow\",\"Notebook\",\"ProgressBar\"}\n        has_ttk = any(w[\"type\"] in ttk_types for w in state[\"widgets\"])\n        has_var  = any(w[\"type\"] in (\"Checkbutton\",\"Radiobutton\",\"Scale\",\"Spinbox\",\"Combobox\",\"Entry\",\"OptionMenu\") for w in state[\"widgets\"])\n\n        lines += [\n            \"# Generated by TkBuilder -- edit freely\",\n            \"import tkinter as tk\",\n        ]\n        if has_ttk:\n            lines.append(\"from tkinter import ttk\")\n        lines += [\n            \"from tkinter import messagebox, filedialog, colorchooser, simpledialog, font as tkfont\",\n            \"\",\n        ]\n\n        # collect callbacks\n        callbacks = set()\n        for w in state[\"widgets\"]:\n            cmd = w[\"props\"].get(\"command\",\"\")\n            if cmd and cmd.strip():\n                callbacks.add(cmd.strip())\n        for w in state[\"widgets\"]:\n            pc = w[\"props\"].get(\"postcommand\",\"\")\n            if pc and pc.strip():\n                callbacks.add(pc.strip())\n\n        lines += [\n            \"# -- App class --------------------------------------------------\",\n            \"class App(tk.Tk):\",\n            \"    def __init__(self):\",\n            \"        super().__init__()\",\n            f\"        self.title({json.dumps(state['app_title'])})\",\n            f\"        self.geometry('{state['win_width']}x{state['win_height']}')\",\n            f\"        self.configure(bg={json.dumps(state['win_bg'])})\",\n            f\"        self.resizable({'True' if state['win_resizable']=='1' else 'False'}, {'True' if state['win_resizable']=='1' else 'False'})\",\n        ]\n\n        if state[\"win_icon\"]:\n            lines.append(f\"        self.iconbitmap({json.dumps(state['win_icon'])})\")\n\n        if has_ttk:\n            lines.append(f\"        self.style = ttk.Style(self)\")\n            lines.append(f\"        self.style.theme_use({json.dumps(state['theme'])})\")\n\n        lines.append(\"        self._build_ui()\")\n\n        # menu\n        if state[\"menu_enabled\"] == \"1\":\n            lines += [\n                \"\",\n                \"    def _build_menu(self):\",\n                \"        menubar = tk.Menu(self)\",\n                \"        filemenu = tk.Menu(menubar, tearoff=0)\",\n                \"        filemenu.add_command(label='New',  command=self.on_menu_new)\",\n                \"        filemenu.add_command(label='Open', command=self.on_menu_open)\",\n                \"        filemenu.add_command(label='Save', command=self.on_menu_save)\",\n                \"        filemenu.add_separator()\",\n                \"        filemenu.add_command(label='Exit', command=self.destroy)\",\n                \"        menubar.add_cascade(label='File', menu=filemenu)\",\n                \"        helpmenu = tk.Menu(menubar, tearoff=0)\",\n                \"        helpmenu.add_command(label='About', command=self.on_menu_about)\",\n                \"        menubar.add_cascade(label='Help', menu=helpmenu)\",\n                \"        self.config(menu=menubar)\",\n            ]\n\n        lines += [\"\", \"    def _build_ui(self):\"]\n\n        if state[\"menu_enabled\"] == \"1\":\n            lines.append(\"        self._build_menu()\")\n\n        # status bar\n        if state[\"statusbar\"] == \"1\":\n            lines += [\n                \"        self._status_var = tk.StringVar(value='Ready')\",\n                \"        self._statusbar = tk.Label(self, textvariable=self._status_var, relief='sunken', anchor='w', font='Arial 9')\",\n                \"        self._statusbar.pack(side='bottom', fill='x')\",\n            ]\n\n        # trace variables\n        var_lines = []\n        for w in state[\"widgets\"]:\n            vname = w[\"var\"] + \"_var\"\n            wt = w[\"type\"]\n            if wt in (\"Checkbutton\",\"Radiobutton\"):\n                var_lines.append(f\"        self.{vname} = tk.IntVar(value=0)\")\n            elif wt in (\"Entry\",\"Spinbox\",\"Combobox\",\"OptionMenu\"):\n                var_lines.append(f\"        self.{vname} = tk.StringVar(value='')\")\n            elif wt == \"Scale\":\n                var_lines.append(f\"        self.{vname} = tk.DoubleVar(value=0)\")\n        if var_lines:\n            lines += [\"\"] + var_lines\n\n        lines.append(\"\")\n\n        # ensure _build_ui always has at least one statement\n        _ui_body_start = len(lines)\n\n        # widget instantiation\n        ttk_map = {\n            \"Combobox\":\"ttk.Combobox\",\"ProgressBar\":\"ttk.Progressbar\",\n            \"Treeview\":\"ttk.Treeview\",\"Notebook\":\"ttk.Notebook\",\n            \"Separator\":\"ttk.Separator\",\"Sizegrip\":\"ttk.Sizegrip\",\n            \"PanedWindow\":\"ttk.PanedWindow\",\n        }\n\n        for w in state[\"widgets\"]:\n            vname    = w[\"var\"]\n            wtype    = w[\"type\"]\n            cls      = ttk_map.get(wtype, \"tk.\" + wtype)\n            props    = w[\"props\"]\n            lmethod  = w[\"layout\"]\n            lo       = w[\"lo\"]\n\n            # build kwargs\n            skip_props = set()\n            kw_parts = []\n\n            p = dict(props)\n\n            # attach variable where relevant\n            if wtype in (\"Checkbutton\",\"Radiobutton\"):\n                kw_parts.append(f\"variable=self.{vname}_var\")\n            elif wtype in (\"Entry\",\"Spinbox\"):\n                kw_parts.append(f\"textvariable=self.{vname}_var\")\n            elif wtype == \"Scale\":\n                kw_parts.append(f\"variable=self.{vname}_var\")\n\n            for k, v in p.items():\n                if v == \"\": continue\n                if k == \"command\" and v:\n                    kw_parts.append(f\"command=self.{v}\")\n                elif k == \"postcommand\" and v:\n                    kw_parts.append(f\"postcommand=self.{v}\")\n                elif k == \"values\" and wtype in (\"Combobox\",\"OptionMenu\",\"Treeview\"):\n                    vals = [x.strip() for x in v.split() if x.strip()]\n                    kw_parts.append(f\"values={vals!r}\")\n                elif k == \"image\":\n                    pass  # user handles images\n                else:\n                    # booleans\n                    if v in (\"0\",\"1\") and k not in (\"row\",\"column\",\"rowspan\",\"columnspan\",\"padx\",\"pady\",\"ipadx\",\"ipady\",\"x\",\"y\",\"width\",\"height\",\"underline\",\"onvalue\",\"offvalue\",\"value\",\"increment\",\"resolution\",\"from_\",\"to\",\"tickinterval\",\"spacing1\",\"spacing2\",\"spacing3\",\"bd\",\"insertwidth\",\"wraplength\",\"padx\",\"pady\",\"aspect\",\"length\",\"sashwidth\",\"sashpad\",\"handlepad\",\"handlesize\",\"maximum\"):\n                        kw_parts.append(f\"{k}={int(v)==1}\")\n                    elif v.lstrip('-').isdigit() or (v.replace('.','',1).lstrip('-').isdigit() and '.' in v):\n                        kw_parts.append(f\"{k}={v}\")\n                    else:\n                        kw_parts.append(f\"{k}={json.dumps(v)}\")\n\n            kw_str = \", \".join(kw_parts)\n            if kw_str:\n                lines.append(f\"        self.{vname} = {cls}(self, {kw_str})\")\n            else:\n                lines.append(f\"        self.{vname} = {cls}(self)\")\n\n            # special post-creation for Listbox\n            if wtype == \"Listbox\":\n                lines.append(f\"        self.{vname}.insert('end', 'Item 1', 'Item 2', 'Item 3')\")\n            # Combobox default\n            if wtype == \"Combobox\":\n                vals2 = [x.strip() for x in props.get(\"values\",\"\").split() if x.strip()]\n                if vals2:\n                    lines.append(f\"        self.{vname}.set({json.dumps(vals2[0])})\")\n            # Treeview headings\n            if wtype == \"Treeview\":\n                cols = [x.strip() for x in props.get(\"columns\",\"\").split() if x.strip()]\n                for col in cols:\n                    lines.append(f\"        self.{vname}.heading({json.dumps(col)}, text={json.dumps(col.capitalize())})\")\n            # OptionMenu special\n            if wtype == \"OptionMenu\":\n                vals3 = [x.strip() for x in props.get(\"values\",\"Option1\").split() if x.strip()]\n                opts  = \", \".join(json.dumps(v) for v in vals3)\n                lines[-1] = f\"        self.{vname}_var = tk.StringVar(value={json.dumps(vals3[0])})\"\n                lines.append(f\"        self.{vname} = tk.OptionMenu(self, self.{vname}_var, {opts})\")\n\n            # layout\n            lo_kw = []\n            for k2, v2 in lo.items():\n                if v2 == \"\": continue\n                if v2.lstrip('-').isdigit():\n                    lo_kw.append(f\"{k2}={v2}\")\n                else:\n                    lo_kw.append(f\"{k2}={json.dumps(v2)}\")\n            lo_str = \", \".join(lo_kw)\n            lines.append(f\"        self.{vname}.{lmethod}({lo_str})\")\n            lines.append(\"\")\n\n        # ensure _build_ui body is never empty (would cause IndentationError)\n        if len(lines) == _ui_body_start:\n            lines.append(\"        pass\")\n\n        # callbacks\n        if callbacks:\n            lines += [\n                \"\",\n                \"    # -- Event handlers ------------------------------------------\",\n            ]\n        for cb in sorted(callbacks):\n            lines += [\n                f\"    def {cb}(self, *args):\",\n                f\"        pass  # TODO: implement {cb}\",\n                \"\",\n            ]\n        if state[\"menu_enabled\"] == \"1\":\n            for mcb in [\"on_menu_new\",\"on_menu_open\",\"on_menu_save\",\"on_menu_about\"]:\n                lines += [\n                    f\"    def {mcb}(self):\",\n                    f\"        pass  # TODO\",\n                    \"\",\n                ]\n\n        lines += [\n            \"\",\n            \"# -- Entry point -------------------------------------------------\",\n            \"if __name__ == '__main__':\",\n            \"    app = App()\",\n            \"    app.mainloop()\",\n        ]\n\n        return \"\\n\".join(lines)\n\n    # ==============================================================\n    #  CURSES UI\n    # ==============================================================\n    def run(stdscr):\n        curses.curs_set(0)\n        curses.start_color()\n        curses.use_default_colors()\n        curses.init_pair(1,  curses.COLOR_WHITE,   -1)\n        curses.init_pair(2,  curses.COLOR_BLACK,   curses.COLOR_CYAN)\n        curses.init_pair(3,  curses.COLOR_YELLOW,  -1)\n        curses.init_pair(4,  curses.COLOR_GREEN,   -1)\n        curses.init_pair(5,  curses.COLOR_RED,     -1)\n        curses.init_pair(6,  curses.COLOR_BLACK,   curses.COLOR_YELLOW)\n        curses.init_pair(7,  curses.COLOR_CYAN,    -1)\n        curses.init_pair(8,  curses.COLOR_WHITE,   curses.COLOR_BLUE)\n        curses.init_pair(9,  curses.COLOR_BLACK,   curses.COLOR_WHITE)\n        curses.init_pair(10, curses.COLOR_MAGENTA, -1)\n        curses.init_pair(11, curses.COLOR_WHITE,   curses.COLOR_RED)\n        curses.init_pair(12, curses.COLOR_BLACK,   curses.COLOR_GREEN)\n\n        P_NORM  = curses.color_pair(1)\n        P_SEL   = curses.color_pair(2) | curses.A_BOLD\n        P_YEL   = curses.color_pair(3) | curses.A_BOLD\n        P_GRN   = curses.color_pair(4)\n        P_RED   = curses.color_pair(5) | curses.A_BOLD\n        P_HINV  = curses.color_pair(6) | curses.A_BOLD\n        P_CYA   = curses.color_pair(7)\n        P_TITLE = curses.color_pair(8) | curses.A_BOLD\n        P_INV   = curses.color_pair(9)\n        P_MAG   = curses.color_pair(10)\n        P_ERR   = curses.color_pair(11) | curses.A_BOLD\n        P_OK    = curses.color_pair(12) | curses.A_BOLD\n\n        msg     = [\"\"]\n        msg_ok  = [True]\n\n        def set_msg(text, ok=True):\n            msg[0]    = text\n            msg_ok[0] = ok\n\n        # -- input helpers ------------------------------------------\n        def prompt(stdscr, label, default=\"\"):\n            sh, sw = stdscr.getmaxyx()\n            row = sh - 2\n            curses.curs_set(1)\n            buf = \"\"\n            def _draw_prompt():\n                try:\n                    stdscr.move(row, 0)\n                    stdscr.clrtoeol()\n                    full = (label + \" [\" + default + \"]: \" + buf)[:sw-1]\n                    stdscr.addstr(row, 0, full, P_YEL)\n                    stdscr.refresh()\n                except: pass\n            _draw_prompt()\n            while True:\n                k = stdscr.getch()\n                if k in (10, 13):\n                    curses.curs_set(0)\n                    return buf if buf else default\n                elif k == 27:\n                    curses.curs_set(0)\n                    return default\n                elif k in (curses.KEY_BACKSPACE, 127, 8):\n                    buf = buf[:-1]\n                elif 32 <= k < 256:\n                    buf += chr(k)\n                _draw_prompt()\n\n        def menu_popup(stdscr, title, options):\n            if not options:\n                return -1\n            sh, sw = stdscr.getmaxyx()\n            max_w = max((len(o) for o in options), default=10) + 6\n            max_w = max(max_w, len(title) + 4, 28)\n            max_w = min(max_w, sw - 4)          # clamp to terminal width\n            max_w = max(max_w, 10)\n            ph = len(options) + 4\n            py = max(0, min((sh - ph) // 2, sh - ph - 1))\n            px = max(0, (sw - max_w) // 2)\n            # scroll offset so selected item stays visible\n            vis_h = max(1, sh - py - 4)\n            sel = 0\n            scroll = 0\n            stdscr.nodelay(False)\n            while True:\n                sh, sw = stdscr.getmaxyx()\n                max_w = min(max_w, sw - 4)\n                vis_h = max(1, sh - py - 5)\n                if sel < scroll: scroll = sel\n                if sel >= scroll + vis_h: scroll = sel - vis_h + 1\n                try:\n                    stdscr.attron(P_TITLE)\n                    stdscr.addstr(py, px, \"+\" + \"-\" * (max_w-2) + \"+\")\n                    lbl = \" \" + title[:max_w-4] + \" \"\n                    stdscr.addstr(py, px + max(0, (max_w - len(lbl)) // 2), lbl)\n                    stdscr.attroff(P_TITLE)\n                except: pass\n                for vi in range(vis_h):\n                    i = scroll + vi\n                    if i >= len(options): break\n                    row = py + 1 + vi\n                    if row >= sh - 1: break\n                    attr = P_SEL if i == sel else P_NORM\n                    line = (\" > \" if i == sel else \"   \") + options[i]\n                    try:\n                        stdscr.addstr(row, px, \"|\")\n                        stdscr.addstr(row, px+1, line.ljust(max_w-2)[:max_w-2], attr)\n                        stdscr.addstr(row, min(px+max_w-1, sw-2), \"|\")\n                    except: pass\n                bot = py + 1 + min(vis_h, len(options))\n                try:\n                    stdscr.attron(P_TITLE)\n                    if bot < sh-1: stdscr.addstr(bot, px, \"+\" + \"-\" * (max_w-2) + \"+\")\n                    esc_row = bot + 1\n                    if esc_row < sh-1:\n                        stdscr.addstr(esc_row, px, \"| \" + \"ESC=cancel\".center(max_w-4)[:max_w-4] + \" |\")\n                    bot2 = bot + 2\n                    if bot2 < sh-1: stdscr.addstr(bot2, px, \"+\" + \"-\" * (max_w-2) + \"+\")\n                    stdscr.attroff(P_TITLE)\n                except: pass\n                stdscr.refresh()\n                k = stdscr.getch()\n                if k in (curses.KEY_UP, ord('w'), ord('W'), ord('k')):\n                    sel = (sel-1) % len(options)\n                elif k in (curses.KEY_DOWN, ord('s'), ord('S'), ord('j')):\n                    sel = (sel+1) % len(options)\n                elif k in (10, 13):\n                    stdscr.nodelay(True)\n                    return sel\n                elif k == 27:\n                    stdscr.nodelay(True)\n                    return -1\n\n        def confirm_popup(stdscr, question):\n            sh, sw = stdscr.getmaxyx()\n            max_w = min(max(len(question) + 4, 30), sw - 4)\n            py = max(0, sh // 2 - 2)\n            px = max(0, (sw - max_w) // 2)\n            try:\n                stdscr.attron(P_ERR)\n                if py < sh:   stdscr.addstr(py,   px, \"+\" + \"-\" * (max_w-2) + \"+\")\n                if py+1 < sh: stdscr.addstr(py+1, px, \"| \" + question[:max_w-4].center(max_w-4) + \" |\")\n                if py+2 < sh: stdscr.addstr(py+2, px, \"| \" + \"[Y] Yes    [N] No\".center(max_w-4) + \" |\")\n                if py+3 < sh: stdscr.addstr(py+3, px, \"+\" + \"-\" * (max_w-2) + \"+\")\n                stdscr.attroff(P_ERR)\n            except: pass\n            stdscr.refresh()\n            stdscr.nodelay(False)\n            while True:\n                k = stdscr.getch()\n                if k in (ord('y'), ord('Y')): stdscr.nodelay(True); return True\n                if k in (ord('n'), ord('N'), 27): stdscr.nodelay(True); return False\n\n        def info_popup(stdscr, lines, title=\"INFO\"):\n            sh, sw = stdscr.getmaxyx()\n            max_w = max((len(l) for l in lines), default=10) + 4\n            max_w = max(max_w, len(title) + 4, 24)\n            max_w = min(max_w, sw - 4)\n            ph = len(lines) + 4\n            py = max(0, (sh - ph) // 2)\n            px = max(0, (sw - max_w) // 2)\n            try:\n                stdscr.attron(P_CYA | curses.A_BOLD)\n                stdscr.addstr(py, px, \"+\" + \"-\"*(max_w-2) + \"+\")\n                stdscr.addstr(py, px + max(0,(max_w - len(title)-2)//2), \" \"+title[:max_w-4]+\" \")\n                stdscr.attroff(P_CYA | curses.A_BOLD)\n            except: pass\n            for i, l in enumerate(lines):\n                row = py+1+i\n                if row >= sh-1: break\n                try: stdscr.addstr(row, px, \"| \" + l.ljust(max_w-4)[:max_w-4] + \" |\")\n                except: pass\n            bot = py+1+len(lines)\n            try:\n                stdscr.attron(P_CYA | curses.A_BOLD)\n                if bot < sh-1:   stdscr.addstr(bot,   px, \"+\" + \"-\"*(max_w-2) + \"+\")\n                if bot+1 < sh-1: stdscr.addstr(bot+1, px, \"| \" + \"[ ENTER ]\".center(max_w-4) + \" |\")\n                if bot+2 < sh-1: stdscr.addstr(bot+2, px, \"+\" + \"-\"*(max_w-2) + \"+\")\n                stdscr.attroff(P_CYA | curses.A_BOLD)\n            except: pass\n            stdscr.refresh()\n            stdscr.nodelay(False)\n            while True:\n                k = stdscr.getch()\n                if k in (10,13,27,ord(' ')): break\n            stdscr.nodelay(True)\n\n        # -- edit props of selected widget --------------------------\n        def edit_props(stdscr):\n            if state[\"selected\"] < 0 or state[\"selected\"] >= len(state[\"widgets\"]):\n                set_msg(\"No widget selected.\", False)\n                return\n            w = state[\"widgets\"][state[\"selected\"]]\n            while True:\n                keys = list(w[\"props\"].keys())\n                opts = [f\"{k:<20} = {v}\"[:60] for k, v in w[\"props\"].items()]\n                opts += [\"--- Layout: \" + w[\"layout\"] + \" ---\"]\n                for lk, lv in w[\"lo\"].items():\n                    opts.append(f\"  lo.{lk:<16} = {lv}\")\n                opts += [\"--- Meta ---\",\n                         f\"  var name   = {w['var']}\",\n                         f\"  note       = {w['note']}\",\n                         \"[Done]\",\n                        ]\n                sel = menu_popup(stdscr, f\"EDIT {w['type']} [{w['id']}]\", opts)\n                if sel < 0 or opts[sel] == \"[Done]\": break\n                chosen = opts[sel]\n                # props\n                if sel < len(keys):\n                    k = keys[sel]\n                    val = prompt(stdscr, k, w[\"props\"][k])\n                    w[\"props\"][k] = val\n                    set_msg(f\"  {k} = {val}\")\n                # layout method\n                elif chosen.startswith(\"--- Layout\"):\n                    lm_sel = menu_popup(stdscr, \"Layout method\", LAYOUT_METHODS)\n                    if lm_sel >= 0:\n                        new_lm = LAYOUT_METHODS[lm_sel]\n                        w[\"layout\"] = new_lm\n                        w[\"lo\"] = copy.deepcopy(LAYOUT_DEFAULTS[new_lm])\n                        set_msg(f\"Layout -> {new_lm}\")\n                # layout opts\n                elif chosen.startswith(\"  lo.\"):\n                    lo_keys = list(w[\"lo\"].keys())\n                    lo_opts_list = [f\"lo.{lk:<16} = {lv}\" for lk, lv in w[\"lo\"].items()]\n                    offset = len(keys) + 1\n                    lo_idx = sel - offset\n                    if 0 <= lo_idx < len(lo_keys):\n                        lk = lo_keys[lo_idx]\n                        val = prompt(stdscr, \"lo.\"+lk, w[\"lo\"][lk])\n                        w[\"lo\"][lk] = val\n                        set_msg(f\"  lo.{lk} = {val}\")\n                elif \"var name\" in chosen:\n                    val = prompt(stdscr, \"var name\", w[\"var\"])\n                    if val and val.isidentifier():\n                        w[\"var\"] = val\n                        set_msg(f\"var = {val}\")\n                    else:\n                        set_msg(\"Invalid identifier.\", False)\n                elif \"note\" in chosen:\n                    val = prompt(stdscr, \"note\", w[\"note\"])\n                    w[\"note\"] = val\n\n        # -- draw ---------------------------------------------------\n        def draw(stdscr):\n            stdscr.erase()\n            sh, sw = stdscr.getmaxyx()\n\n            # Title bar\n            title = f\"  TkBuilder  |  {state['app_title']}  {state['win_width']}x{state['win_height']}  |  {len(state['widgets'])} widgets  \"\n            try:\n                stdscr.addstr(0, 0, title.ljust(sw-1)[:sw-1], P_TITLE)\n            except: pass\n\n            # Left panel: widget list (40 wide)\n            PANEL_W = 40\n            list_h = sh - 6\n\n            try: stdscr.addstr(1, 0, \"+\" + \"-\"*(PANEL_W-2) + \"+\", P_CYA)\n            except: pass\n            try: stdscr.addstr(1, 2, \" WIDGETS \", P_YEL)\n            except: pass\n\n            start = max(0, state[\"selected\"] - list_h//2) if state[\"selected\"] >= 0 else 0\n            for i, w in enumerate(state[\"widgets\"]):\n                row = 2 + i - start\n                if row < 2 or row >= 2 + list_h: continue\n                sel = (i == state[\"selected\"])\n                tag = \"[SEL]\" if sel else \"     \"\n                nm  = w[\"type\"][:14].ljust(14)\n                vn  = w[\"var\"][:14]\n                txt = f\" {i+1:02d}. {nm}  {vn}\"\n                attr = P_SEL if sel else P_NORM\n                try:\n                    stdscr.addstr(row, 0, \"|\", P_CYA)\n                    stdscr.addstr(row, 1, txt.ljust(PANEL_W-2)[:PANEL_W-2], attr)\n                    stdscr.addstr(row, PANEL_W-1, \"|\", P_CYA)\n                except: pass\n\n            # empty rows\n            for r in range(2 + len(state[\"widgets\"]), 2 + list_h):\n                try:\n                    stdscr.addstr(r, 0, \"|\" + \" \"*(PANEL_W-2) + \"|\", P_CYA)\n                except: pass\n            try: stdscr.addstr(2+list_h, 0, \"+\" + \"-\"*(PANEL_W-2) + \"+\", P_CYA)\n            except: pass\n\n            # Right panel: selected widget detail\n            RX = PANEL_W + 2\n            RW = max(10, sw - RX - 1)\n            try: stdscr.addstr(1, RX, \"+\" + \"-\"*(RW-2) + \"+\", P_CYA)\n            except: pass\n            try: stdscr.addstr(1, RX+2, \" PROPERTIES \", P_YEL)\n            except: pass\n\n            detail_rows = []\n            if 0 <= state[\"selected\"] < len(state[\"widgets\"]):\n                w = state[\"widgets\"][state[\"selected\"]]\n                detail_rows.append((f\"Widget : {w['type']}\", P_YEL))\n                detail_rows.append((f\"Var    : {w['var']}\", P_CYA))\n                detail_rows.append((f\"Layout : {w['layout']}\", P_GRN))\n                if w[\"note\"]: detail_rows.append((f\"Note   : {w['note']}\", P_MAG))\n                detail_rows.append((\"\", P_NORM))\n                detail_rows.append((\"-- Props ------------------------------\", P_CYA))\n                for k, v in w[\"props\"].items():\n                    detail_rows.append((f\"  {k:<18} {v}\", P_NORM))\n                detail_rows.append((\"\", P_NORM))\n                detail_rows.append((\"-- Layout opts ------------------------\", P_CYA))\n                for k, v in w[\"lo\"].items():\n                    detail_rows.append((f\"  {k:<18} {v}\", P_NORM))\n            else:\n                detail_rows.append((\" No widget selected.\", P_NORM))\n                detail_rows.append((\"\", P_NORM))\n                detail_rows.append((\" App settings:\", P_YEL))\n                detail_rows.append((f\"   title      = {state['app_title']}\", P_NORM))\n                detail_rows.append((f\"   size       = {state['win_width']}x{state['win_height']}\", P_NORM))\n                detail_rows.append((f\"   bg         = {state['win_bg']}\", P_NORM))\n                detail_rows.append((f\"   resizable  = {state['win_resizable']}\", P_NORM))\n                detail_rows.append((f\"   theme      = {state['theme']}\", P_NORM))\n                detail_rows.append((f\"   menu       = {state['menu_enabled']}\", P_NORM))\n                detail_rows.append((f\"   statusbar  = {state['statusbar']}\", P_NORM))\n\n            for i, (row_txt, attr) in enumerate(detail_rows):\n                r = 2 + i\n                if r >= 2 + list_h: break\n                try:\n                    stdscr.addstr(r, RX, \"|\", P_CYA)\n                    stdscr.addstr(r, RX+1, row_txt.ljust(RW-2)[:RW-2], attr)\n                    stdscr.addstr(r, RX+RW-1, \"|\", P_CYA)\n                except: pass\n            for r in range(2 + len(detail_rows), 2 + list_h):\n                try:\n                    stdscr.addstr(r, RX, \"|\" + \" \"*(RW-2) + \"|\", P_CYA)\n                except: pass\n            try: stdscr.addstr(2+list_h, RX, \"+\" + \"-\"*(RW-2) + \"+\", P_CYA)\n            except: pass\n\n            # bottom status\n            status_row = sh - 3\n            keys_row   = sh - 2\n            try:\n                attr = P_OK if msg_ok[0] else P_ERR\n                stdscr.addstr(status_row, 0, (\" \" + msg[0]).ljust(sw-1)[:sw-1], attr)\n            except: pass\n            help_txt = \" A=Add  E=Edit  D=Del  C=Copy  ^v=Select  M=Move  G=AppCfg  X=Export  S=Save  L=Load  Q=Quit \"\n            try:\n                stdscr.addstr(keys_row, 0, help_txt.ljust(sw-1)[:sw-1], P_TITLE)\n            except: pass\n            stdscr.refresh()\n\n        # -- MAIN LOOP ---------------------------------------------\n        stdscr.nodelay(True)\n        stdscr.keypad(True)\n        set_msg(\"Welcome to TkBuilder! Press A to add a widget, Q to quit.\")\n\n        while True:\n            draw(stdscr)\n            k = stdscr.getch()\n            if k == -1:\n                import time; time.sleep(0.02)\n                continue\n\n            sh, sw = stdscr.getmaxyx()\n\n            # navigation\n            if k in (curses.KEY_UP, ord('k')):\n                if state[\"widgets\"]:\n                    state[\"selected\"] = max(0, state[\"selected\"] - 1)\n            elif k in (curses.KEY_DOWN, ord('j')):\n                if state[\"widgets\"]:\n                    state[\"selected\"] = min(len(state[\"widgets\"])-1, state[\"selected\"] + 1)\n\n            # ADD widget\n            elif k in (ord('a'), ord('A')):\n                sel = menu_popup(stdscr, \"Add Widget\", WIDGET_TYPES)\n                if sel >= 0:\n                    wtype = WIDGET_TYPES[sel]\n                    w = new_widget(wtype)\n                    state[\"widgets\"].append(w)\n                    state[\"selected\"] = len(state[\"widgets\"]) - 1\n                    set_msg(f\"Added {wtype} [{w['id']}]\")\n\n            # EDIT\n            elif k in (ord('e'), ord('E')):\n                edit_props(stdscr)\n\n            # DELETE\n            elif k in (ord('d'), ord('D')):\n                if 0 <= state[\"selected\"] < len(state[\"widgets\"]):\n                    w = state[\"widgets\"][state[\"selected\"]]\n                    if confirm_popup(stdscr, f\"Delete {w['type']} [{w['id']}]?\"):\n                        state[\"widgets\"].pop(state[\"selected\"])\n                        state[\"selected\"] = min(state[\"selected\"], len(state[\"widgets\"])-1)\n                        set_msg(\"Deleted.\")\n\n            # COPY/DUPLICATE\n            elif k in (ord('c'), ord('C')):\n                if 0 <= state[\"selected\"] < len(state[\"widgets\"]):\n                    orig = state[\"widgets\"][state[\"selected\"]]\n                    w2   = copy.deepcopy(orig)\n                    wtype = w2[\"type\"]\n                    c = state[\"counter\"]\n                    c[wtype] = c.get(wtype, 0) + 1\n                    w2[\"id\"]  = wtype.lower() + str(c[wtype])\n                    w2[\"var\"] = w2[\"id\"]\n                    state[\"widgets\"].append(w2)\n                    state[\"selected\"] = len(state[\"widgets\"]) - 1\n                    set_msg(f\"Copied -> {w2['id']}\")\n\n            # MOVE up/down in list\n            elif k in (ord('m'), ord('M')):\n                opts = [\"Move Up\", \"Move Down\", \"Move to Top\", \"Move to Bottom\"]\n                mv = menu_popup(stdscr, \"Move Widget\", opts)\n                i  = state[\"selected\"]\n                ws = state[\"widgets\"]\n                if mv == 0 and i > 0:\n                    ws[i], ws[i-1] = ws[i-1], ws[i]; state[\"selected\"] -= 1\n                elif mv == 1 and i < len(ws)-1:\n                    ws[i], ws[i+1] = ws[i+1], ws[i]; state[\"selected\"] += 1\n                elif mv == 2:\n                    ws.insert(0, ws.pop(i)); state[\"selected\"] = 0\n                elif mv == 3:\n                    ws.append(ws.pop(i)); state[\"selected\"] = len(ws)-1\n                set_msg(\"Moved.\")\n\n            # APP CONFIG\n            elif k in (ord('g'), ord('G')):\n                opts = [\n                    f\"App title      = {state['app_title']}\",\n                    f\"Window width   = {state['win_width']}\",\n                    f\"Window height  = {state['win_height']}\",\n                    f\"Window bg      = {state['win_bg']}\",\n                    f\"Resizable      = {state['win_resizable']}\",\n                    f\"Win icon path  = {state['win_icon']}\",\n                    f\"TTK theme      = {state['theme']}\",\n                    f\"Menu bar       = {state['menu_enabled']}\",\n                    f\"Status bar     = {state['statusbar']}\",\n                    \"[Done]\",\n                ]\n                cfg_keys = [\"app_title\",\"win_width\",\"win_height\",\"win_bg\",\"win_resizable\",\"win_icon\",\"theme\",\"menu_enabled\",\"statusbar\"]\n                while True:\n                    opts = [\n                        f\"App title      = {state['app_title']}\",\n                        f\"Window width   = {state['win_width']}\",\n                        f\"Window height  = {state['win_height']}\",\n                        f\"Window bg      = {state['win_bg']}\",\n                        f\"Resizable      = {state['win_resizable']}\",\n                        f\"Win icon path  = {state['win_icon']}\",\n                        f\"TTK theme      = {state['theme']}\",\n                        f\"Menu bar       = {state['menu_enabled']}\",\n                        f\"Status bar     = {state['statusbar']}\",\n                        \"[Done]\",\n                    ]\n                    csel = menu_popup(stdscr, \"App Config\", opts)\n                    if csel < 0 or csel >= len(cfg_keys): break\n                    key = cfg_keys[csel]\n                    if key == \"theme\":\n                        themes = [\"default\",\"clam\",\"alt\",\"classic\"]\n                        ts = menu_popup(stdscr, \"TTK Theme\", themes)\n                        if ts >= 0: state[key] = themes[ts]\n                    elif key in (\"win_resizable\",\"menu_enabled\",\"statusbar\"):\n                        tv = menu_popup(stdscr, key, [\"0 (No)\",\"1 (Yes)\"])\n                        if tv == 0: state[key] = \"0\"\n                        elif tv == 1: state[key] = \"1\"\n                    else:\n                        val = prompt(stdscr, key, state[key])\n                        state[key] = val\n                set_msg(\"App config updated.\")\n\n            # EXPORT\n            elif k in (ord('x'), ord('X')):\n                code = generate_code()\n                fname = prompt(stdscr, \"Export filename\", \"app.py\")\n                if not fname.endswith(\".py\"):\n                    fname += \".py\"\n                try:\n                    with open(fname, \"w\") as f:\n                        f.write(code)\n                    set_msg(f\"Exported to {fname}  ({len(code)} chars, {len(state['widgets'])} widgets)\")\n                except Exception as ex:\n                    set_msg(f\"Export failed: {ex}\", False)\n\n            # PREVIEW code\n            elif k in (ord('p'), ord('P')):\n                code = generate_code()\n                lines = code.split(\"\\n\")\n                sh2, sw2 = stdscr.getmaxyx()\n                view_h = sh2 - 4\n                offset = [0]\n                stdscr.nodelay(False)\n                while True:\n                    stdscr.erase()\n                    try: stdscr.addstr(0, 0, \" CODE PREVIEW -- ^v scroll, Q=close \".center(sw2-1), P_TITLE)\n                    except: pass\n                    for i in range(view_h):\n                        li = offset[0] + i\n                        if li < len(lines):\n                            try: stdscr.addstr(i+1, 0, lines[li][:sw2-1], P_NORM)\n                            except: pass\n                    try: stdscr.addstr(sh2-2, 0, f\" Line {offset[0]+1}/{len(lines)} \".ljust(sw2-1), P_YEL)\n                    except: pass\n                    stdscr.refresh()\n                    pk = stdscr.getch()\n                    if pk in (curses.KEY_DOWN, ord('j')): offset[0] = min(offset[0]+1, max(0,len(lines)-view_h))\n                    elif pk in (curses.KEY_UP,   ord('k')): offset[0] = max(0, offset[0]-1)\n                    elif pk in (ord('q'), ord('Q'), 27): break\n                stdscr.nodelay(True)\n\n            # SAVE project\n            elif k in (ord('s'), ord('S')):\n                fname = prompt(stdscr, \"Save project as\", \"project.tkb\")\n                try:\n                    blob = json.dumps({\"state\": state}, indent=2)\n                    with open(fname, \"w\") as f:\n                        f.write(blob)\n                    set_msg(f\"Saved -> {fname}\")\n                except Exception as ex:\n                    set_msg(f\"Save failed: {ex}\", False)\n\n            # LOAD project\n            elif k in (ord('l'), ord('L')):\n                fname = prompt(stdscr, \"Load project file\", \"project.tkb\")\n                try:\n                    with open(fname) as f:\n                        blob = json.load(f)\n                    loaded = blob.get(\"state\", {})\n                    state.update(loaded)\n                    set_msg(f\"Loaded {fname}  ({len(state['widgets'])} widgets)\")\n                except Exception as ex:\n                    set_msg(f\"Load failed: {ex}\", False)\n\n            # HELP\n            elif k in (ord('?'), ord('h'), ord('H')):\n                info_popup(stdscr, [\n                    \"A         Add widget (pick from full catalogue)\",\n                    \"E         Edit selected widget props & layout\",\n                    \"D         Delete selected widget\",\n                    \"C         Copy/duplicate selected widget\",\n                    \"M         Move widget in order\",\n                    \"G         App / window global config\",\n                    \"X         Export as working .py script\",\n                    \"P         Preview generated code\",\n                    \"S         Save project (.tkb)\",\n                    \"L         Load project (.tkb)\",\n                    \"^/v j/k   Navigate widget list\",\n                    \"Q         Quit\",\n                    \"\",\n                    \"Widgets available:\",\n                    \"Button Label Entry Text Frame LabelFrame\",\n                    \"Checkbutton Radiobutton Scale Scrollbar Listbox\",\n                    \"Combobox Spinbox OptionMenu Canvas Message\",\n                    \"PanedWindow Notebook Treeview ProgressBar\",\n                    \"Separator Sizegrip MenuButton\",\n                ], title=\"HELP\")\n\n            # QUIT\n            elif k in (ord('q'), ord('Q')):\n                if confirm_popup(stdscr, \"Quit TkBuilder?\"):\n                    break\n\n    curses.wrapper(run)\n\n_tkbuilder()\n"
        }
    ]
}