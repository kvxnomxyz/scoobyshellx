{
    "name": "ARENA.EXE \u2014 Open World Multiplayer",
    "author": "kvxnom (Game design), Claude (Code)",
    "version": "2.1_FEATURES",
    "description": "MS-DOS style open world arena. Explore procedural maps, fight enemies, loot chests. Difficulty levels (save/load .a2sf), shop (U), pickaxe to mine trees. First to kill goal wins. curses-based, paste.rs sync. Command: arena2",
    "commands": [
        {
            "name": "arena2",
            "description": "Launch ARENA.EXE Open World Multiplayer",
            "action": "python",
            "value": "def _game():\n    import curses, random, json, threading, urllib.request, time, os, pathlib\n\n    # \u2500\u2500 difficulty presets & save file \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    SAVE_FILE = pathlib.Path.home() / \".arena2.a2sf\"\n    DIFFICULTIES = {\n        \"EASY\":   {\"kill_goal\": 10, \"enemy_count\": 20, \"chest_count\": 18, \"hp_mul\": 1.2, \"gold_mul\": 1.5},\n        \"NORMAL\": {\"kill_goal\": 20, \"enemy_count\": 35, \"chest_count\": 14, \"hp_mul\": 1.0, \"gold_mul\": 1.0},\n        \"HARD\":   {\"kill_goal\": 30, \"enemy_count\": 50, \"chest_count\": 10, \"hp_mul\": 0.8, \"gold_mul\": 0.8},\n        \"INSANE\": {\"kill_goal\": 50, \"enemy_count\": 70, \"chest_count\": 8,  \"hp_mul\": 0.6, \"gold_mul\": 0.6},\n    }\n\n    def save_settings(settings):\n        try: SAVE_FILE.write_text(json.dumps(settings))\n        except Exception: pass\n\n    def load_settings():\n        try: return json.loads(SAVE_FILE.read_text())\n        except Exception: return {\"difficulty\": \"NORMAL\", \"kill_goal\": 20}\n\n    # \u2500\u2500 paste.rs sync \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    PASTE_BASE = \"https://paste.rs/\"\n    _my_key    = [None]\n    _opp_state = {}\n    _opp_lock  = threading.Lock()\n    _stop_poll = threading.Event()\n\n    def pb_post(content):\n        try:\n            req = urllib.request.Request(\n                PASTE_BASE, data=content.encode(), method=\"POST\",\n                headers={\"Content-Type\": \"text/plain; charset=utf-8\"},\n            )\n            with urllib.request.urlopen(req, timeout=8) as r:\n                url = r.read().decode().strip()\n            if url.startswith(PASTE_BASE):\n                return url[len(PASTE_BASE):]\n        except Exception:\n            pass\n        return None\n\n    def pb_get(key):\n        try:\n            req = urllib.request.Request(PASTE_BASE + key, headers={\"User-Agent\": \"arena2/1.0\"})\n            with urllib.request.urlopen(req, timeout=8) as r:\n                return r.read().decode()\n        except Exception:\n            return None\n\n    def pb_delete(key):\n        if not key: return\n        try:\n            req = urllib.request.Request(PASTE_BASE + key, method=\"DELETE\")\n            with urllib.request.urlopen(req, timeout=8) as r: r.read()\n        except Exception:\n            pass\n\n    def push_state(p):\n        blob = {\n            \"name\": p[\"name\"], \"hp\": p[\"hp\"], \"max_hp\": p[\"max_hp\"],\n            \"atk\": p[\"atk\"], \"def_\": p[\"def_\"], \"kills\": p[\"kills\"],\n            \"gold\": p[\"gold\"], \"level\": p[\"level\"],\n            \"dead\": p.get(\"dead\", False), \"won\": p.get(\"won\", False),\n        }\n        old = _my_key[0]\n        key = pb_post(json.dumps(blob))\n        if key:\n            if old and old != key:\n                threading.Thread(target=pb_delete, args=(old,), daemon=True).start()\n            _my_key[0] = key\n        return key\n\n    def poll_opponents(opp_keys):\n        while not _stop_poll.is_set():\n            for nm, key in list(opp_keys.items()):\n                raw = pb_get(key)\n                if raw:\n                    try:\n                        with _opp_lock:\n                            _opp_state[nm] = json.loads(raw)\n                    except Exception:\n                        pass\n            _stop_poll.wait(15)\n\n    def parse_opp_keys(raw):\n        out = {}\n        for part in raw.split(\",\"):\n            part = part.strip()\n            if \"|\" in part:\n                nm, k = part.split(\"|\", 1)\n                out[nm.strip()] = k.strip()\n            elif part:\n                out[\"P_\" + part[:6]] = part\n        return out\n\n    # \u2500\u2500 MAP GENERATION \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    MAP_W = 80\n    MAP_H = 40\n\n    TILE_FLOOR  = \".\"\n    TILE_WALL   = \"#\"\n    TILE_TREE   = \"T\"\n    TILE_WATER  = \"~\"\n    TILE_GRASS  = \",\"\n\n    def gen_map():\n        grid = [[TILE_WALL] * MAP_W for _ in range(MAP_H)]\n\n        # carve rooms\n        rooms = []\n        for _ in range(22):\n            w = random.randint(5, 12)\n            h = random.randint(4, 8)\n            x = random.randint(1, MAP_W - w - 1)\n            y = random.randint(1, MAP_H - h - 1)\n            # check overlap (loose)\n            overlap = False\n            for rx, ry, rw, rh in rooms:\n                if x < rx+rw+2 and x+w+2 > rx and y < ry+rh+2 and y+h+2 > ry:\n                    overlap = True; break\n            if overlap: continue\n            rooms.append((x, y, w, h))\n            for dy in range(h):\n                for dx in range(w):\n                    grid[y+dy][x+dx] = TILE_FLOOR\n\n        # connect rooms with corridors\n        random.shuffle(rooms)\n        for i in range(len(rooms)-1):\n            x1 = rooms[i][0]   + rooms[i][2]   // 2\n            y1 = rooms[i][1]   + rooms[i][3]   // 2\n            x2 = rooms[i+1][0] + rooms[i+1][2] // 2\n            y2 = rooms[i+1][1] + rooms[i+1][3] // 2\n            # horizontal then vertical\n            cx, cy = x1, y1\n            while cx != x2:\n                grid[cy][cx] = TILE_FLOOR\n                cx += 1 if cx < x2 else -1\n            while cy != y2:\n                grid[cy][cx] = TILE_FLOOR\n                cy += 1 if cy < y2 else -1\n\n        # scatter grass and trees in floor areas\n        for y in range(MAP_H):\n            for x in range(MAP_W):\n                if grid[y][x] == TILE_FLOOR and random.random() < 0.06:\n                    grid[y][x] = TILE_GRASS\n                elif grid[y][x] == TILE_WALL and random.random() < 0.03:\n                    # small chance wall becomes tree (purely cosmetic, still blocking)\n                    grid[y][x] = TILE_TREE\n\n        return grid, rooms\n\n    # \u2500\u2500 ENTITIES \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    ENEMY_TEMPLATES = [\n        {\"name\": \"RAT\",      \"ch\": \"r\", \"hp\": 10, \"atk\": 3, \"def_\": 0, \"xp\": 6,  \"gold\": 3,  \"tier\": 0},\n        {\"name\": \"GOBLIN\",   \"ch\": \"g\", \"hp\": 16, \"atk\": 5, \"def_\": 0, \"xp\": 10, \"gold\": 6,  \"tier\": 0},\n        {\"name\": \"SKELETON\", \"ch\": \"s\", \"hp\": 20, \"atk\": 6, \"def_\": 1, \"xp\": 14, \"gold\": 8,  \"tier\": 1},\n        {\"name\": \"ORC\",      \"ch\": \"o\", \"hp\": 30, \"atk\": 8, \"def_\": 2, \"xp\": 22, \"gold\": 14, \"tier\": 1},\n        {\"name\": \"MAGE\",     \"ch\": \"m\", \"hp\": 24, \"atk\":11, \"def_\": 1, \"xp\": 28, \"gold\": 18, \"tier\": 2},\n        {\"name\": \"VAMPIRE\",  \"ch\": \"v\", \"hp\": 40, \"atk\":12, \"def_\": 3, \"xp\": 40, \"gold\": 26, \"tier\": 2},\n        {\"name\": \"GOLEM\",    \"ch\": \"G\", \"hp\": 55, \"atk\":10, \"def_\": 5, \"xp\": 50, \"gold\": 35, \"tier\": 3},\n        {\"name\": \"LICH\",     \"ch\": \"L\", \"hp\": 60, \"atk\":16, \"def_\": 4, \"xp\": 80, \"gold\": 60, \"tier\": 3},\n        {\"name\": \"DRAGON\",   \"ch\": \"D\", \"hp\": 90, \"atk\":20, \"def_\": 6, \"xp\":150, \"gold\":100, \"tier\": 4},\n    ]\n\n    ITEMS_POOL = [\n        {\"name\": \"HEALTH VIAL\",   \"type\": \"heal\",   \"val\": 20, \"price\": 18},\n        {\"name\": \"MEGA POTION\",   \"type\": \"heal\",   \"val\": 45, \"price\": 38},\n        {\"name\": \"IRON SWORD\",    \"type\": \"weapon\", \"val\": 5,  \"price\": 30},\n        {\"name\": \"STEEL BLADE\",   \"type\": \"weapon\", \"val\": 10, \"price\": 55},\n        {\"name\": \"LEATHER VEST\",  \"type\": \"armor\",  \"val\": 3,  \"price\": 28},\n        {\"name\": \"CHAIN MAIL\",    \"type\": \"armor\",  \"val\": 6,  \"price\": 52},\n        {\"name\": \"BOMB\",          \"type\": \"bomb\",   \"val\": 35, \"price\": 22},\n        {\"name\": \"RAGE DRAUGHT\",  \"type\": \"rage\",   \"val\": 3,  \"price\": 28},\n        {\"name\": \"ANTIDOTE\",      \"type\": \"cure\",   \"val\": 1,  \"price\": 12},\n        {\"name\": \"PICKAXE\",       \"type\": \"pickaxe\",\"val\": 1,  \"price\": 0},\n    ]\n\n    def spawn_entities(grid, rooms, count_enemies=35, count_chests=14):\n        entities = []\n        used = set()\n\n        def rand_floor():\n            for _ in range(400):\n                r = random.choice(rooms)\n                x = random.randint(r[0]+1, r[0]+r[2]-2)\n                y = random.randint(r[1]+1, r[1]+r[3]-2)\n                if grid[y][x] == TILE_FLOOR and (x,y) not in used:\n                    used.add((x,y))\n                    return x, y\n            return None, None\n\n        for _ in range(count_enemies):\n            x, y = rand_floor()\n            if x is None: continue\n            t = random.choice(ENEMY_TEMPLATES)\n            e = dict(t)\n            e[\"x\"] = x; e[\"y\"] = y\n            e[\"max_hp\"] = e[\"hp\"]\n            e[\"alive\"] = True\n            e[\"move_cd\"] = 0\n            entities.append((\"enemy\", e))\n\n        for _ in range(count_chests):\n            x, y = rand_floor()\n            if x is None: continue\n            gold = random.randint(10, 60)\n            item = random.choice(ITEMS_POOL) if random.random() < 0.6 else None\n            entities.append((\"chest\", {\"x\": x, \"y\": y, \"gold\": gold, \"item\": item, \"open\": False}))\n\n        return entities\n\n    # \u2500\u2500 PLAYER \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    def make_player(name, sx, sy):\n        return {\n            \"name\":    name,\n            \"x\": sx,   \"y\": sy,\n            \"hp\":      60, \"max_hp\": 60,\n            \"atk\":     8,  \"def_\":   2,\n            \"gold\":    20,\n            \"xp\":      0,  \"xp_next\": 50,\n            \"level\":   1,\n            \"kills\":   0,\n            \"inv\":     [],\n            \"weapon\":  None,\n            \"armor\":   None,\n            \"poison\":  0,\n            \"rage\":    0,\n            \"dead\":    False,\n            \"won\":     False,\n            \"msg\":     \"\",   # status message line\n            \"pickaxe\": True,   # everyone starts with a pickaxe\n        }\n\n    def lvl_up(p):\n        gained = False\n        while p[\"xp\"] >= p[\"xp_next\"]:\n            p[\"level\"]  += 1\n            p[\"xp\"]     -= p[\"xp_next\"]\n            p[\"xp_next\"] = int(p[\"xp_next\"] * 1.6)\n            p[\"max_hp\"] += 10\n            p[\"hp\"]      = min(p[\"hp\"] + 10, p[\"max_hp\"])\n            p[\"atk\"]    += 2\n            gained = True\n        if gained:\n            p[\"msg\"] = \"*** LEVEL UP! Lv\" + str(p[\"level\"]) + \" HP+10 ATK+2 ***\"\n\n    # \u2500\u2500 SHOP \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    SHOP_STOCK = [\n        {\"name\": \"HEALTH VIAL\",  \"type\": \"heal\",    \"val\": 20, \"price\": 18},\n        {\"name\": \"MEGA POTION\",  \"type\": \"heal\",    \"val\": 45, \"price\": 38},\n        {\"name\": \"IRON SWORD\",   \"type\": \"weapon\",  \"val\": 5,  \"price\": 30},\n        {\"name\": \"STEEL BLADE\",  \"type\": \"weapon\",  \"val\": 10, \"price\": 55},\n        {\"name\": \"SHADOW BLADE\", \"type\": \"weapon\",  \"val\": 18, \"price\": 90},\n        {\"name\": \"LEATHER VEST\", \"type\": \"armor\",   \"val\": 3,  \"price\": 28},\n        {\"name\": \"CHAIN MAIL\",   \"type\": \"armor\",   \"val\": 6,  \"price\": 52},\n        {\"name\": \"PLATE ARMOR\",  \"type\": \"armor\",   \"val\": 12, \"price\": 95},\n        {\"name\": \"BOMB\",         \"type\": \"bomb\",    \"val\": 35, \"price\": 22},\n        {\"name\": \"RAGE DRAUGHT\", \"type\": \"rage\",    \"val\": 3,  \"price\": 28},\n        {\"name\": \"ANTIDOTE\",     \"type\": \"cure\",    \"val\": 1,  \"price\": 12},\n        {\"name\": \"PICKAXE\",      \"type\": \"pickaxe\", \"val\": 1,  \"price\": 40},\n    ]\n\n    # \u2500\u2500 CURSES MAIN \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    def run_curses(stdscr, p, grid, entities, kill_goal, opp_keys):\n        curses.curs_set(0)\n        stdscr.nodelay(True)\n        stdscr.keypad(True)\n\n        # colour pairs\n        curses.start_color()\n        curses.use_default_colors()\n        C_NORMAL  = 0\n        curses.init_pair(1,  curses.COLOR_WHITE,   -1)   # wall/normal\n        curses.init_pair(2,  curses.COLOR_GREEN,   -1)   # floor/grass\n        curses.init_pair(3,  curses.COLOR_CYAN,    -1)   # player\n        curses.init_pair(4,  curses.COLOR_RED,     -1)   # enemy\n        curses.init_pair(5,  curses.COLOR_YELLOW,  -1)   # chest/gold\n        curses.init_pair(6,  curses.COLOR_MAGENTA, -1)   # hud border\n        curses.init_pair(7,  curses.COLOR_BLUE,    -1)   # water/info\n        curses.init_pair(8,  curses.COLOR_WHITE,   curses.COLOR_RED)    # danger\n        curses.init_pair(9,  curses.COLOR_BLACK,   curses.COLOR_YELLOW) # msg\n        curses.init_pair(10, curses.COLOR_WHITE,   curses.COLOR_BLUE)   # title bar\n\n        P_WHITE  = curses.color_pair(1)\n        P_GREEN  = curses.color_pair(2)\n        P_CYAN   = curses.color_pair(3)\n        P_RED    = curses.color_pair(4)\n        P_YELLOW = curses.color_pair(5)\n        P_MAG    = curses.color_pair(6)\n        P_BLUE   = curses.color_pair(7)\n        P_DANGER = curses.color_pair(8)\n        P_MSG    = curses.color_pair(9)\n        P_TITLE  = curses.color_pair(10)\n\n        TILE_COLOR = {\n            TILE_FLOOR: P_GREEN  | curses.A_DIM,\n            TILE_GRASS: P_GREEN,\n            TILE_WALL:  P_WHITE  | curses.A_DIM,\n            TILE_TREE:  P_GREEN  | curses.A_BOLD,\n            TILE_WATER: P_BLUE,\n        }\n\n        # viewport\n        scr_h, scr_w = stdscr.getmaxyx()\n        VIEW_H = scr_h - 7   # bottom HUD rows\n        VIEW_W = scr_w - 22  # right panel cols\n\n        cam_x = p[\"x\"] - VIEW_W // 2\n        cam_y = p[\"y\"] - VIEW_H // 2\n\n        # entity index for fast lookup\n        def build_pos_map():\n            pm = {}\n            for idx, (kind, e) in enumerate(entities):\n                if kind == \"enemy\" and e[\"alive\"]:\n                    pm[(e[\"x\"], e[\"y\"])] = idx\n                elif kind == \"chest\" and not e[\"open\"]:\n                    pm[(e[\"x\"], e[\"y\"])] = idx\n            return pm\n\n        # \u2500\u2500 popup helper \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        def popup(lines, title=\"\", col=P_WHITE):\n            max_w = max((len(l) for l in lines), default=10) + 4\n            max_w = max(max_w, len(title) + 4)\n            ph = len(lines) + 4\n            py = (scr_h - ph) // 2\n            px = (scr_w - max_w) // 2\n            # draw box\n            stdscr.attron(col | curses.A_BOLD)\n            stdscr.addstr(py, px, \"+\" + \"-\" * (max_w-2) + \"+\")\n            if title:\n                stdscr.addstr(py, px + (max_w - len(title)) // 2, title)\n            stdscr.attroff(col | curses.A_BOLD)\n            for i, line in enumerate(lines):\n                stdscr.addstr(py+1+i, px, \"| \")\n                stdscr.addstr(line[:max_w-4])\n                stdscr.addstr(\" \" * max(0, max_w-4-len(line)) + \" |\")\n            stdscr.attron(col | curses.A_BOLD)\n            stdscr.addstr(py+1+len(lines), px, \"+\" + \"-\" * (max_w-2) + \"+\")\n            stdscr.addstr(py+2+len(lines), px, \"| \" + \"[ ENTER ]\".center(max_w-4) + \" |\")\n            stdscr.addstr(py+3+len(lines), px, \"+\" + \"-\" * (max_w-2) + \"+\")\n            stdscr.attroff(col | curses.A_BOLD)\n            stdscr.refresh()\n            stdscr.nodelay(False)\n            while True:\n                k = stdscr.getch()\n                if k in (10, 13, ord(' ')):\n                    break\n            stdscr.nodelay(True)\n\n        def menu_popup(title, options, col=P_WHITE):\n            \"\"\"returns index of chosen option, or -1 for cancel\"\"\"\n            max_w = max((len(o) for o in options), default=10) + 6\n            max_w = max(max_w, len(title) + 4, 24)\n            ph = len(options) + 4\n            py = (scr_h - ph) // 2\n            px = (scr_w - max_w) // 2\n            sel = 0\n            stdscr.nodelay(False)\n            while True:\n                stdscr.attron(col | curses.A_BOLD)\n                stdscr.addstr(py, px, \"+\" + \"-\" * (max_w-2) + \"+\")\n                stdscr.addstr(py, px + (max_w - len(title)) // 2, title)\n                stdscr.attroff(col | curses.A_BOLD)\n                for i, opt in enumerate(options):\n                    row = py + 1 + i\n                    if i == sel:\n                        stdscr.attron(col | curses.A_REVERSE)\n                    stdscr.addstr(row, px, \"| \")\n                    stdscr.addstr((\" > \" + opt).ljust(max_w-4))\n                    stdscr.addstr(\" |\")\n                    if i == sel:\n                        stdscr.attroff(col | curses.A_REVERSE)\n                stdscr.attron(col | curses.A_BOLD)\n                stdscr.addstr(py+1+len(options), px, \"+\" + \"-\" * (max_w-2) + \"+\")\n                stdscr.addstr(py+2+len(options), px, \"| \" + \"ESC=cancel\".center(max_w-4) + \" |\")\n                stdscr.addstr(py+3+len(options), px, \"+\" + \"-\" * (max_w-2) + \"+\")\n                stdscr.attroff(col | curses.A_BOLD)\n                stdscr.refresh()\n                k = stdscr.getch()\n                if k in (curses.KEY_UP, ord('w'), ord('W')):\n                    sel = (sel - 1) % len(options)\n                elif k in (curses.KEY_DOWN, ord('s'), ord('S')):\n                    sel = (sel + 1) % len(options)\n                elif k in (10, 13):\n                    stdscr.nodelay(True)\n                    return sel\n                elif k == 27:\n                    stdscr.nodelay(True)\n                    return -1\n\n        # \u2500\u2500 combat popup \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        def do_combat(enemy):\n            e = dict(enemy)\n            e[\"max_hp_orig\"] = e[\"hp\"]\n            log = [\"You encounter \" + e[\"name\"] + \"!\",\n                   \"HP:\" + str(e[\"hp\"]) + \" ATK:\" + str(e[\"atk\"]) + \" DEF:\" + str(e[\"def_\"])]\n\n            stdscr.nodelay(False)\n            while e[\"hp\"] > 0 and p[\"hp\"] > 0:\n                stdscr.clear()\n                # enemy bar\n                ebar = int(e[\"hp\"] / e[\"max_hp_orig\"] * 16)\n                pbar = int(p[\"hp\"] / p[\"max_hp\"] * 16)\n                hp_ind = P_RED if p[\"hp\"] < p[\"max_hp\"]//4 else (P_YELLOW if p[\"hp\"] < p[\"max_hp\"]//2 else P_GREEN)\n\n                lines_top = [\n                    \" \" + (\"=\" * 40),\n                    \"  COMBAT: \" + e[\"name\"],\n                    \" \" + (\"=\" * 40),\n                    \"  Enemy  HP [\" + \"#\"*ebar + \"-\"*(16-ebar) + \"] \" + str(e[\"hp\"]) + \"/\" + str(e[\"max_hp_orig\"]),\n                    \"  You    HP [\" + \"#\"*pbar + \"-\"*(16-pbar) + \"] \" + str(p[\"hp\"]) + \"/\" + str(p[\"max_hp\"]),\n                    \" \" + (\"-\" * 40),\n                ]\n                for i, l in enumerate(lines_top):\n                    stdscr.attron(P_RED | curses.A_BOLD)\n                    try: stdscr.addstr(i, 0, l[:scr_w-1])\n                    except: pass\n                    stdscr.attroff(P_RED | curses.A_BOLD)\n\n                # log (last 8 lines)\n                for i, l in enumerate(log[-8:]):\n                    try: stdscr.addstr(len(lines_top)+i, 2, l[:scr_w-3])\n                    except: pass\n\n                # actions\n                action_row = len(lines_top) + 9\n                actions = [\n                    (\"A\", \"Attack\"),\n                    (\"B\", \"Bomb\"),\n                    (\"I\", \"Use item\"),\n                    (\"R\", \"Try flee\"),\n                ]\n                try:\n                    stdscr.attron(P_YELLOW | curses.A_BOLD)\n                    stdscr.addstr(action_row, 2, \"[ A ]Attack  [ B ]Bomb  [ I ]Item  [ R ]Flee\")\n                    stdscr.attroff(P_YELLOW | curses.A_BOLD)\n                except: pass\n                stdscr.refresh()\n\n                k = stdscr.getch()\n                ch = chr(k).lower() if 0 <= k < 256 else \"\"\n\n                if ch == \"a\":\n                    rage_mul = 1.5 if p[\"rage\"] > 0 else 1.0\n                    if p[\"rage\"] > 0: p[\"rage\"] -= 1\n                    raw = max(1, int((p[\"atk\"] + random.randint(-1,3)) * rage_mul))\n                    crit = random.random() < 0.1\n                    if crit: raw = int(raw * 2)\n                    dmg = max(0, raw - e[\"def_\"])\n                    e[\"hp\"] -= dmg\n                    msg = (\"CRIT! \" if crit else \"\") + str(dmg) + \" dmg to \" + e[\"name\"]\n                    if rage_mul > 1: msg += \" (ENRAGED)\"\n                    log.append(\"> \" + msg)\n                elif ch == \"b\":\n                    bombs = [x for x in p[\"inv\"] if x[\"type\"] == \"bomb\"]\n                    if bombs:\n                        b = bombs[0]; p[\"inv\"].remove(b)\n                        dmg = max(0, b[\"val\"] - e[\"def_\"]//2)\n                        e[\"hp\"] -= dmg\n                        log.append(\"> BOMB! \" + str(dmg) + \" dmg!\")\n                    else:\n                        log.append(\"> No bombs.\")\n                        continue\n                elif ch == \"i\":\n                    usable = [x for x in p[\"inv\"] if x[\"type\"] in (\"heal\",\"rage\",\"cure\")]\n                    if not usable:\n                        log.append(\"> No usable items.\"); continue\n                    opts = [x[\"name\"] + \" (\" + x[\"type\"] + \")\" for x in usable]\n                    sel = menu_popup(\"[ USE ITEM ]\", opts, col=P_CYAN)\n                    if sel < 0: continue\n                    it = usable[sel]; p[\"inv\"].remove(it)\n                    if it[\"type\"] == \"heal\":\n                        g = min(it[\"val\"], p[\"max_hp\"]-p[\"hp\"])\n                        p[\"hp\"] += g; log.append(\"> Healed \" + str(g) + \" HP.\")\n                    elif it[\"type\"] == \"rage\":\n                        p[\"rage\"] = it[\"val\"]; log.append(\"> ENRAGED x\" + str(it[\"val\"]) + \"!\")\n                    elif it[\"type\"] == \"cure\":\n                        p[\"poison\"] = 0; log.append(\"> Poison cured!\")\n                elif ch == \"r\":\n                    if random.random() < 0.4:\n                        log.append(\"> Escaped!\")\n                        stdscr.nodelay(True)\n                        return \"fled\"\n                    else:\n                        log.append(\"> Escape failed!\")\n                else:\n                    continue\n\n                # regen\n                if p.get(\"regen_t\", 0) > 0:\n                    h = min(5, p[\"max_hp\"]-p[\"hp\"]); p[\"hp\"] += h; p[\"regen_t\"] -= 1\n                    if h: log.append(\"  Regen +\" + str(h) + \" HP.\")\n\n                # poison\n                if p[\"poison\"] > 0:\n                    p[\"hp\"] -= 3; p[\"poison\"] -= 1\n                    log.append(\"  Poison -3 HP.\")\n\n                # enemy attacks back\n                if e[\"hp\"] > 0:\n                    edm = max(0, e[\"atk\"] - p[\"def_\"] + random.randint(-2,2))\n                    p[\"hp\"] -= edm\n                    log.append(\"  \" + e[\"name\"] + \" hits for \" + str(edm) + \".\")\n                    if random.random() < 0.12:\n                        p[\"poison\"] = max(p.get(\"poison\",0), 2)\n                        log.append(\"  You are POISONED!\")\n\n            stdscr.nodelay(True)\n            if p[\"hp\"] <= 0:\n                return \"dead\"\n            return \"won\"\n\n        # \u2500\u2500 chest popup \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        def do_chest(chest):\n            chest[\"open\"] = True\n            lines = [\"You open the chest!\",\n                     \"Gold: +\" + str(chest[\"gold\"])]\n            p[\"gold\"] += chest[\"gold\"]\n            if chest[\"item\"]:\n                p[\"inv\"].append(dict(chest[\"item\"]))\n                lines.append(\"Found: \" + chest[\"item\"][\"name\"])\n            else:\n                lines.append(\"(nothing else inside)\")\n            popup(lines, title=\"[ CHEST ]\", col=P_YELLOW)\n\n        # \u2500\u2500 inventory/equip screen \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        def do_inventory():\n            if not p[\"inv\"]:\n                popup([\"Your inventory is empty.\"], title=\"[ INVENTORY ]\")\n                return\n            while True:\n                opts = []\n                for it in p[\"inv\"]:\n                    eq = \"\"\n                    if p[\"weapon\"] and p[\"weapon\"].get(\"name\") == it.get(\"name\") and it[\"type\"]==\"weapon\": eq=\" [EQP]\"\n                    if p[\"armor\"]  and p[\"armor\"].get(\"name\")  == it.get(\"name\") and it[\"type\"]==\"armor\":  eq=\" [EQP]\"\n                    opts.append(it[\"name\"] + \" (\" + it[\"type\"] + \")\" + eq)\n                opts.append(\"-- Close --\")\n                sel = menu_popup(\"[ INVENTORY ]\", opts, col=P_YELLOW)\n                if sel < 0 or sel == len(p[\"inv\"]):\n                    break\n                it = p[\"inv\"][sel]\n                if it[\"type\"] == \"weapon\":\n                    p[\"weapon\"] = it\n                    p[\"atk\"]    = 8 + (p[\"level\"]-1)*2 + it[\"val\"]\n                    p[\"msg\"]    = \"Equipped \" + it[\"name\"]\n                elif it[\"type\"] == \"armor\":\n                    p[\"armor\"] = it\n                    p[\"def_\"]  = 2 + it[\"val\"]\n                    p[\"msg\"]   = \"Equipped \" + it[\"name\"]\n                elif it[\"type\"] == \"heal\":\n                    g = min(it[\"val\"], p[\"max_hp\"]-p[\"hp\"])\n                    p[\"hp\"] += g; p[\"inv\"].remove(it)\n                    p[\"msg\"] = \"Used \" + it[\"name\"] + \": +\" + str(g) + \" HP\"\n                    break\n                elif it[\"type\"] == \"cure\":\n                    p[\"poison\"] = 0; p[\"inv\"].remove(it)\n                    p[\"msg\"] = \"Cured poison!\"\n                    break\n                elif it[\"type\"] == \"rage\":\n                    p[\"rage\"] = it[\"val\"]; p[\"inv\"].remove(it)\n                    p[\"msg\"] = \"ENRAGED for \" + str(it[\"val\"]) + \" turns!\"\n                    break\n                else:\n                    popup([\"Can't use \" + it[\"name\"] + \" here.\"])\n\n        # \u2500\u2500 scoreboard popup \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        def do_scoreboard(kill_goal):\n            lines = [\"YOU: \" + p[\"name\"] + \" Lv\" + str(p[\"level\"]),\n                     \"  HP:\" + str(p[\"hp\"]) + \"/\" + str(p[\"max_hp\"]) +\n                     \"  Kills:\" + str(p[\"kills\"]) + \"/\" + str(kill_goal),\n                     \"\"]\n            with _opp_lock:\n                snap = dict(_opp_state)\n            if snap:\n                for nm, st in snap.items():\n                    status = \"WON\" if st.get(\"won\") else (\"DEAD\" if st.get(\"dead\") else\n                             \"K:\" + str(st.get(\"kills\",\"?\")) + \"/\" + str(kill_goal))\n                    lines.append(nm + \" Lv\" + str(st.get(\"level\",\"?\")) + \" - \" + status)\n            else:\n                lines.append(\"(no opponents synced)\")\n            lines += [\"\", \"Kill goal: \" + str(kill_goal)]\n            if _my_key[0]:\n                lines.append(\"Your key: paste.rs/\" + _my_key[0])\n            popup(lines, title=\"[ SCOREBOARD ]\", col=P_CYAN)\n\n        # \u2500\u2500 SHOP popup \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        def do_shop():\n            while True:\n                opts = []\n                for it in SHOP_STOCK:\n                    owned = sum(1 for x in p[\"inv\"] if x[\"name\"] == it[\"name\"])\n                    opts.append(it[\"name\"] + \" (\" + it[\"type\"] + \")  \" + str(it[\"price\"]) + \"g\" + (\" [x\"+str(owned)+\"]\" if owned else \"\"))\n                opts.append(\"-- Leave Shop --\")\n                title = \"[ SHOP  Gold:\" + str(p[\"gold\"]) + \"g ]\"\n                sel = menu_popup(title, opts, col=P_YELLOW)\n                if sel < 0 or sel == len(SHOP_STOCK):\n                    break\n                it = SHOP_STOCK[sel]\n                if p[\"gold\"] < it[\"price\"]:\n                    popup([\"Not enough gold!\", \"Need \" + str(it[\"price\"]) + \"g, have \" + str(p[\"gold\"]) + \"g.\"], title=\"[ SHOP ]\", col=P_RED)\n                else:\n                    p[\"gold\"] -= it[\"price\"]\n                    if it[\"type\"] == \"pickaxe\":\n                        p[\"pickaxe\"] = True\n                        p[\"msg\"] = \"Bought PICKAXE!\"\n                    else:\n                        p[\"inv\"].append(dict(it))\n                        p[\"msg\"] = \"Bought \" + it[\"name\"] + \" for \" + str(it[\"price\"]) + \"g\"\n\n        # \u2500\u2500 MINE tree block \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        def try_mine(tx, ty):\n            if not p.get(\"pickaxe\"):\n                p[\"msg\"] = \"Need a PICKAXE to mine trees! (buy at shop U)\"\n                return\n            if grid[ty][tx] == TILE_TREE:\n                grid[ty][tx] = TILE_FLOOR\n                loot_gold = random.randint(5, 25)\n                p[\"gold\"] += loot_gold\n                loot_lines = [\"You mine the tree!\", \"Found \" + str(loot_gold) + \"g\"]\n                if random.random() < 0.35:\n                    bonus = random.choice([x for x in ITEMS_POOL if x[\"type\"] != \"pickaxe\"])\n                    p[\"inv\"].append(dict(bonus))\n                    loot_lines.append(\"Also found: \" + bonus[\"name\"] + \"!\")\n                p[\"msg\"] = \"Mined tree: +\" + str(loot_gold) + \"g\"\n                popup(loot_lines, title=\"[ MINING ]\", col=P_GREEN)\n\n        # \u2500\u2500 HELP popup \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        def do_help():\n            popup([\n                \"WASD / Arrow keys : Move\",\n                \"E or SPACE        : Interact (chest/enemy)\",\n                \"I                 : Inventory\",\n                \"U                 : Shop (buy weapons, armor, items)\",\n                \"V                 : Scoreboard\",\n                \"H                 : This help\",\n                \"Q                 : Quit\",\n                \"\",\n                \"Walk into enemies to fight.\",\n                \"Walk into chests to open.\",\n                \"Face a T (tree) then press E to mine it (need pickaxe).\",\n                \"You start with a PICKAXE \u2014 upgrade at the shop!\",\n                \"Reach kill goal to win!\",\n            ], title=\"[ HELP ]\", col=P_WHITE)\n\n        # \u2500\u2500 DRAW \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        tick = [0]\n\n        def draw():\n            scr_h2, scr_w2 = stdscr.getmaxyx()\n            VIEW_H2 = scr_h2 - 7\n            VIEW_W2 = scr_w2 - 22\n\n            # centre camera on player\n            nonlocal cam_x, cam_y\n            cam_x = p[\"x\"] - VIEW_W2 // 2\n            cam_y = p[\"y\"] - VIEW_H2 // 2\n            cam_x = max(0, min(cam_x, MAP_W - VIEW_W2))\n            cam_y = max(0, min(cam_y, MAP_H - VIEW_H2))\n\n            pos_map = build_pos_map()\n\n            # draw map\n            for vy in range(VIEW_H2):\n                my = cam_y + vy\n                for vx in range(VIEW_W2):\n                    mx = cam_x + vx\n                    if 0 <= my < MAP_H and 0 <= mx < MAP_W:\n                        tile = grid[my][mx]\n                        ch   = tile\n                        attr = TILE_COLOR.get(tile, P_WHITE)\n                        # entities on top\n                        if (mx, my) == (p[\"x\"], p[\"y\"]):\n                            ch = \"@\"; attr = P_CYAN | curses.A_BOLD\n                        elif (mx, my) in pos_map:\n                            idx = pos_map[(mx,my)]\n                            kind, ent = entities[idx]\n                            if kind == \"enemy\":\n                                ch = ent[\"ch\"]\n                                attr = P_RED | curses.A_BOLD\n                            elif kind == \"chest\":\n                                ch = \"C\"\n                                attr = P_YELLOW | curses.A_BOLD\n                        try:\n                            stdscr.addch(vy, vx, ch, attr)\n                        except:\n                            pass\n                    else:\n                        try: stdscr.addch(vy, vx, \" \")\n                        except: pass\n\n            # right panel (22 cols)\n            px_panel = VIEW_W2\n            def rline(row, text, attr=P_MAG):\n                try:\n                    stdscr.addstr(row, px_panel, (\"\u2502\" + text)[:22], attr)\n                except: pass\n\n            hp_col = P_RED if p[\"hp\"] < p[\"max_hp\"]//4 else (P_YELLOW if p[\"hp\"] < p[\"max_hp\"]//2 else P_GREEN)\n            hpbar = int(p[\"hp\"]/p[\"max_hp\"]*14)\n            xpbar = int(p[\"xp\"]/p[\"xp_next\"]*14)\n\n            try: stdscr.addstr(0,  px_panel, \"\u250c\" + \"\u2500\"*20 + \"\u2510\", P_MAG | curses.A_BOLD)\n            except: pass\n            rline(1,  \" \" + p[\"name\"][:14].ljust(14) + \" Lv\" + str(p[\"level\"]))\n            rline(2,  \" HP \" + str(p[\"hp\"]).rjust(3) + \"/\" + str(p[\"max_hp\"]), hp_col | curses.A_BOLD)\n            rline(3,  \" [\" + \"#\"*hpbar + \"-\"*(14-hpbar) + \"]\", hp_col)\n            rline(4,  \" XP [\" + \"=\"*xpbar + \"-\"*(14-xpbar) + \"]\", P_BLUE)\n            rline(5,  \" ATK:\" + str(p[\"atk\"]).ljust(3) + \" DEF:\" + str(p[\"def_\"]))\n            rline(6,  \" GOLD:\" + str(p[\"gold\"]) + \"g\")\n            rline(7,  \" KILLS:\" + str(p[\"kills\"]) + \"/\" + str(kill_goal), P_YELLOW | curses.A_BOLD)\n            try: stdscr.addstr(8, px_panel, \"\u251c\" + \"\u2500\"*20 + \"\u2524\", P_MAG | curses.A_BOLD)\n            except: pass\n            # status\n            statrow = 9\n            if p[\"poison\"] > 0:\n                rline(statrow, \" !! POISONED !!\",  P_RED | curses.A_BOLD); statrow+=1\n            if p[\"rage\"] > 0:\n                rline(statrow, \" ** ENRAGED x\"+str(p[\"rage\"])+\"**\", P_RED | curses.A_BOLD); statrow+=1\n            # rivals\n            with _opp_lock:\n                snap = dict(_opp_state)\n            rline(statrow, \" RIVALS:\", P_CYAN | curses.A_BOLD); statrow+=1\n            if snap:\n                for nm, st in list(snap.items())[:4]:\n                    s = \"WON\" if st.get(\"won\") else (\"DEAD\" if st.get(\"dead\") else\n                        \"K\"+str(st.get(\"kills\",\"?\")))\n                    rline(statrow, \" \"+nm[:10]+\":\"+s); statrow+=1\n            else:\n                rline(statrow, \" (none)\"); statrow+=1\n            try: stdscr.addstr(min(statrow, scr_h2-1), px_panel, \"\u251c\" + \"\u2500\"*20 + \"\u2524\", P_MAG | curses.A_BOLD)\n            except: pass\n            try:\n                stdscr.addstr(min(statrow+1, scr_h2-2), px_panel, \"\u2502WASD=Move I=Inv  \", P_WHITE | curses.A_DIM)\n                stdscr.addstr(min(statrow+2, scr_h2-2), px_panel, \"\u2502E=Act U=Shop H=? \", P_WHITE | curses.A_DIM)\n                stdscr.addstr(min(statrow+3, scr_h2-2), px_panel, \"\u2502V=Score Q=Quit   \", P_WHITE | curses.A_DIM)\n            except: pass\n\n            # bottom HUD\n            hud_row = VIEW_H2\n            try:\n                stdscr.addstr(hud_row,   0, \"\u2500\" * (scr_w2-1), P_MAG | curses.A_BOLD)\n                stdscr.addstr(hud_row+1, 0, (\" ARENA.EXE  |  \" + p[\"name\"] + \"  Lv\" + str(p[\"level\"]) +\n                    \"  HP:\" + str(p[\"hp\"]) + \"/\" + str(p[\"max_hp\"]) +\n                    \"  Gold:\" + str(p[\"gold\"]) + \"g  Kills:\" + str(p[\"kills\"]) + \"/\" + str(kill_goal))[:scr_w2-1],\n                    P_TITLE | curses.A_BOLD)\n                # msg line\n                msg = p[\"msg\"]\n                if msg:\n                    stdscr.addstr(hud_row+2, 0, (\"  \" + msg)[:scr_w2-1], P_YELLOW)\n                else:\n                    stdscr.addstr(hud_row+2, 0, \"  \" + \" \"*max(0,scr_w2-3))\n                # weapon/armor line\n                wp = p[\"weapon\"][\"name\"] if p[\"weapon\"] else \"FISTS\"\n                ar = p[\"armor\"][\"name\"]  if p[\"armor\"]  else \"NONE\"\n                inv_count = len(p[\"inv\"])\n                stdscr.addstr(hud_row+3, 0,\n                    (\"  WPN:\" + wp[:16] + \"  ARM:\" + ar[:16] + \"  BAG:\" + str(inv_count))[:scr_w2-1],\n                    P_WHITE | curses.A_DIM)\n                stdscr.addstr(hud_row+4, 0, \"\u2500\" * (scr_w2-1), P_MAG | curses.A_BOLD)\n            except: pass\n\n            stdscr.refresh()\n\n        # \u2500\u2500 ENEMY AI: simple wander / chase \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        def update_enemies():\n            for idx, (kind, e) in enumerate(entities):\n                if kind != \"enemy\" or not e[\"alive\"]:\n                    continue\n                e[\"move_cd\"] = e.get(\"move_cd\", 0) - 1\n                if e[\"move_cd\"] > 0:\n                    continue\n                e[\"move_cd\"] = random.randint(6, 14)  # ticks between moves\n\n                dx = p[\"x\"] - e[\"x\"]\n                dy = p[\"y\"] - e[\"y\"]\n                dist = abs(dx) + abs(dy)\n\n                if dist <= 10:\n                    # chase\n                    if abs(dx) > abs(dy):\n                        mx = 1 if dx > 0 else -1; my = 0\n                    else:\n                        mx = 0; my = 1 if dy > 0 else -1\n                else:\n                    # wander\n                    mx, my = random.choice([(1,0),(-1,0),(0,1),(0,-1)])\n\n                nx = e[\"x\"] + mx\n                ny = e[\"y\"] + my\n                if 0 <= nx < MAP_W and 0 <= ny < MAP_H and grid[ny][nx] in (TILE_FLOOR, TILE_GRASS):\n                    # don't stack on other enemies\n                    occupied = any(\n                        k2 == \"enemy\" and e2[\"alive\"] and e2[\"x\"] == nx and e2[\"y\"] == ny\n                        for k2, e2 in entities\n                    )\n                    if not occupied and (nx, ny) != (p[\"x\"], p[\"y\"]):\n                        e[\"x\"] = nx; e[\"y\"] = ny\n\n        # \u2500\u2500 MAIN LOOP \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n        outcome = None\n        msg_timer = [0]\n\n        while True:\n            tick[0] += 1\n\n            # clear msg after a few ticks\n            if p[\"msg\"]:\n                msg_timer[0] += 1\n                if msg_timer[0] > 30:\n                    p[\"msg\"] = \"\"; msg_timer[0] = 0\n            else:\n                msg_timer[0] = 0\n\n            # enemy AI every 2 ticks\n            if tick[0] % 2 == 0:\n                update_enemies()\n\n            # poison tick\n            if tick[0] % 40 == 0 and p[\"poison\"] > 0:\n                p[\"hp\"] -= 2; p[\"poison\"] -= 1\n                p[\"msg\"] = \"Poison! -2 HP\"\n                if p[\"hp\"] <= 0:\n                    outcome = \"dead\"; break\n\n            draw()\n\n            # check opponent won\n            with _opp_lock:\n                for nm, st in _opp_state.items():\n                    if st.get(\"won\") and not p.get(\"won\"):\n                        popup([nm + \" reached \" + str(kill_goal) + \" kills first!\",\n                               \"You lose. Better luck next time.\"],\n                              title=\"[ RACE OVER ]\", col=P_RED)\n                        outcome = \"loss\"; break\n            if outcome: break\n\n            # push state every ~5s (300 ticks @ ~60fps... but nodelay is fast)\n            if tick[0] % 200 == 0:\n                threading.Thread(target=push_state, args=(p,), daemon=True).start()\n\n            k = stdscr.getch()\n            if k == -1:\n                time.sleep(0.016)\n                continue\n\n            # movement\n            dx = dy = 0\n            if   k in (ord('w'), ord('W'), curses.KEY_UP):    dy = -1\n            elif k in (ord('s'), ord('S'), curses.KEY_DOWN):  dy =  1\n            elif k in (ord('a'), ord('A'), curses.KEY_LEFT):  dx = -1\n            elif k in (ord('d'), ord('D'), curses.KEY_RIGHT): dx =  1\n            elif k in (ord('i'), ord('I')): do_inventory(); continue\n            elif k in (ord('v'), ord('V')): do_scoreboard(kill_goal); continue\n            elif k in (ord('h'), ord('H')): do_help(); continue\n            elif k in (ord('u'), ord('U')): do_shop(); continue\n            elif k in (ord('q'), ord('Q')):\n                outcome = \"quit\"; break\n            elif k in (ord('e'), ord('E'), ord(' ')):\n                # interact with adjacent entities\n                pos_map2 = build_pos_map()\n                interacted = False\n                for ddx, ddy in [(0,0),(1,0),(-1,0),(0,1),(0,-1)]:\n                    tx = p[\"x\"] + ddx; ty = p[\"y\"] + ddy\n                    if (tx,ty) in pos_map2:\n                        idx = pos_map2[(tx,ty)]\n                        kind, ent = entities[idx]\n                        if kind == \"chest\" and not ent[\"open\"]:\n                            do_chest(ent); interacted = True; break\n                        elif kind == \"enemy\" and ent[\"alive\"]:\n                            res = do_combat(ent)\n                            if res == \"won\":\n                                ent[\"alive\"] = False\n                                p[\"kills\"] += 1\n                                xpg = ent[\"xp\"]; goldg = ent[\"gold\"] + random.randint(0, ent[\"gold\"]//3)\n                                p[\"xp\"] += xpg; p[\"gold\"] += goldg\n                                lvl_up(p)\n                                p[\"msg\"] = \"Defeated \" + ent[\"name\"] + \"! +\" + str(xpg) + \"XP +\" + str(goldg) + \"g\"\n                                push_state(p)\n                                if p[\"kills\"] >= kill_goal:\n                                    outcome = \"won\"; break\n                            elif res == \"dead\":\n                                outcome = \"dead\"; break\n                            interacted = True; break\n                if not interacted:\n                    # try mining adjacent trees\n                    for ddx2, ddy2 in [(1,0),(-1,0),(0,1),(0,-1)]:\n                        tx2 = p[\"x\"]+ddx2; ty2 = p[\"y\"]+ddy2\n                        if 0 <= tx2 < MAP_W and 0 <= ty2 < MAP_H and grid[ty2][tx2] == TILE_TREE:\n                            try_mine(tx2, ty2); break\n                if outcome: break\n                continue\n\n            if dx == 0 and dy == 0:\n                continue\n\n            nx = p[\"x\"] + dx\n            ny = p[\"y\"] + dy\n            if not (0 <= nx < MAP_W and 0 <= ny < MAP_H):\n                continue\n            if grid[ny][nx] in (TILE_WALL, TILE_TREE):\n                continue\n\n            # bump into entity?\n            pos_map3 = build_pos_map()\n            if (nx, ny) in pos_map3:\n                idx = pos_map3[(nx,ny)]\n                kind, ent = entities[idx]\n                if kind == \"enemy\" and ent[\"alive\"]:\n                    res = do_combat(ent)\n                    if res == \"won\":\n                        ent[\"alive\"] = False\n                        p[\"kills\"] += 1\n                        xpg = ent[\"xp\"]; goldg = ent[\"gold\"] + random.randint(0, ent[\"gold\"]//3)\n                        p[\"xp\"] += xpg; p[\"gold\"] += goldg\n                        lvl_up(p)\n                        p[\"msg\"] = \"Defeated \" + ent[\"name\"] + \"! +\" + str(xpg) + \"XP +\" + str(goldg) + \"g\"\n                        push_state(p)\n                        if p[\"kills\"] >= kill_goal:\n                            outcome = \"won\"; break\n                    elif res == \"dead\":\n                        outcome = \"dead\"; break\n                elif kind == \"chest\" and not ent[\"open\"]:\n                    do_chest(ent)\n                continue\n\n            p[\"x\"] = nx; p[\"y\"] = ny\n\n        return outcome\n\n    # \u2500\u2500 PRE-GAME LOBBY (plain terminal) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    os.system(\"cls\" if os.name == \"nt\" else \"clear\")\n    print(\"\\033[93m\\033[1m\")\n    print(\"  \u2554\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2557\")\n    print(\"  \u2551                                                          \u2551\")\n    print(\"  \u2551    \u2588\u2588\u2588\u2588\u2588\u2557 \u2588\u2588\u2588\u2588\u2588\u2588\u2557 \u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2557\u2588\u2588\u2588\u2557   \u2588\u2588\u2557 \u2588\u2588\u2588\u2588\u2588\u2557            \u2551\")\n    print(\"  \u2551   \u2588\u2588\u2554\u2550\u2550\u2588\u2588\u2557\u2588\u2588\u2554\u2550\u2550\u2588\u2588\u2557\u2588\u2588\u2554\u2550\u2550\u2550\u2550\u255d\u2588\u2588\u2588\u2588\u2557  \u2588\u2588\u2551\u2588\u2588\u2554\u2550\u2550\u2588\u2588\u2557           \u2551\")\n    print(\"  \u2551   \u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2551\u2588\u2588\u2588\u2588\u2588\u2588\u2554\u255d\u2588\u2588\u2588\u2588\u2588\u2557  \u2588\u2588\u2554\u2588\u2588\u2557 \u2588\u2588\u2551\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2551           \u2551\")\n    print(\"  \u2551   \u2588\u2588\u2554\u2550\u2550\u2588\u2588\u2551\u2588\u2588\u2554\u2550\u2550\u2588\u2588\u2557\u2588\u2588\u2554\u2550\u2550\u255d  \u2588\u2588\u2551\u255a\u2588\u2588\u2557\u2588\u2588\u2551\u2588\u2588\u2554\u2550\u2550\u2588\u2588\u2551           \u2551\")\n    print(\"  \u2551   \u2588\u2588\u2551  \u2588\u2588\u2551\u2588\u2588\u2551  \u2588\u2588\u2551\u2588\u2588\u2588\u2588\u2588\u2588\u2588\u2557\u2588\u2588\u2551 \u255a\u2588\u2588\u2588\u2588\u2551\u2588\u2588\u2551  \u2588\u2588\u2551           \u2551\")\n    print(\"  \u2551   \u255a\u2550\u255d  \u255a\u2550\u255d\u255a\u2550\u255d  \u255a\u2550\u255d\u255a\u2550\u2550\u2550\u2550\u2550\u2550\u255d\u255a\u2550\u255d  \u255a\u2550\u2550\u2550\u255d\u255a\u2550\u255d  \u255a\u2550\u255d           \u2551\")\n    print(\"  \u2551                                                          \u2551\")\n    print(\"  \u2551         O P E N   W O R L D   M U L T I P L A Y E R    \u2551\")\n    print(\"  \u2551     Explore. Fight. Loot. First to kill goal wins.      \u2551\")\n    print(\"  \u2551                    kvxnom  //  v1.0                     \u2551\")\n    print(\"  \u2551                                                          \u2551\")\n    print(\"  \u255a\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u255d\")\n    print(\"\\033[0m\")\n\n    print(\"  \\033[92m[H]\\033[0m Host match\")\n    print(\"  \\033[94m[J]\\033[0m Join match\")\n    print(\"  \\033[93m[S]\\033[0m Solo\")\n    print(\"  \\033[91m[Q]\\033[0m Quit\")\n    print()\n    mode = input(\"\\033[2m  > \\033[0m\").strip().lower()\n\n    if mode == \"q\":\n        print(\"\\033[2m  (quit)\\033[0m\"); return\n\n    opp_keys = {}\n    rules    = {\"kill_goal\": 20}\n\n    if mode == \"h\":\n        os.system(\"cls\" if os.name == \"nt\" else \"clear\")\n        print(\"\\033[93m\\033[1m  \u2550\u2550\u2550  HOST \u2014 CONFIGURE MATCH  \u2550\u2550\u2550\\033[0m\\n\")\n        saved_h = load_settings()\n        diff_names_h = list(DIFFICULTIES.keys())\n        print(\"  Difficulties: \" + \"  \".join(\"[\" + str(i+1) + \"] \" + n for i, n in enumerate(diff_names_h)))\n        dc_h = input(\"\\033[2m  Difficulty [1-4 or name, ENTER=\" + saved_h.get(\"difficulty\",\"NORMAL\") + \"]: \\033[0m\").strip().upper()\n        if dc_h.isdigit() and 1 <= int(dc_h) <= 4:\n            diff_key_h = diff_names_h[int(dc_h)-1]\n        elif dc_h in DIFFICULTIES:\n            diff_key_h = dc_h\n        else:\n            diff_key_h = saved_h.get(\"difficulty\", \"NORMAL\")\n        diff_h = DIFFICULTIES[diff_key_h]\n        kg = input(\"\\033[2m  Kill goal [\" + str(diff_h[\"kill_goal\"]) + \"]: \\033[0m\").strip()\n        kill_goal = int(kg) if kg.isdigit() and int(kg) > 0 else diff_h[\"kill_goal\"]\n        save_settings({\"difficulty\": diff_key_h, \"kill_goal\": kill_goal})\n        rules[\"kill_goal\"] = kill_goal\n        print(\"\\033[92m  Difficulty: \" + diff_key_h + \"  Kill goal: \" + str(kill_goal) + \"\\033[0m\")\n        print(\"\\033[92m  Kill goal: \" + str(kill_goal) + \"\\033[0m\\n\")\n\n        import random as _r\n        lc = \"\".join(_r.choices(\"ABCDEFGHJKLMNPQRSTUVWXYZ23456789\", k=8))\n        blob = json.dumps({\"lobby\": lc, \"rules\": rules, \"type\": \"arena2_lobby\"})\n        print(\"\\033[96m  Pushing lobby...\\033[0m\")\n        lobby_key = pb_post(blob)\n        if lobby_key:\n            print(\"\\033[97m\\033[1m\")\n            print(\"  LOBBY CODE  : \" + lc)\n            print(\"  PASTE ID    : \" + lobby_key)\n            print(\"  JOIN STRING : \" + lc + \"|\" + lobby_key)\n            print(\"\\033[0m\")\n        else:\n            print(\"\\033[93m  paste.rs offline \u2014 share rules manually.\\033[0m\")\n\n        name = input(\"\\033[2m  Your fighter name: \\033[0m\").strip() or \"Fighter\"\n        grid, rooms = gen_map()\n        sx = rooms[0][0] + rooms[0][2]//2\n        sy = rooms[0][1] + rooms[0][3]//2\n        p = make_player(name, sx, sy)\n        key = push_state(p)\n        if key:\n            print(\"\\n\\033[96m\\033[1m  Your track ID: paste.rs/\" + key + \"\\033[0m\")\n            print(\"\\033[96m  Share as     : \" + name + \"|\" + key + \"\\033[0m\\n\")\n\n        raw_opp = input(\"\\033[2m  Opponent keys (Name|Key, comma-sep): \\033[0m\").strip()\n        opp_keys = parse_opp_keys(raw_opp)\n\n    elif mode == \"j\":\n        os.system(\"cls\" if os.name == \"nt\" else \"clear\")\n        print(\"\\033[94m\\033[1m  \u2550\u2550\u2550  JOIN MATCH  \u2550\u2550\u2550\\033[0m\\n\")\n        join_in = input(\"\\033[2m  Join string (LOBBYCODE|PasteKey): \\033[0m\").strip()\n        if \"|\" in join_in:\n            lc, lkey = join_in.split(\"|\", 1)\n            raw = pb_get(lkey.strip())\n            if raw:\n                try:\n                    d = json.loads(raw)\n                    rules = d.get(\"rules\", rules)\n                    print(\"\\033[92m  Lobby loaded! Kill goal: \" + str(rules[\"kill_goal\"]) + \"\\033[0m\")\n                except Exception:\n                    print(\"\\033[93m  Could not parse lobby, using defaults.\\033[0m\")\n            else:\n                print(\"\\033[93m  Could not fetch lobby, using defaults.\\033[0m\")\n\n        kill_goal = rules[\"kill_goal\"]\n        print(\"\\033[96m  Kill goal: \" + str(kill_goal) + \"\\033[0m\\n\")\n\n        name = input(\"\\033[2m  Your fighter name: \\033[0m\").strip() or \"Fighter\"\n        grid, rooms = gen_map()\n        sx = rooms[0][0] + rooms[0][2]//2\n        sy = rooms[0][1] + rooms[0][3]//2\n        p = make_player(name, sx, sy)\n        key = push_state(p)\n        if key:\n            print(\"\\n\\033[96m\\033[1m  Your track ID: paste.rs/\" + key + \"\\033[0m\")\n            print(\"\\033[96m  Share as     : \" + name + \"|\" + key + \"\\033[0m\\n\")\n\n        raw_opp = input(\"\\033[2m  Opponent keys (Name|Key, comma-sep): \\033[0m\").strip()\n        opp_keys = parse_opp_keys(raw_opp)\n\n    else:  # solo\n        saved = load_settings()\n        print(\"\\033[93m\\033[1m  \u2550\u2550\u2550  SOLO SETUP  \u2550\u2550\u2550\\033[0m\\n\")\n        diff_names = list(DIFFICULTIES.keys())\n        print(\"  Difficulties: \" + \"  \".join(\"[\" + str(i+1) + \"] \" + n for i, n in enumerate(diff_names)))\n        print(\"  Saved: \" + saved.get(\"difficulty\", \"NORMAL\"))\n        dc = input(\"\\033[2m  Choose difficulty [1-4 or name, ENTER=saved]: \\033[0m\").strip().upper()\n        if dc.isdigit() and 1 <= int(dc) <= 4:\n            diff_key = diff_names[int(dc)-1]\n        elif dc in DIFFICULTIES:\n            diff_key = dc\n        else:\n            diff_key = saved.get(\"difficulty\", \"NORMAL\")\n        diff = DIFFICULTIES[diff_key]\n        kg_in = input(\"\\033[2m  Kill goal [\" + str(diff[\"kill_goal\"]) + \"]: \\033[0m\").strip()\n        kill_goal = int(kg_in) if kg_in.isdigit() and int(kg_in) > 0 else diff[\"kill_goal\"]\n        save_settings({\"difficulty\": diff_key, \"kill_goal\": kill_goal})\n        print(\"\\033[92m  Difficulty: \" + diff_key + \"  Kill goal: \" + str(kill_goal) + \"\\033[0m\\n\")\n        rules[\"kill_goal\"] = kill_goal\n        name = input(\"\\033[2m  Fighter name: \\033[0m\").strip() or \"Fighter\"\n        grid, rooms = gen_map()\n        sx = rooms[0][0] + rooms[0][2]//2\n        sy = rooms[0][1] + rooms[0][3]//2\n        p = make_player(name, sx, sy)\n        p[\"hp\"] = int(p[\"hp\"] * diff[\"hp_mul\"]); p[\"max_hp\"] = p[\"hp\"]\n        p[\"gold\"] = int(p[\"gold\"] * diff[\"gold_mul\"])\n\n    entities = spawn_entities(grid, rooms)\n\n    print()\n    print(\"\\033[2m  Generating world... press ENTER to start.\\033[0m\")\n    input()\n\n    if opp_keys:\n        t = threading.Thread(target=poll_opponents, args=(opp_keys,), daemon=True)\n        t.start()\n\n    # \u2500\u2500 launch curses \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    outcome = curses.wrapper(run_curses, p, grid, entities, kill_goal, opp_keys)\n\n    _stop_poll.set()\n\n    # \u2500\u2500 post-game screen \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n    os.system(\"cls\" if os.name == \"nt\" else \"clear\")\n\n    if outcome == \"won\":\n        p[\"won\"] = True; push_state(p)\n        print(\"\\033[93m\\033[1m\")\n        print(\"  \u2554\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2557\")\n        print(\"  \u2551   \u2605  ARENA CHAMPION  \u2605              \u2551\")\n        print(\"  \u255a\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u255d\\033[0m\")\n        print(\"  Name   : \\033[1m\" + p[\"name\"] + \"\\033[0m\")\n        print(\"  Level  : \\033[93m\" + str(p[\"level\"]) + \"\\033[0m\")\n        print(\"  Kills  : \\033[92m\" + str(p[\"kills\"]) + \"/\" + str(kill_goal) + \"\\033[0m\")\n        print(\"  Gold   : \\033[93m\" + str(p[\"gold\"]) + \"g\\033[0m\")\n        def _del():\n            time.sleep(60); pb_delete(_my_key[0])\n        threading.Thread(target=_del, daemon=True).start()\n    elif outcome == \"dead\":\n        p[\"dead\"] = True; push_state(p)\n        print(\"\\033[91m\\033[1m\")\n        print(\"  \u2554\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2557\")\n        print(\"  \u2551   \u271d   YOU HAVE FALLEN               \u2551\")\n        print(\"  \u255a\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u255d\\033[0m\")\n        print(\"  Name   : \\033[1m\" + p[\"name\"] + \"\\033[0m\")\n        print(\"  Level  : \\033[93m\" + str(p[\"level\"]) + \"\\033[0m\")\n        print(\"  Kills  : \\033[92m\" + str(p[\"kills\"]) + \"\\033[0m\")\n        print(\"  Gold   : \\033[93m\" + str(p[\"gold\"]) + \"g\\033[0m\")\n        def _del():\n            time.sleep(60); pb_delete(_my_key[0])\n        threading.Thread(target=_del, daemon=True).start()\n    elif outcome == \"loss\":\n        print(\"\\033[91m  RACE OVER \u2014 an opponent won first.\\033[0m\")\n    else:\n        print(\"\\033[2m  (quit)\\033[0m\")\n\n    print()\n    input(\"\\033[2m  Press ENTER to exit.\\033[0m\")\n    print()\n\n_game()"
        }
    ]
}