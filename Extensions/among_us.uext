{
    "name": "AMONG US CLI",
    "author": "kvxnom (Game design), Claude (Code)",
    "version": "1.1",
    "sig_ver": 2,
    "aid": "com.kvxnom.among_us_cli",
    "certcode": "2F7351AF9DB616F18C65783F52B0CC9D88D75351EA70485C155AEA26C044C3BC",
    "description": "ASCII Among Us clone. 12 skins, vent travel, task mini-games, sabotage, meetings, voting, multiplayer via paste.rs. Command: among",
    "commands": [
        {
            "name": "among",
            "description": "Launch AMONG US CLI",
            "action": "python",
            "value": "def _game():\n    import curses, json, threading, urllib.request, time, os, pathlib, random, collections\n\n    SAVE_FILE  = pathlib.Path.home() / \".among_us_cli.auf\"\n    PASTE_BASE = \"https://paste.rs/\"\n    _my_key    = [None]\n    _net_data  = {}\n    _net_lock  = threading.Lock()\n    _stop_ev   = threading.Event()\n\n    def pb_post(txt):\n        try:\n            req = urllib.request.Request(PASTE_BASE, data=txt.encode(), method=\"POST\", headers={\"Content-Type\":\"text/plain; charset=utf-8\"})\n            with urllib.request.urlopen(req, timeout=8) as r: url = r.read().decode().strip()\n            if url.startswith(PASTE_BASE): return url[len(PASTE_BASE):]\n        except: pass\n        return None\n    def pb_get(key):\n        try:\n            req = urllib.request.Request(PASTE_BASE + key, headers={\"User-Agent\":\"among_cli/1.0\"})\n            with urllib.request.urlopen(req, timeout=8) as r: return r.read().decode()\n        except: return None\n    def pb_delete(key):\n        if not key: return\n        try:\n            req = urllib.request.Request(PASTE_BASE + key, method=\"DELETE\")\n            with urllib.request.urlopen(req, timeout=8) as r: r.read()\n        except: pass\n    def push(blob):\n        old = _my_key[0]; key = pb_post(json.dumps(blob))\n        if key:\n            if old and old != key: threading.Thread(target=pb_delete, args=(old,), daemon=True).start()\n            _my_key[0] = key\n        return key\n    def poll(peer_keys):\n        while not _stop_ev.is_set():\n            for nm, k in list(peer_keys.items()):\n                raw = pb_get(k)\n                if raw:\n                    try:\n                        with _net_lock: _net_data[nm] = json.loads(raw)\n                    except: pass\n            _stop_ev.wait(5)\n\n    # -- skins -----------------------------------------------------------------\n    # col: 1=white 2=green 3=cyan 4=red 5=yellow 6=magenta 7=blue\n    SKINS = [\n        {\"name\":\"Classic\",   \"body\":\"( )\",  \"hat\":\"   \", \"col\":2},\n        {\"name\":\"Cowboy\",    \"body\":\"( )\",  \"hat\":\"/_\\\\\", \"col\":5},\n        {\"name\":\"Astronaut\", \"body\":\"[O]\",  \"hat\":\"===\", \"col\":3},\n        {\"name\":\"Knight\",    \"body\":\"<O>\",  \"hat\":\"[#]\", \"col\":7},\n        {\"name\":\"Santa\",     \"body\":\"( )\",  \"hat\":\"vvv\", \"col\":4},\n        {\"name\":\"Ninja\",     \"body\":\"(^)\",  \"hat\":\"===\", \"col\":1},\n        {\"name\":\"Alien\",     \"body\":\"(*)\",  \"hat\":\"~~~\", \"col\":6},\n        {\"name\":\"Robot\",     \"body\":\"[#]\",  \"hat\":\"---\", \"col\":3},\n        {\"name\":\"Ghost\",     \"body\":\"( )\",  \"hat\":\"   \", \"col\":1},\n        {\"name\":\"Pirate\",    \"body\":\"(X)\",  \"hat\":\"/^\\\\\", \"col\":5},\n        {\"name\":\"Wizard\",    \"body\":\"( )\",  \"hat\":\"/|\\\\\", \"col\":6},\n        {\"name\":\"Clown\",     \"body\":\"(o)\",  \"hat\":\"oOo\", \"col\":4},\n    ]\n\n    # ANSI colour codes indexed by skin col value (col is 1-7)\n    _ANSI = {1:\"\\033[37m\", 2:\"\\033[32m\", 3:\"\\033[36m\", 4:\"\\033[31m\",\n             5:\"\\033[33m\", 6:\"\\033[35m\", 7:\"\\033[34m\"}\n\n    MAP_RAW = [\n        \"##############################################\",\n        \"#..................##.....T....##............#\",\n        \"#.T.....##.........#.......####.....V.....T.#\",\n        \"#.......##.........#...........#............#\",\n        \"#.......##.........#...........#............#\",\n        \"#####D######.......####D#######.....########\",\n        \"#...........#######...........######........#\",\n        \"#.T..V......#.....#.T.........#....#....T...#\",\n        \"#...........#.....#...........#....#........#\",\n        \"#...........#.....#...........D....#........#\",\n        \"#####D#######.....####D#######....##########\",\n        \"#...........#.....#...........##...V........#\",\n        \"#.T.........#..T..#............#............#\",\n        \"#....V......#.....#............#....T.......#\",\n        \"#...........#######...........##............#\",\n        \"##############################################\",\n    ]\n    MAP_H = len(MAP_RAW)\n    MAP_W = len(MAP_RAW[0])\n\n    TASKS_DEF = [\n        {\"id\":\"fix_wires\",    \"name\":\"Fix Wires\",     \"steps\":3},\n        {\"id\":\"scan_id\",      \"name\":\"MedBay Scan\",   \"steps\":5},\n        {\"id\":\"fuel_engines\", \"name\":\"Fuel Engines\",  \"steps\":4},\n        {\"id\":\"empty_trash\",  \"name\":\"Empty Garbage\", \"steps\":2},\n        {\"id\":\"align_engine\", \"name\":\"Align Engine\",  \"steps\":4},\n        {\"id\":\"upload_data\",  \"name\":\"Upload Data\",   \"steps\":3},\n    ]\n\n    TASK_POS = []; VENT_POS = []\n    for ry, row in enumerate(MAP_RAW):\n        for rx, ch in enumerate(row):\n            if ch == 'T': TASK_POS.append((rx, ry))\n            if ch == 'V': VENT_POS.append((rx, ry))\n\n    def load_save():\n        try: return json.loads(SAVE_FILE.read_text())\n        except: return {}\n    def save_pref(d):\n        try: SAVE_FILE.write_text(json.dumps(d))\n        except: pass\n\n    def new_player(name, skin_idx, is_imp):\n        return {\"name\":name, \"skin\":skin_idx, \"col\":SKINS[skin_idx][\"col\"],\n                \"x\":3.0, \"y\":3.0, \"alive\":True, \"ghost\":False,\n                \"impostor\":is_imp, \"kills\":0, \"tasks_done\":[],\n                \"in_vent\":False, \"vent_idx\":None,\n                \"sabotage_cd\":0, \"kill_cd\":0}\n\n    def new_game(name, skin_idx, num_impostors=1, task_count=4):\n        positions = random.sample(TASK_POS, min(task_count, len(TASK_POS)))\n        task_list = []\n        for pos in positions:\n            td = random.choice(TASKS_DEF)\n            task_list.append({\"id\":td[\"id\"], \"name\":td[\"name\"], \"pos\":list(pos),\n                               \"done\":False, \"progress\":0, \"steps\":td[\"steps\"]})\n        is_imp = random.random() < (num_impostors / 5.0)\n        p = new_player(name, skin_idx, is_imp)\n        return {\"player\":p, \"tasks\":task_list, \"bodies\":[],\n                \"meeting\":False, \"meeting_log\":[], \"votes\":{},\n                \"phase\":\"play\", \"winner\":None,\n                \"sabotage\":None, \"sab_timer\":0, \"lights_out\":False, \"tick\":0}\n\n    def walkable(x, y):\n        ix, iy = int(round(x)), int(round(y))\n        if ix < 0 or iy < 0 or iy >= MAP_H or ix >= MAP_W: return False\n        return MAP_RAW[iy][ix] in '.TVD'\n\n    def run_curses(stdscr, g, peer_keys):\n        curses.curs_set(0); stdscr.nodelay(True); stdscr.keypad(True)\n        curses.start_color(); curses.use_default_colors()\n        _pairs = [\n            (curses.COLOR_WHITE,  -1),   # 1 white\n            (curses.COLOR_GREEN,  -1),   # 2 green\n            (curses.COLOR_CYAN,   -1),   # 3 cyan\n            (curses.COLOR_RED,    -1),   # 4 red\n            (curses.COLOR_YELLOW, -1),   # 5 yellow\n            (curses.COLOR_MAGENTA,-1),   # 6 magenta\n            (curses.COLOR_BLUE,   -1),   # 7 blue\n            (curses.COLOR_BLACK,  curses.COLOR_GREEN),   # 8 BG green\n            (curses.COLOR_BLACK,  curses.COLOR_YELLOW),  # 9 BG yellow\n            (curses.COLOR_WHITE,  curses.COLOR_BLUE),    # 10 title bar\n            (curses.COLOR_BLACK,  curses.COLOR_CYAN),    # 11 BG cyan\n            (curses.COLOR_WHITE,  curses.COLOR_RED),     # 12 BG red\n            (curses.COLOR_WHITE,  curses.COLOR_MAGENTA), # 13 BG magenta\n            (curses.COLOR_BLACK,  curses.COLOR_WHITE),   # 14 BG white\n        ]\n        for i, (fg, bg) in enumerate(_pairs, 1): curses.init_pair(i, fg, bg)\n\n        P_W  = curses.color_pair(1)\n        P_G  = curses.color_pair(2)\n        P_C  = curses.color_pair(3)\n        P_R  = curses.color_pair(4)\n        P_Y  = curses.color_pair(5)\n        P_M  = curses.color_pair(6)\n        P_B  = curses.color_pair(7)\n        P_BG = curses.color_pair(8)\n        P_BY = curses.color_pair(9)\n        P_TB = curses.color_pair(10)\n        P_BC = curses.color_pair(11)\n        P_BR = curses.color_pair(12)\n        P_BM = curses.color_pair(13)\n\n        # map col index -> curses pair (skin col 1-7)\n        _COL_MAP = {1:P_W, 2:P_G, 3:P_C, 4:P_R, 5:P_Y, 6:P_M, 7:P_B}\n\n        tick = [0]; last_t = [time.time()]\n        msg  = [\"\"]; msg_t = [0]\n        SPEED = 0.18\n\n        def sa(r, c, txt, attr=0):\n            try: stdscr.addstr(int(r), int(c), str(txt), attr)\n            except: pass\n\n        def popup(lines, title=\"\", col=None):\n            if col is None: col = P_W\n            sh, sw = stdscr.getmaxyx()\n            mw = max((len(l) for l in lines), default=10) + 4\n            mw = max(mw, len(title) + 4, 34)\n            ph = len(lines) + 4\n            py = (sh - ph) // 2; px = (sw - mw) // 2\n            stdscr.attron(col | curses.A_BOLD)\n            sa(py, px, \"+\" + \"-\"*(mw-2) + \"+\")\n            if title: sa(py, px + (mw - len(title))//2, title)\n            stdscr.attroff(col | curses.A_BOLD)\n            for i, line in enumerate(lines):\n                sa(py+1+i, px, \"| \")\n                try: stdscr.addstr(line[:mw-4]); stdscr.addstr(\" \"*max(0,mw-4-len(line)) + \" |\")\n                except: pass\n            stdscr.attron(col | curses.A_BOLD)\n            sa(py+1+len(lines), px, \"+\" + \"-\"*(mw-2) + \"+\")\n            sa(py+2+len(lines), px, \"| \" + \"[ ENTER ]\".center(mw-4) + \" |\")\n            sa(py+3+len(lines), px, \"+\" + \"-\"*(mw-2) + \"+\")\n            stdscr.attroff(col | curses.A_BOLD)\n            stdscr.refresh(); stdscr.nodelay(False)\n            while True:\n                k = stdscr.getch()\n                if k in (10, 13, ord(' ')): break\n            stdscr.nodelay(True)\n\n        def menu_popup(title, opts, col=None):\n            if col is None: col = P_W\n            mw = max((len(o) for o in opts), default=10) + 8\n            mw = max(mw, len(title) + 4, 36)\n            ph = len(opts) + 4; sh, sw = stdscr.getmaxyx()\n            py = (sh - ph) // 2; px = (sw - mw) // 2; sel = 0\n            stdscr.nodelay(False)\n            while True:\n                stdscr.attron(col | curses.A_BOLD)\n                sa(py, px, \"+\" + \"-\"*(mw-2) + \"+\")\n                if title: sa(py, px + (mw - len(title))//2, title)\n                stdscr.attroff(col | curses.A_BOLD)\n                for i, opt in enumerate(opts):\n                    if i == sel: stdscr.attron(col | curses.A_REVERSE)\n                    sa(py+1+i, px, \"| \")\n                    stdscr.addstr((\" > \" + opt)[:mw-4].ljust(mw-4))\n                    stdscr.addstr(\" |\")\n                    if i == sel: stdscr.attroff(col | curses.A_REVERSE)\n                stdscr.attron(col | curses.A_BOLD)\n                sa(py+1+len(opts), px, \"+\" + \"-\"*(mw-2) + \"+\")\n                sa(py+2+len(opts), px, \"| \" + \"ESC=cancel\".center(mw-4) + \" |\")\n                sa(py+3+len(opts), px, \"+\" + \"-\"*(mw-2) + \"+\")\n                stdscr.attroff(col | curses.A_BOLD)\n                stdscr.refresh()\n                k = stdscr.getch()\n                if k in (curses.KEY_UP,):   sel = (sel-1) % len(opts)\n                elif k in (curses.KEY_DOWN,): sel = (sel+1) % len(opts)\n                elif k in (10, 13): stdscr.nodelay(True); return sel\n                elif k == 27:       stdscr.nodelay(True); return -1\n\n        def do_task_minigame(task):\n            sh, sw = stdscr.getmaxyx()\n            name = task[\"name\"]; steps = task[\"steps\"]\n            for step in range(steps):\n                stdscr.erase()\n                bx = sw//2 - 20\n                sa(sh//2-4, bx, \"+\" + \"=\"*38 + \"+\", P_C | curses.A_BOLD)\n                sa(sh//2-3, bx, \"|\" + (\" TASK: \" + name)[:38].center(38) + \"|\", P_C | curses.A_BOLD)\n                sa(sh//2-2, bx, \"|\" + (\" Step \" + str(step+1) + \"/\" + str(steps)).ljust(38) + \"|\", P_C)\n\n                if task[\"id\"] == \"fix_wires\":\n                    wires = list(\"RGBY\"); random.shuffle(wires)\n                    prompt = \"Connect in order: \" + \" \".join(wires)\n                    sa(sh//2-1, bx, \"| \" + prompt[:36].ljust(36) + \"|\", P_Y)\n                    sa(sh//2,   bx, \"| \" + \"Type each letter then ENTER\".ljust(36) + \"|\", P_W)\n                    sa(sh//2+1, bx, \"+\" + \"=\"*38 + \"+\", P_C | curses.A_BOLD)\n                    stdscr.refresh(); stdscr.nodelay(False)\n                    buf = \"\"; done = False\n                    while not done:\n                        k = stdscr.getch()\n                        if k in (10, 13):\n                            if buf.upper() == \"\".join(wires): done = True\n                            else: buf = \"\"; sa(sh//2+2, bx+5, \"Wrong! Try again.   \", P_BR | curses.A_BOLD); stdscr.refresh()\n                        elif k == 27: stdscr.nodelay(True); return False\n                        elif k == 8 or k == 127: buf = buf[:-1]\n                        elif 32 <= k < 128: buf += chr(k)\n                        sa(sh//2, bx, \"| Input: \" + buf[:28].ljust(29) + \"|\", P_Y); stdscr.refresh()\n                    stdscr.nodelay(True)\n\n                elif task[\"id\"] == \"scan_id\":\n                    target = random.randint(1000, 9999)\n                    sa(sh//2-1, bx, \"| \" + (\"Enter code: \" + str(target)).ljust(36) + \"|\", P_Y)\n                    sa(sh//2+1, bx, \"+\" + \"=\"*38 + \"+\", P_C | curses.A_BOLD)\n                    stdscr.refresh(); stdscr.nodelay(False)\n                    buf = \"\"; done = False\n                    while not done:\n                        k = stdscr.getch()\n                        if k in (10, 13):\n                            if buf == str(target): done = True\n                            else: buf = \"\"; sa(sh//2+2, bx+5, \"Wrong!              \", P_BR | curses.A_BOLD); stdscr.refresh()\n                        elif k == 27: stdscr.nodelay(True); return False\n                        elif k == 8 or k == 127: buf = buf[:-1]\n                        elif ord('0') <= k <= ord('9'): buf += chr(k)\n                        sa(sh//2-1, bx, \"| Code: \" + buf[:30].ljust(30) + \"|\", P_Y); stdscr.refresh()\n                    stdscr.nodelay(True)\n\n                else:\n                    words = {\"fuel_engines\":\"FUEL\",\"align_engine\":\"ALGN\",\"upload_data\":\"UPLD\",\"empty_trash\":\"TRSH\"}\n                    word = words.get(task[\"id\"], \"DONE\")\n                    sa(sh//2-1, bx, \"| \" + (\"Type: \" + word + \" and press ENTER\").ljust(36) + \"|\", P_Y)\n                    sa(sh//2+1, bx, \"+\" + \"=\"*38 + \"+\", P_C | curses.A_BOLD)\n                    stdscr.refresh(); stdscr.nodelay(False)\n                    buf = \"\"; done = False\n                    while not done:\n                        k = stdscr.getch()\n                        if k in (10, 13):\n                            if buf.upper() == word: done = True\n                            else: buf = \"\"; sa(sh//2+2, bx+5, \"Wrong!              \", P_BR | curses.A_BOLD); stdscr.refresh()\n                        elif k == 27: stdscr.nodelay(True); return False\n                        elif k == 8 or k == 127: buf = buf[:-1]\n                        elif 32 <= k < 128: buf += chr(k)\n                        sa(sh//2-1, bx, \"| Input: \" + buf[:28].ljust(29) + \"|\", P_Y); stdscr.refresh()\n                    stdscr.nodelay(True)\n            return True\n\n        def do_meeting(reporter=None):\n            g[\"phase\"] = \"meeting\"; g[\"votes\"] = {}\n            with _net_lock: snap = dict(_net_data)\n            peers_alive = [nm for nm,st in snap.items() if st.get(\"alive\", True)]\n            candidates = peers_alive + [\"SKIP\"]\n            log = g[\"meeting_log\"][-6:]\n            lines = [\"EMERGENCY MEETING!\", \"\"]\n            if reporter: lines.append(reporter + \" called the meeting.\")\n            lines += [\"\", \"-\"*30, \"Recent events:\"] + log + [\"\", \"-\"*30, \"Vote to eject:\"]\n            popup(lines, title=\"[ MEETING ]\", col=P_BM)\n            if not candidates: candidates = [\"SKIP\"]\n            sel = menu_popup(\"[ VOTE ]\", candidates, col=P_R)\n            voted = candidates[sel] if 0 <= sel < len(candidates) else \"SKIP\"\n            g[\"votes\"][g[\"player\"][\"name\"]] = voted\n            tally = collections.Counter()\n            tally[voted] += 1\n            for _ in range(random.randint(0, 3)): tally[random.choice(candidates)] += 1\n            most = tally.most_common(1)[0]\n            result_lines = [\"You voted: \" + voted, \"\"]\n            if most[0] != \"SKIP\":\n                result_lines += [\"EJECTED: \" + most[0] + \" (\" + str(most[1]) + \" votes)\", \"\", \"Were they the Impostor? ...Maybe.\"]\n                g[\"meeting_log\"].append(most[0] + \" was ejected.\")\n            else:\n                result_lines.append(\"No majority. Nobody ejected.\")\n            popup(result_lines, title=\"[ VOTE RESULT ]\", col=P_BM)\n            g[\"phase\"] = \"play\"\n\n        def do_sabotage():\n            opts = [\"Lights Out (60s)\", \"Lock Doors (30s)\", \"Reactor Meltdown (45s)\", \"Cancel\"]\n            sel = menu_popup(\"[ SABOTAGE ]\", opts, col=P_BR)\n            p = g[\"player\"]\n            if sel == 0:   g[\"lights_out\"] = True; g[\"sab_timer\"] = 60*4; msg[0] = \"SABOTAGE: Lights out!\"\n            elif sel == 1: msg[0] = \"SABOTAGE: Doors locked!\"\n            elif sel == 2: g[\"sabotage\"] = \"reactor\"; g[\"sab_timer\"] = 45*4; msg[0] = \"SABOTAGE: Reactor meltdown!\"\n            p[\"sabotage_cd\"] = 20*4\n\n        def draw():\n            sh, sw = stdscr.getmaxyx(); stdscr.erase()\n            p = g[\"player\"]; skin = SKINS[p[\"skin\"]]\n            role = \"IMPOSTOR\" if p[\"impostor\"] else \"CREWMATE\"\n            role_col = P_BR | curses.A_BOLD if p[\"impostor\"] else P_BG | curses.A_BOLD\n            hdr = \"  AMONG US CLI  |  \" + p[\"name\"] + \"  [\" + role + \"]\"\n            sa(0, 0, hdr[:sw-1].ljust(sw-1), role_col)\n\n            VP_W = min(46, sw - 26); VP_H = min(14, sh - 7)\n            VP_W = max(VP_W, 10); VP_H = max(VP_H, 5)\n            cam_x = max(0, min(MAP_W - VP_W, int(p[\"x\"]) - VP_W//2))\n            cam_y = max(0, min(MAP_H - VP_H, int(p[\"y\"]) - VP_H//2))\n\n            for vy in range(VP_H):\n                my = cam_y + vy\n                for vx in range(VP_W):\n                    mx = cam_x + vx\n                    if 0 <= my < MAP_H and 0 <= mx < MAP_W:\n                        ch = MAP_RAW[my][mx]\n                        dark = g.get(\"lights_out\") and (abs(mx-int(p[\"x\"])) > 5 or abs(my-int(p[\"y\"])) > 3)\n                        if dark:               sa(2+vy, 2+vx, \"#\", P_B | curses.A_DIM)\n                        elif ch == '#':        sa(2+vy, 2+vx, \"#\", P_B)\n                        elif ch == 'T':        sa(2+vy, 2+vx, \"T\", P_Y | curses.A_BOLD)\n                        elif ch == 'V':        sa(2+vy, 2+vx, \"V\", P_C | curses.A_DIM)\n                        elif ch == 'D':        sa(2+vy, 2+vx, \"D\", P_W | curses.A_BOLD)\n                        else:                  sa(2+vy, 2+vx, \".\", P_B | curses.A_DIM)\n\n            for t in g[\"tasks\"]:\n                tx, ty = t[\"pos\"]; vx = tx-cam_x; vy = ty-cam_y\n                if 0 <= vx < VP_W and 0 <= vy < VP_H:\n                    sa(2+vy, 2+vx, \"*\", P_BG if t[\"done\"] else P_BY)\n\n            for b in g[\"bodies\"]:\n                vx = int(b[\"x\"])-cam_x; vy = int(b[\"y\"])-cam_y\n                if 0 <= vx < VP_W and 0 <= vy < VP_H:\n                    sa(2+vy, 2+vx, \"X\", P_BR | curses.A_BOLD)\n\n            with _net_lock: snap = dict(_net_data)\n            for nm, st in snap.items():\n                vx = int(st.get(\"x\",0))-cam_x; vy = int(st.get(\"y\",0))-cam_y\n                if 0 <= vx < VP_W-1 and 0 <= vy < VP_H:\n                    sk = st.get(\"skin\", 0)\n                    if sk < 0 or sk >= len(SKINS): sk = 0\n                    skin2 = SKINS[sk]\n                    pc2 = _COL_MAP.get(skin2[\"col\"], P_W)\n                    sym = skin2[\"body\"] if not st.get(\"ghost\") else \"~~~\"\n                    sa(2+vy, 2+vx, sym[:3], pc2 | (curses.A_DIM if st.get(\"ghost\") else curses.A_BOLD))\n                    if vy > 0: sa(1+vy, 2+vx, nm[:3], pc2 | curses.A_DIM)\n\n            pvx = int(p[\"x\"])-cam_x; pvy = int(p[\"y\"])-cam_y\n            pc = _COL_MAP.get(skin[\"col\"], P_W)\n            if 0 <= pvx < VP_W and 0 <= pvy < VP_H:\n                if p.get(\"ghost\"):\n                    sa(2+pvy, 2+pvx, \"~~~\", P_W | curses.A_DIM)\n                elif p.get(\"in_vent\"):\n                    sa(2+pvy, 2+pvx, \"[v]\", P_C | curses.A_BOLD)\n                else:\n                    hat = skin[\"hat\"]\n                    if hat.strip() and pvy > 0: sa(1+pvy, 2+pvx, hat, pc | curses.A_BOLD)\n                    sa(2+pvy, 2+pvx, skin[\"body\"], pc | curses.A_BOLD)\n\n            # right panel\n            rp = VP_W + 4\n            task_done = sum(1 for t in g[\"tasks\"] if t[\"done\"])\n            task_total = len(g[\"tasks\"])\n            pct = int(task_done / max(1, task_total) * 100)\n            bw = 16; filled = int(pct * bw / 100)\n            panel = [\n                \"+\" + \"-\"*20 + \"+\",\n                \"|\" + \" STATUS \".center(20) + \"|\",\n                \"+\" + \"-\"*20 + \"+\",\n                \"| Role: \" + role[:13].ljust(13) + \"|\",\n                \"| Skin: \" + skin[\"name\"][:13].ljust(13) + \"|\",\n                \"| Alive: \" + (\"YES\" if p[\"alive\"] else \"DEAD\").ljust(12) + \"|\",\n                \"+\" + \"-\"*20 + \"+\",\n                \"| TASKS\".ljust(21) + \"|\",\n            ]\n            for t in g[\"tasks\"]:\n                bar = \"[\" + (\"#\"*t[\"progress\"] + \".\"*max(0,t[\"steps\"]-t[\"progress\"]))[:t[\"steps\"]] + \"]\"\n                mark = \"V\" if t[\"done\"] else \".\"\n                panel.append(\"|\" + mark + t[\"name\"][:10].ljust(10) + bar[:9].ljust(9) + \"|\")\n            panel += [\n                \"+\" + \"-\"*20 + \"+\",\n                \"| \" + \"#\"*filled + \".\"*(bw-filled) + \" \" + str(pct) + \"%|\",\n                \"| \" + (str(task_done) + \"/\" + str(task_total) + \" complete\").ljust(19) + \"|\",\n                \"+\" + \"-\"*20 + \"+\",\n            ]\n            if p[\"impostor\"]:\n                kcd = max(0, p.get(\"kill_cd\",0))\n                scd = max(0, p.get(\"sabotage_cd\",0))\n                panel += [\n                    \"| Kill CD:  \" + str(kcd//4) + \"s\".ljust(8) + \"|\",\n                    \"| Sab CD:   \" + str(scd//4) + \"s\".ljust(8) + \"|\",\n                    \"+\" + \"-\"*20 + \"+\",\n                    \"| K=Kill  X=Sabotage  |\",\n                ]\n            else:\n                panel += [\n                    \"| E=Task  R=Report    |\",\n                    \"| C=EmergencyMeeting  |\",\n                ]\n            panel += [\"+\" + \"-\"*20 + \"+\", \"| WASD=Move  H=Help   |\", \"+\" + \"-\"*20 + \"+\"]\n            for i, line in enumerate(panel):\n                sa(2+i, rp, line[:22], P_C)\n\n            # peers panel\n            if snap:\n                pr = 2 + len(panel) + 1\n                sa(pr,   rp, \"+\" + \"-\"*20 + \"+\", P_M | curses.A_BOLD)\n                sa(pr+1, rp, \"|\" + \" PLAYERS \".center(20) + \"|\", P_M | curses.A_BOLD)\n                sa(pr+2, rp, \"+\" + \"-\"*20 + \"+\", P_M | curses.A_BOLD)\n                rr = pr+3\n                for nm, st in list(snap.items())[:5]:\n                    alive_s = \"ALIVE\" if st.get(\"alive\",True) else \"DEAD\"\n                    sa(rr, rp, \"| \" + nm[:10].ljust(10) + \" \" + alive_s.ljust(6) + \"|\", P_W)\n                    rr += 1\n                sa(rr, rp, \"+\" + \"-\"*20 + \"+\", P_M | curses.A_BOLD)\n\n            # sabotage overlays\n            if g.get(\"sabotage\") == \"reactor\":\n                rt = g[\"sab_timer\"]//4\n                try: stdscr.addstr(sh//2, sw//2-14, \"  !! REACTOR MELTDOWN: \" + str(rt) + \"s !!  \", P_BR | curses.A_BOLD)\n                except: pass\n            if g.get(\"lights_out\"):\n                try: stdscr.addstr(sh//2+1, sw//2-10, \"  !! LIGHTS OUT !!  \", P_BM | curses.A_BOLD)\n                except: pass\n\n            if g[\"phase\"] == \"end\":\n                result = \"* \" + str(g[\"winner\"]) + \" WIN! *\"\n                rc = P_BG if \"CREW\" in str(g[\"winner\"]) else P_BR\n                try: stdscr.addstr(sh//2, sw//2-len(result)//2, result, rc | curses.A_BOLD)\n                except: pass\n\n            if msg[0]: sa(sh-3, 2, (\"  \" + msg[0])[:sw-3], P_BY)\n            try:\n                stdscr.addstr(sh-2, 0, \"-\"*(sw-1), P_M | curses.A_BOLD)\n                stdscr.addstr(sh-1, 0, \" WASD=Move  E=Task/Vent  R=Report  C=Meeting  K=Kill  X=Sab  H=Help  Q=Quit\"[:sw-1], P_W | curses.A_DIM)\n            except: pass\n            stdscr.refresh()\n\n        _COL_MAP = {1:curses.color_pair(1), 2:curses.color_pair(2), 3:curses.color_pair(3),\n                    4:curses.color_pair(4),  5:curses.color_pair(5), 6:curses.color_pair(6),\n                    7:curses.color_pair(7)}\n\n        while True:\n            tick[0] += 1\n            p = g[\"player\"]\n\n            if p.get(\"kill_cd\",0) > 0:    p[\"kill_cd\"] -= 1\n            if p.get(\"sabotage_cd\",0) > 0: p[\"sabotage_cd\"] -= 1\n            if g.get(\"sab_timer\",0) > 0:\n                g[\"sab_timer\"] -= 1\n                if g[\"sab_timer\"] == 0: g[\"lights_out\"] = False; g[\"sabotage\"] = None; msg[0] = \"Sabotage expired.\"\n            msg_t[0] += 1\n            if msg_t[0] > 100: msg[0] = \"\"\n\n            if not p[\"impostor\"] and g[\"phase\"] == \"play\":\n                if all(t[\"done\"] for t in g[\"tasks\"]):\n                    g[\"phase\"] = \"end\"; g[\"winner\"] = \"CREWMATES\"\n                    popup([\"All tasks complete!\", \"CREWMATES WIN!\"], title=\"[ WIN ]\", col=P_BG)\n\n            if tick[0] % 50 == 0 and peer_keys:\n                blob = {\"name\":p[\"name\"], \"x\":p[\"x\"], \"y\":p[\"y\"], \"skin\":p[\"skin\"],\n                        \"alive\":p[\"alive\"], \"ghost\":p.get(\"ghost\",False),\n                        \"tasks\":sum(1 for t in g[\"tasks\"] if t[\"done\"])}\n                threading.Thread(target=push, args=(blob,), daemon=True).start()\n\n            draw()\n            k = stdscr.getch()\n            if k == -1: time.sleep(0.016); continue\n\n            if g[\"phase\"] == \"end\":\n                if k in (ord('q'), ord('Q')): break\n                continue\n\n            nx, ny = p[\"x\"], p[\"y\"]\n            moved = False\n            if k in (curses.KEY_UP,    ord('w'), ord('W')): ny -= SPEED; moved = True\n            elif k in (curses.KEY_DOWN, ord('s'), ord('S')): ny += SPEED; moved = True\n            elif k in (curses.KEY_LEFT, ord('a'), ord('A')): nx -= SPEED; moved = True\n            elif k in (curses.KEY_RIGHT,ord('d'), ord('D')): nx += SPEED; moved = True\n            if moved and walkable(nx, ny): p[\"x\"] = nx; p[\"y\"] = ny\n\n            elif k in (ord('e'), ord('E')):\n                near_task = None\n                for i, t in enumerate(g[\"tasks\"]):\n                    if not t[\"done\"] and abs(p[\"x\"]-t[\"pos\"][0]) < 2 and abs(p[\"y\"]-t[\"pos\"][1]) < 2:\n                        near_task = (i, t); break\n                if near_task and not p[\"impostor\"]:\n                    i, t = near_task\n                    ok = do_task_minigame(t)\n                    if ok: t[\"done\"] = True; t[\"progress\"] = t[\"steps\"]; msg[0] = \"Task done: \" + t[\"name\"] + \" V\"\n                else:\n                    near_vent = None\n                    for vi, (vx, vy) in enumerate(VENT_POS):\n                        if abs(p[\"x\"]-vx) < 2 and abs(p[\"y\"]-vy) < 2: near_vent = vi; break\n                    if near_vent is not None:\n                        if p.get(\"impostor\"):\n                            if p.get(\"in_vent\"):\n                                opts = [\"Exit vent here\"] + [\"Jump -> vent \" + str(j+1) for j in range(len(VENT_POS)) if j != near_vent] + [\"Stay\"]\n                                sel = menu_popup(\"[ VENT ]\", opts, col=P_C)\n                                if sel == 0: p[\"in_vent\"] = False; p[\"vent_idx\"] = None; msg[0] = \"Exited vent.\"\n                                elif 1 <= sel <= len(VENT_POS):\n                                    dest = [j for j in range(len(VENT_POS)) if j != near_vent]\n                                    if dest:\n                                        dv = dest[min(sel-1, len(dest)-1)]\n                                        p[\"x\"] = float(VENT_POS[dv][0]); p[\"y\"] = float(VENT_POS[dv][1])\n                                        msg[0] = \"Jumped to vent \" + str(dv+1) + \"!\"\n                            else:\n                                p[\"in_vent\"] = True; p[\"vent_idx\"] = near_vent; msg[0] = \"In vent! E to jump/exit.\"\n                        else:\n                            msg[0] = \"Only impostors can use vents!\"\n                    else:\n                        msg[0] = \"Nothing nearby. Walk to * (task) or V (vent).\"\n\n            elif k in (ord('r'), ord('R')):\n                near_body = any(abs(p[\"x\"]-b[\"x\"]) < 3 and abs(p[\"y\"]-b[\"y\"]) < 3 for b in g[\"bodies\"])\n                if near_body: do_meeting(reporter=p[\"name\"])\n                else: msg[0] = \"No body nearby to report.\"\n\n            elif k in (ord('c'), ord('C')):\n                if abs(p[\"x\"]-MAP_W//2) < 8 and abs(p[\"y\"]-MAP_H//2) < 6:\n                    do_meeting(reporter=p[\"name\"])\n                else:\n                    msg[0] = \"Emergency button is at the centre of the map!\"\n\n            elif k in (ord('k'), ord('K')):\n                if not p.get(\"impostor\"): msg[0] = \"You're not the impostor!\"; continue\n                if p.get(\"kill_cd\",0) > 0: msg[0] = \"Kill cooldown: \" + str(p[\"kill_cd\"]//4) + \"s\"; continue\n                with _net_lock: snap = dict(_net_data)\n                victims = [(nm,st) for nm,st in snap.items()\n                           if st.get(\"alive\",True) and abs(p[\"x\"]-st.get(\"x\",999)) < 3 and abs(p[\"y\"]-st.get(\"y\",999)) < 3]\n                if not victims: msg[0] = \"No crewmates nearby.\"; continue\n                nm, st = victims[0]\n                g[\"bodies\"].append({\"name\":nm,\"x\":st[\"x\"],\"y\":st[\"y\"]})\n                g[\"meeting_log\"].append(nm + \" was killed near (\" + str(int(st[\"x\"])) + \",\" + str(int(st[\"y\"])) + \").\")\n                p[\"kills\"] += 1; p[\"kill_cd\"] = 15*4\n                msg[0] = \"Killed \" + nm + \"! Body left behind.\"\n\n            elif k in (ord('x'), ord('X')):\n                if not p.get(\"impostor\"): msg[0] = \"Impostors only!\"; continue\n                if p.get(\"sabotage_cd\",0) > 0: msg[0] = \"Sab cooldown: \" + str(p[\"sabotage_cd\"]//4) + \"s\"; continue\n                do_sabotage()\n\n            elif k in (ord('h'), ord('H')):\n                if p.get(\"impostor\"):\n                    popup([\"WASD       : Move\",\"E near V   : Enter / use vent\",\"K          : Kill nearby crewmate\",\n                           \"X          : Sabotage\",\"R          : Report body\",\"C          : Emergency meeting (map centre)\",\n                           \"H          : Help\",\"Q          : Quit\",\"\",\n                           \"Vents let you teleport across the ship.\",\n                           \"Sabotage to slow crewmates down.\",\n                           \"Kill all crewmates or stall tasks to win.\"],\n                          title=\"[ IMPOSTOR HELP ]\", col=P_BR)\n                else:\n                    popup([\"WASD       : Move\",\"E near *   : Do task\",\"R near X   : Report body\",\n                           \"C at centre: Emergency meeting\",\"H          : Help\",\"Q          : Quit\",\"\",\n                           \"Complete all * tasks to win!\",\"Watch for impostors sabotaging.\"],\n                          title=\"[ CREWMATE HELP ]\", col=P_BG)\n\n            elif k in (ord('q'), ord('Q')): break\n\n    # -- skin chooser (pre-game, runs in terminal) ------------------------------\n    def skin_chooser():\n        os.system(\"cls\" if os.name == \"nt\" else \"clear\")\n        print(\"\\033[96m\\033[1m  +======================================+\")\n        print(\"  |         SKIN CHOOSER                 |\")\n        print(\"  +======================================+\\033[0m\\n\")\n        for i, sk in enumerate(SKINS):\n            col_code = _ANSI.get(sk[\"col\"], \"\\033[37m\")\n            reset = \"\\033[0m\"\n            hat  = sk[\"hat\"]  if sk[\"hat\"].strip()  else \"   \"\n            body = sk[\"body\"]\n            print(\"  [\" + str(i) + \"] \" + col_code + hat + \"  \" + body + reset + \"  \" + sk[\"name\"])\n        print()\n        raw = input(\"  Choose skin [0-\" + str(len(SKINS)-1) + \"]: \").strip()\n        if raw.isdigit() and 0 <= int(raw) < len(SKINS):\n            return int(raw)\n        return 0\n\n    # -- lobby -----------------------------------------------------------------\n    os.system(\"cls\" if os.name == \"nt\" else \"clear\")\n    print(\"\\033[93m\\033[1m\")\n    print(\"  +==================================================+\")\n    print(\"  |                                                  |\")\n    print(\"  |    _^# #^_^# #^# #_ # #^^   # # #^             |\")\n    print(\"  |    #^# # ^ # #_# # ^# #_#   #_# _#             |\")\n    print(\"  |                                CLI               |\")\n    print(\"  |                                                  |\")\n    print(\"  |      Crewmates complete tasks.                   |\")\n    print(\"  |      Impostors kill everyone.                    |\")\n    print(\"  |      Trust. No. One.                             |\")\n    print(\"  |                                                  |\")\n    print(\"  +==================================================+\\033[0m\")\n    print()\n    print(\"  \\033[93m[S]\\033[0m Solo     \\033[96m[M]\\033[0m Multiplayer     \\033[91m[Q]\\033[0m Quit\")\n    mode = input(\"\\033[2m  > \\033[0m\").strip().lower()\n    if mode == \"q\": return\n\n    name = input(\"\\033[2m  Crewmate name: \\033[0m\").strip() or \"Crewmate\"\n    skin_idx = skin_chooser()\n\n    save_pref({\"name\": name, \"skin\": skin_idx})\n    peer_keys = {}\n\n    if mode == \"m\":\n        os.system(\"cls\" if os.name == \"nt\" else \"clear\")\n        print(\"\\033[96m\\033[1m  ===  MULTIPLAYER  ===\\033[0m\\n\")\n        print(\"  \\033[93m[H]\\033[0m Host   \\033[94m[J]\\033[0m Join\")\n        sub = input(\"\\033[2m  > \\033[0m\").strip().lower()\n        g = new_game(name, skin_idx)\n        blob = {\"name\":name,\"x\":g[\"player\"][\"x\"],\"y\":g[\"player\"][\"y\"],\"skin\":skin_idx,\n                \"alive\":True,\"ghost\":False,\"tasks\":0}\n        key = push(blob)\n        if key: print(\"\\033[97m\\033[1m  YOUR KEY: \" + key + \"\\033[0m\\n  paste.rs/\" + key + \"\\n  Share as: \" + name + \"|\" + key + \"\\n\")\n        raw = input(\"\\033[2m  Peer keys (Name|Key, comma-sep, blank=none): \\033[0m\").strip()\n        for part in raw.split(\",\"):\n            part = part.strip()\n            if \"|\" in part:\n                nm, k = part.split(\"|\", 1); peer_keys[nm.strip()] = k.strip()\n            elif part: peer_keys[\"P_\" + part[:6]] = part\n        if sub != \"h\":\n            key = push(blob)\n            if key: print(\"\\033[96m  Your ID: \" + key + \"  share as: \" + name + \"|\" + key + \"\\033[0m\")\n    else:\n        g = new_game(name, skin_idx)\n\n    print(\"\\n\\033[2m  Press ENTER to enter the ship...\\033[0m\"); input()\n    if peer_keys: threading.Thread(target=poll, args=(peer_keys,), daemon=True).start()\n    curses.wrapper(run_curses, g, peer_keys)\n    _stop_ev.set()\n\n    os.system(\"cls\" if os.name == \"nt\" else \"clear\")\n    p = g[\"player\"]\n    tasks_done = sum(1 for t in g[\"tasks\"] if t[\"done\"])\n    role = \"IMPOSTOR\" if p[\"impostor\"] else \"CREWMATE\"\n    print(\"\\033[93m\\033[1m  ===  AMONG US CLI - SESSION OVER  ===\\033[0m\")\n    print(\"  \" + p[\"name\"] + \" | \" + role + \" | Tasks: \" + str(tasks_done) + \"/\" + str(len(g[\"tasks\"])) + \" | Kills: \" + str(p.get(\"kills\",0)))\n    if g[\"winner\"]: print(\"  Winner: \" + str(g[\"winner\"]))\n    input(\"\\033[2m  ENTER to exit.\\033[0m\")\n    print()\n\n_game()"
        }
    ]
}